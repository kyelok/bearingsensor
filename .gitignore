# Host test build artifacts
host/build/

# TI CGT cross-compile artifacts (everything under build/, except the
# Makefiles that drive the build, which are source).
# Note: must use `build/*` pattern (not `build/`) for the `!` exception
# to take effect — git skips ignored directories entirely otherwise.
build/*
!build/Makefile.cross
!build/Makefile.legacy.cross
!build/Makefile.legacy.cross.O1
!build/Makefile.legacy.cross.O1heap
!build/Makefile.legacy.cross.O1nomt
!build/Makefile.legacy.cross.O1bootfix
!build/Makefile.legacy.cross.O1bootfix_nomt
!build/Makefile.legacy.cross.O1full
!build/Makefile.legacy.cgt18
!build/bearingwear.bootfix.cmd
!build/Makefile.hybrid
!build/Makefile.hybrid_pristine
!build/README.md

# Generated PDF documentation
docs-pdf/

# Local coverage matrix output (regenerable)
host/coverage_matrix.md

# Coverage instrumentation outputs (regenerable; from `make coverage`)
*.profraw
*.profdata
*.gcda
*.gcno
*.gcov
host/build/coverage-html/

# Generated Doxygen output
docs/html/
docs/latex/

# CCS / Eclipse workspace artifacts (created when CCS opens any dir
# as a workspace — pollutes the source tree with browser cache, etc.)
.jxbrowser-data/
.metadata/
RemoteSystemsTempFiles/
.settings/
.cproject
.project
SourceCode1/SPU_Firmware/FirmwareSource_6.20/.gitignore
SourceCode1/SPU_Firmware/FirmwareSource_6.20/.jxbrowser-data/
SourceCode1/SPU_Firmware/FirmwareSource_6.20/RemoteSystemsTempFiles/

