    </Button>
    <Button x:Name="buttonAll" Click="buttonAll_Click" Width="44" Height="44" HorizontalAlignment="Left" Margin="0,0,48,0" Grid.Row="1" VerticalAlignment="Bottom" Style="{StaticResource ButtonStyleAMOT}">
      <Button.Background>
        <SolidColorBrush Color="{StaticResource ColorAMOTButton}" />
      </Button.Background>
      <Button.Foreground>
        <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
      </Button.Foreground>
      <Grid>
        <Path Stretch="Fill" Data="F1 M32,0 L159.717,0 L159.717,448 L127.616,448 L127.616,480 L64,480 L64,448 L32,448 L32,0 z" Margin="0,0,20,12" UseLayoutRounding="False" HorizontalAlignment="Center" Height="28" Width="8" VerticalAlignment="Bottom" Fill="{Binding Foreground, ElementName=buttonAll}" />
