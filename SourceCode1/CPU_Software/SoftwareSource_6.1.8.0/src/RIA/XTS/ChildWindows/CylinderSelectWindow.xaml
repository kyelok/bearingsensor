      </Grid>
    </Button>
    <Button x:Name="OKButton" Click="OKButton_Click" Width="44" Height="44" HorizontalAlignment="Right" Margin="0,0,52,0" Grid.Row="1" VerticalAlignment="Bottom" Style="{StaticResource ButtonStyleAMOT}">
      <Button.Background>
        <SolidColorBrush Color="{StaticResource ColorAMOTButton}" />
      </Button.Background>
      <Button.Foreground>
        <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
