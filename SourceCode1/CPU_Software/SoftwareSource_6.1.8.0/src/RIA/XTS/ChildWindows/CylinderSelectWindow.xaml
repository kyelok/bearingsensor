        <TextBlock Margin="2,0,0,-0.364" TextWrapping="Wrap" Text="{Binding Path=ResourceStrings.XTSStringAll, Source={StaticResource LocalizedResources}}" FontSize="8" HorizontalAlignment="Left" VerticalAlignment="Bottom" />
      </Grid>
    </Button>
    <Button x:Name="buttonNone" Click="buttonNone_Click" Width="44" Height="44" HorizontalAlignment="Left" Grid.Row="1" VerticalAlignment="Bottom" Style="{StaticResource ButtonStyleAMOT}" Margin="48,0,0,0">
      <Button.Background>
        <SolidColorBrush Color="{StaticResource ColorAMOTButton}" />
      </Button.Background>
      <Button.Foreground>
        <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
      </Button.Foreground>
      <Grid>
        <Path Stretch="Fill" Data="F1 M32,0 L159.717,0 L159.717,448 L127.616,448 L127.616,480 L64,480 L64,448 L32,448 L32,0 z" Margin="0,0,20,12" UseLayoutRounding="False" Opacity="0.5" HorizontalAlignment="Center" Height="28" Width="8" VerticalAlignment="Bottom" Fill="{Binding Foreground, ElementName=buttonNone}" />
