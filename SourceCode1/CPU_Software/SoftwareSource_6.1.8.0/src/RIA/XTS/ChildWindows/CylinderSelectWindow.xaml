    mc:Ignorable="d"
    x:Class="XTS.ChildWindows.CylinderSelectWindow"
    Title="{Binding Path=ResourceStrings.XTSStringSelectCylinders, Source={StaticResource LocalizedResources}}" Style="{StaticResource ChildWindowStyleAMOT}"
    Loaded="CylinderSelectWindow_Loaded"
    Closing="CylinderSelectWindow_Closing"
    d:DesignWidth="377" d:DesignHeight="231"
    HasCloseButton="False">
