<controls:ChildWindow
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:System.Windows.Controls;assembly=System.Windows.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:XTS_Controls="clr-namespace:XTS.Controls"
    xmlns:XTS_ChildWindows="clr-namespace:XTS.ChildWindows"
    mc:Ignorable="d"
    x:Class="XTS.ChildWindows.EventLogWindow"
    Title="{Binding Path=ResourceStrings.XTSStringEventLog, Source={StaticResource LocalizedResources}}"
    Style="{StaticResource ChildWindowStyleAMOT}"
    HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
    d:DesignWidth="600" d:DesignHeight="400"
    Margin="44,66,44,200"
    HasCloseButton="False"
    Loaded="EventLogWindow_Loaded"
    Unloaded="EventLogWindow_Unloaded">
  <controls:ChildWindow.Resources>
    <XTS_ChildWindows:XTSAlarmAckDateTimeConverter x:Key="DateTimeConverter" />
        <XTS_ChildWindows:XTSTimeStampConverter x:Key="TimeStampConverter" />
        <DataTemplate x:Key="EventTemplate">
		<StackPanel HorizontalAlignment="Left" Orientation="Horizontal">
                <TextBlock Text="{Binding Path=Timestamp, Converter={StaticResource TimeStampConverter}}" Width="200"/>
	        <TextBlock Text="{Binding Path=Message}"  Width="400"/>
	        <TextBlock Text="{Binding Path=., Converter={StaticResource DateTimeConverter}}"  Width="200"/>
	        <TextBlock Text="{Binding Path=AckUser}"  Width="150"/>
		</StackPanel>
    </DataTemplate>
  </controls:ChildWindow.Resources>
  <Grid x:Name="LayoutRoot" Margin="2">
    <Grid.RowDefinitions>
      <RowDefinition />
      <RowDefinition Height="48" />
    </Grid.RowDefinitions>
    <Button x:Name="CancelButton" Click="CancelButton_Click" Width="44" Height="44" HorizontalAlignment="Right" Grid.Row="1" Style="{StaticResource ButtonStyleAMOT}" VerticalAlignment="Bottom">
      <Button.Foreground>
        <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
      </Button.Foreground>
      <Button.Background>
        <SolidColorBrush Color="{StaticResource ColorAMOTButton}" />
      </Button.Background>
      <Grid>
        <TextBlock Margin="2,0,0,0" TextWrapping="Wrap" Text="{Binding Path=ResourceStrings.XTSStringClose, Source={StaticResource LocalizedResources}}" HorizontalAlignment="Left" VerticalAlignment="Bottom" FontSize="8" />
        <Path Stretch="Fill" Data="F1 M 400,224C 400,237.255 389.255,248 376,248L 280,248C 266.745,248 256,237.255 256,224L 256,128C 256,114.745 266.745,104 280,104L 376,104C 389.255,104 400,114.745 400,128L 400,224 Z M 272,136L 312,176L 272,216L 288,232L 328,192L 368,232L 384,216L 344,176L 384,136L 368,120L 328,160L 288,120L 272,136 Z " Margin="8,4,8,0" UseLayoutRounding="False" Fill="{Binding Foreground, ElementName=CancelButton}" Height="28" VerticalAlignment="Top" />
      </Grid>
    </Button>
    <XTS_Controls:ContentScroll x:Name="EventLogList" >
    	<XTS_Controls:ContentScroll.Foreground>
    		<SolidColorBrush Color="{StaticResource ColorAMOTText}"/>
    	</XTS_Controls:ContentScroll.Foreground>
    </XTS_Controls:ContentScroll>
    <Button x:Name="buttonPrevious" HorizontalAlignment="Left" Width="44" Style="{StaticResource ButtonStyleAMOT}" Grid.Row="1" Height="44" VerticalAlignment="Bottom" Click="buttonPrevious_Click" IsEnabled="False">
      <Button.Foreground>
        <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
      </Button.Foreground>
      <Button.Background>
        <SolidColorBrush Color="{StaticResource ColorAMOTButton}" />
      </Button.Background>
      <Grid>
        <TextBlock Margin="2,0,0,0" TextWrapping="Wrap" Text="{Binding Path=ResourceStrings.XTSStringPrevious, Source={StaticResource LocalizedResources}}" HorizontalAlignment="Left" VerticalAlignment="Bottom" FontSize="8" />
        <Path x:Name="path_Copy" Width="18" Height="16" Stretch="Fill" Data="F1 M 23.9063,22.5L 21.9063,24.5L 14.9063,31.75L 14.9063,25.25L 23.9063,15.75L 32.9063,25.25L 32.9063,31.75L 25.9063,24.5L 23.9063,22.5 Z " HorizontalAlignment="Center" VerticalAlignment="Center" UseLayoutRounding="False" Fill="{Binding Foreground, ElementName=buttonPrevious}" Margin="0,0,0,8" RenderTransformOrigin="0.5,0.5">
          <Path.RenderTransform>
            <CompositeTransform Rotation="270" />
          </Path.RenderTransform>
        </Path>
      </Grid>
    </Button>
    <Button x:Name="buttonNext" HorizontalAlignment="Left" Width="44" Style="{StaticResource ButtonStyleAMOT}" Grid.Row="1" VerticalAlignment="Bottom" Height="44" Margin="48,0,0,0" Click="buttonNext_Click">
      <Button.Background>
        <SolidColorBrush Color="{StaticResource ColorAMOTButton}" />
      </Button.Background>
      <Button.Foreground>
        <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
      </Button.Foreground>
      <Grid>
        <TextBlock Margin="2,0,0,0" TextWrapping="Wrap" Text="{Binding Path=ResourceStrings.XTSStringNext, Source={StaticResource LocalizedResources}}" HorizontalAlignment="Left" VerticalAlignment="Bottom" FontSize="8" />
        <Path x:Name="path_Copy1" Width="18" Height="16" Stretch="Fill" Data="F1 M 23.9063,22.5L 21.9063,24.5L 14.9063,31.75L 14.9063,25.25L 23.9063,15.75L 32.9063,25.25L 32.9063,31.75L 25.9063,24.5L 23.9063,22.5 Z " HorizontalAlignment="Center" VerticalAlignment="Center" UseLayoutRounding="False" Fill="{Binding Foreground, ElementName=buttonNext}" RenderTransformOrigin="0.5,0.5" Margin="0,0,0,8">
          <Path.RenderTransform>
            <CompositeTransform Rotation="90" />
          </Path.RenderTransform>
        </Path>
      </Grid>
    </Button>
  </Grid>
</controls:ChildWindow>