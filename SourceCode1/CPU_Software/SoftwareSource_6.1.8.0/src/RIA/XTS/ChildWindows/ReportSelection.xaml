          </Grid>
        </Border>
      </DataTemplate>
    </Grid.Resources>
    <Grid.RowDefinitions>
      <RowDefinition />
      <RowDefinition Height="48" />
    </Grid.RowDefinitions>
    <Path Stretch="Fill" Data="F1 M 29.9991,24.9009C 31.5379,24.874 32.962,25.4967 34.1175,26.3385L 30.1213,31.8998L 36.8015,33.9978C 35.9237,36.7943 33.3352,38.8448 30.2435,38.8988C 26.3781,38.9662 23.1898,35.8874 23.1224,32.022C 23.0549,28.1566 26.1337,24.9684 29.9991,24.9009 Z M 12,11L 26.5,11L 34,18.5L 34,24.7186L 32,23.6871L 32,21L 24,21L 24,13L 14,13L 14,35L 21.6473,35C 21.8623,35.7224 22.1908,36.396 22.6121,37L 12,37L 12,11 Z M 26,13.5001L 26,19L 31.4999,19L 26,13.5001 Z M 21,33L 16,33L 16,31L 21,31L 21,33 Z M 22,30L 16,30L 16,28L 22,28L 22,30 Z M 16,27L 16,25L 23,25L 23,27L 16,27 Z " HorizontalAlignment="Right" Height="540" UseLayoutRounding="False" VerticalAlignment="Top" Width="500" Margin="0,20,20,0">
      <Path.Fill>
        <SolidColorBrush Color="{StaticResource ColorAMOTBGIcon}" />
      </Path.Fill>
    </Path>
    <Grid Grid.Row="0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="272" />
        <ColumnDefinition Width="4" />
        <ColumnDefinition />
      </Grid.ColumnDefinitions>
      <ScrollViewer Style="{StaticResource ScrollViewerStyleAMOTButtons}">
        <ScrollViewer.Foreground>
          <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
        </ScrollViewer.Foreground>
        <ScrollViewer.Background>
          <SolidColorBrush Color="{StaticResource ColorAMOTBlue}" />
        </ScrollViewer.Background>
        <ListBox x:Name="ReportItems" ItemTemplate="{StaticResource ReportListTemplate}" Background="{x:Null}" BorderBrush="{x:Null}">
          <ListBox.Foreground>
            <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
          </ListBox.Foreground>
        </ListBox>
      </ScrollViewer>

            <telerik:RadHtmlPlaceholder Grid.Column="2" ScrollViewer.HorizontalScrollBarVisibility="Disabled" 
                                        ScrollViewer.VerticalScrollBarVisibility="Disabled" 
                                       x:Name="htmlReportPage" Visibility="Collapsed"/>
               
    </Grid>
    <Button x:Name="CancelButton" Click="CancelButton_Click" Width="44" Height="44" HorizontalAlignment="Right" Grid.Row="1" Style="{StaticResource ButtonStyleAMOT}" VerticalAlignment="Bottom">
      <Button.Background>
        <SolidColorBrush Color="{StaticResource ColorAMOTButton}" />
      </Button.Background>
      <Button.Foreground>
        <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
      </Button.Foreground>
      <Grid>
        <sdk:Label Margin="2,0,0,0" VerticalAlignment="Bottom" FontSize="8" Content="{Binding Path=ResourceStrings.XTSStringClose, Source={StaticResource LocalizedResources}}" >
          <sdk:Label.Foreground>
            <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
          </sdk:Label.Foreground>
        </sdk:Label>
        <Path Stretch="Fill" Data="F1 M 400,224C 400,237.255 389.255,248 376,248L 280,248C 266.745,248 256,237.255 256,224L 256,128C 256,114.745 266.745,104 280,104L 376,104C 389.255,104 400,114.745 400,128L 400,224 Z M 272,136L 312,176L 272,216L 288,232L 328,192L 368,232L 384,216L 344,176L 384,136L 368,120L 328,160L 288,120L 272,136 Z " Margin="8,4,8,12" UseLayoutRounding="False" Fill="{Binding Foreground, ElementName=CancelButton}" />
      </Grid>
    </Button>
    <Button x:Name="buttonDownload" HorizontalAlignment="Left" Margin="0,0,48,0" Grid.Row="1" Width="44" Style="{StaticResource ButtonStyleAMOT}" VerticalAlignment="Bottom" Height="44" Click="buttonDownload_Click" IsEnabled="False">
    	<Button.Foreground>
    		<SolidColorBrush Color="{StaticResource ColorAMOTText}"/>
    	</Button.Foreground>
    	<Button.Background>
    		<SolidColorBrush Color="{StaticResource ColorAMOTButton}"/>
    	</Button.Background>
    	<Grid>
    		<Path Stretch="Fill" Data="F1 M 30,24L 36,24L 36,30L 41,30L 33,38L 25,30L 30,30L 30,24 Z M 13,13L 31,13L 35,17L 35,23L 32.9999,23L 32.9999,18.0001L 30,15L 29,15L 29,23L 28,23L 18,23L 18,15L 15,15.0001L 15,33L 26,33L 28,35L 13,35L 13,13 Z M 25,15L 25,21L 27,21L 27,15L 25,15 Z " Margin="6,4,0,0" UseLayoutRounding="False" Fill="{Binding Foreground, ElementName=buttonDownload}" Width="33" Height="28" HorizontalAlignment="Center" VerticalAlignment="Top" />
    		<TextBlock Margin="0" TextWrapping="Wrap" Text="{Binding ResourceStrings.XTSStringDownload, Source={StaticResource LocalizedResources}}" VerticalAlignment="Bottom" HorizontalAlignment="Left" FontSize="8" Visibility="Visible" />
    	</Grid>
    </Button>
  </Grid>
</sdk:ChildWindow>