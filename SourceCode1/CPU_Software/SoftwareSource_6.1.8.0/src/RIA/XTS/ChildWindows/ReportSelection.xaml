    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:System.Windows.Controls;assembly=System.Windows.Controls"
    xmlns:sdk="http://schemas.microsoft.com/winfx/2006/xaml/presentation/sdk"
    xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
    xmlns:xtscontrols="clr-namespace:XTS.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    x:Class="XTS.ChildWindows.ReportSelection"
    Title="{Binding Path=ResourceStrings.XTSStringReportSelection, Source={StaticResource LocalizedResources}}"
    Style="{StaticResource ChildWindowStyleAMOT}"
    HasCloseButton="False"
    Loaded="ReportSelection_Loaded"
    Unloaded="ReportSelection_Unloaded"
    Margin="22"
    HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
    d:DesignWidth="1024" d:DesignHeight="768">
  <Grid x:Name="LayoutRoot" Margin="2">
    <Grid.Resources>
      <DataTemplate x:Key="ReportListTemplate">
        <Border BorderThickness="1" BorderBrush="#77FFFFFF" Width="252" Height="44" HorizontalAlignment="Stretch">
          <Grid>
            <Grid.Background>
              <SolidColorBrush Color="{StaticResource ColorAMOTButton}" />
            </Grid.Background>
            <Grid.ColumnDefinitions>
              <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <TextBlock Text="{Binding}" HorizontalAlignment="Left" Grid.Column="0" VerticalAlignment="Center" FontSize="14" Margin="4,0" d:LayoutOverrides="GridBox">
              <TextBlock.Foreground>
                <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
              </TextBlock.Foreground>
            </TextBlock>

