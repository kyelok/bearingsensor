<sdk:ChildWindow
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sdk="http://schemas.microsoft.com/winfx/2006/xaml/presentation/sdk"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:XTS_Controls="clr-namespace:XTS.Controls"
    mc:Ignorable="d"
    x:Class="XTS.TrendConfigName"
    Title="{Binding Path=ResourceStrings.XTSStringConfigurationName, Source={StaticResource LocalizedResources}}"
    Width="400" Height="200"
    HasCloseButton="False">
  <sdk:ChildWindow.Style>
    <StaticResource ResourceKey="ChildWindowStyleAMOT" />
  </sdk:ChildWindow.Style>
  <Grid x:Name="LayoutRoot">
    <Grid.RowDefinitions>
      <RowDefinition />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>
    <Path Stretch="Fill" Data="F1 M 11,12L 13,12L 13,34L 37,34L 37,36L 11,36L 11,12 Z M 14,33L 14,30L 20,23L 29,27L 37,13L 37,17L 30,30L 20,26L 14,33 Z " Height="240" Margin="11,0,0,8" UseLayoutRounding="False" Width="260" HorizontalAlignment="Left" VerticalAlignment="Bottom" Grid.RowSpan="2">
      <Path.Fill>
        <SolidColorBrush Color="{StaticResource ColorAMOTBGIcon}" />
      </Path.Fill>
    </Path>
    <Button x:Name="CancelButton" Style="{StaticResource ButtonStyleAMOT}" Click="CancelButton_Click" Width="44" Height="44" HorizontalAlignment="Right" Grid.Row="1" VerticalAlignment="Bottom" d:LayoutOverrides="VerticalAlignment">
      <Button.Background>
        <SolidColorBrush Color="{StaticResource ColorAMOTButton}" />
      </Button.Background>
      <Button.Foreground>
        <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
      </Button.Foreground>
      <Grid>
        <sdk:Label Margin="2,0,0,0" VerticalAlignment="Bottom" d:LayoutOverrides="Width" FontSize="8" Content="{Binding Path=ResourceStrings.XTSStringCancel, Source={StaticResource LocalizedResources}}" >
          <sdk:Label.Foreground>
            <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
          </sdk:Label.Foreground>
        </sdk:Label>
        <Path Stretch="Fill" Data="F1 M 400,224C 400,237.255 389.255,248 376,248L 280,248C 266.745,248 256,237.255 256,224L 256,128C 256,114.745 266.745,104 280,104L 376,104C 389.255,104 400,114.745 400,128L 400,224 Z M 272,136L 312,176L 272,216L 288,232L 328,192L 368,232L 384,216L 344,176L 384,136L 368,120L 328,160L 288,120L 272,136 Z " Margin="8,4,8,12" UseLayoutRounding="False" Fill="{Binding Foreground, ElementName=CancelButton}" />
      </Grid>
    </Button>
    <Button x:Name="OKButton" Style="{StaticResource ButtonStyleAMOT}" Click="OKButton_Click" Width="44" Height="44" HorizontalAlignment="Right" Grid.Row="1" d:LayoutOverrides="HorizontalAlignment" VerticalAlignment="Center" Margin="0,0,52,0">
      <Button.Background>
        <SolidColorBrush Color="{StaticResource ColorAMOTButton}" />
      </Button.Background>
      <Button.Foreground>
        <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
      </Button.Foreground>
      <Grid>
        <sdk:Label Margin="2,0,0,0" VerticalAlignment="Bottom" d:LayoutOverrides="Width" FontSize="8" Content="{Binding Path=ResourceStrings.XTSStringOK, Source={StaticResource LocalizedResources}}" >
          <sdk:Label.Foreground>
            <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
          </sdk:Label.Foreground>
        </sdk:Label>
        <Path Stretch="Fill" Data="F1 M 256,112L 257.947,112.078L 344,112L 344,112.123C 357.24,112.123 367.976,122.845 368,136.123L 368,232.123C 368,245.378 357.255,256.123 344,256.123L 342.052,256.045L 256,256.123C 242.745,256.123 232,245.378 232,232.08L 232,136C 232,122.745 242.745,112 256,112 Z M 353.094,140.14L 336,128L 289.684,206.583L 256,176L 243.146,192L 296,240L 353.094,140.14 Z " Margin="8,4,8,12" UseLayoutRounding="False" Fill="{Binding Foreground, ElementName=OKButton}" />
      </Grid>
    </Button>
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition />
        <RowDefinition Height="Auto" />
        <RowDefinition />
      </Grid.RowDefinitions>
      <Grid.ColumnDefinitions>
        <ColumnDefinition />
      </Grid.ColumnDefinitions>
      <XTS_Controls:InputBox x:Name="textBoxDescription" TextWrapping="NoWrap" Text="TextBox" VerticalAlignment="Center" FontSize="28" Grid.Row="1" Margin="0" HorizontalAlignment="Left" Width="382">
        <XTS_Controls:InputBox.Background>
          <SolidColorBrush Color="{StaticResource ColorAMOTBackground}" />
        </XTS_Controls:InputBox.Background>
      </XTS_Controls:InputBox>
      <sdk:Label HorizontalAlignment="Left" VerticalAlignment="Bottom" Content="{Binding Path=ResourceStrings.XTSStringConfigDescriptionC, Source={StaticResource LocalizedResources}}" Margin="2,0,0,0" Foreground="Black" />
    </Grid>
  </Grid>
</sdk:ChildWindow>