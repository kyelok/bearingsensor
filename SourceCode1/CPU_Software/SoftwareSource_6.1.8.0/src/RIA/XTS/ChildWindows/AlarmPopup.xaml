<sdk:ChildWindow 
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:System.Windows.Controls;assembly=System.Windows.Controls"
    xmlns:sdk="http://schemas.microsoft.com/winfx/2006/xaml/presentation/sdk"
    xmlns:local="clr-namespace:XTS"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d" x:Class="XTS.ChildWindows.AlarmPopup"
    Width="600" Height="200"
    Title="{Binding Path=ResourceStrings.XTSStringAlarm, Source={StaticResource LocalizedResources}}"
    Loaded="AlarmPopup_Loaded"
    Unloaded="AlarmPopup_Unloaded"
    HasCloseButton="False">
  <sdk:ChildWindow.Foreground>
    <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
  </sdk:ChildWindow.Foreground>
  <sdk:ChildWindow.Style>
    <StaticResource ResourceKey="ChildWindowStyleAMOT" />
  </sdk:ChildWindow.Style>
  <Grid x:Name="LayoutRoot" Margin="2">
    <Grid.RowDefinitions>
      <RowDefinition Height="22" />
      <RowDefinition />
      <RowDefinition Height="44"/>
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>
    <Path Stretch="Fill" Data="F1 M 24,14C 26,14 36,33 35,34C 34,35 14,35 13,34C 12,33 22,14 24,14 Z M 24,29C 23.1716,29 22.5,29.6716 22.5,30.5C 22.5,31.3284 23.1716,32 24,32C 24.8284,32 25.5,31.3284 25.5,30.5C 25.5,29.6716 24.8284,29 24,29 Z M 22.5,20L 23,28L 25,28L 25.5,20L 22.5,20 Z " UseLayoutRounding="False" HorizontalAlignment="Left" VerticalAlignment="Top" Width="200" Height="160" Grid.RowSpan="4" Margin="-20,-20,0,0">
      <Path.Fill>
        <SolidColorBrush Color="{StaticResource ColorAMOTBGIcon}" />
      </Path.Fill>
    </Path>
    <Button Grid.Row="3" x:Name="LoginButton" Click="LoginButton_Click" Width="44" Height="44" HorizontalAlignment="Left" Margin="0" Style="{StaticResource ButtonStyleAMOT}">
      <Button.Background>
        <SolidColorBrush Color="{StaticResource ColorAMOTButton}" />
      </Button.Background>
      <Button.Foreground>
        <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
      </Button.Foreground>
      <Grid>
        <TextBlock Margin="2,0,0,0" TextWrapping="Wrap" Text="{Binding Path=ResourceStrings.XTSStringLogOn, Source={StaticResource LocalizedResources}}" HorizontalAlignment="Left" VerticalAlignment="Bottom" FontSize="8" />
        <Path Stretch="Fill" Data="F1 M 19,13C 22.866,13 26,16.134 26,20C 26,20.7866 25.8702,21.5429 25.631,22.2487L 26.0273,22.5473L 27,24.25L 29.025,23.5541L 28.465,27.2023L 31.6177,26.76L 31.5113,30.3109L 35,28.5L 35.9627,29.4705L 37,34.5723L 32.7986,35.1627L 21.404,26.5763C 20.6543,26.8504 19.8446,27 19,27C 15.134,27 12,23.866 12,20C 12,16.134 15.134,13 19,13 Z M 17,16.5C 16.1716,16.5 15.5,17.1716 15.5,18C 15.5,18.8284 16.1716,19.5 17,19.5C 17.8284,19.5 18.5,18.8284 18.5,18C 18.5,17.1716 17.8284,16.5 17,16.5 Z " Margin="8,4,8,0" UseLayoutRounding="False" Fill="{Binding Foreground, ElementName=CancelButton}" Height="28" VerticalAlignment="Top" />
      </Grid>
    </Button>
    <StackPanel Grid.Row="3" HorizontalAlignment="Right" Orientation="Horizontal">
      <Button x:Name="OKButton" Click="OKButton_Click" Width="44" Height="44" Style="{StaticResource ButtonStyleAMOT}" Margin="8,0,0,0">
        <Button.Background>
          <SolidColorBrush Color="{StaticResource ColorAMOTButton}" />
        </Button.Background>
        <Button.Foreground>
          <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
        </Button.Foreground>
        <Grid>
          <TextBlock Margin="2,0,0,0" TextWrapping="Wrap" Text="{Binding Path=ResourceStrings.XTSStringOK, Source={StaticResource LocalizedResources}}" HorizontalAlignment="Left" VerticalAlignment="Bottom" FontSize="8" />
          <Path Stretch="Fill" Data="F1 M 256,112L 257.947,112.078L 344,112L 344,112.123C 357.24,112.123 367.976,122.845 368,136.123L 368,232.123C 368,245.378 357.255,256.123 344,256.123L 342.052,256.045L 256,256.123C 242.745,256.123 232,245.378 232,232.08L 232,136C 232,122.745 242.745,112 256,112 Z M 353.094,140.14L 336,128L 289.684,206.583L 256,176L 243.146,192L 296,240L 353.094,140.14 Z " Margin="8,4,8,12" UseLayoutRounding="False" Fill="{Binding Foreground, ElementName=OKButton}" />
        </Grid>
      </Button>
      <Button x:Name="CancelButton" Click="CancelButton_Click" Width="44" Height="44" Margin="8,0,0,0" Style="{StaticResource ButtonStyleAMOT}">
        <Button.Background>
          <SolidColorBrush Color="{StaticResource ColorAMOTButton}" />
        </Button.Background>
        <Button.Foreground>
          <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
        </Button.Foreground>
        <Grid>
          <TextBlock Margin="2,0,0,0" TextWrapping="Wrap" Text="{Binding Path=ResourceStrings.XTSStringIgnore, Source={StaticResource LocalizedResources}}" HorizontalAlignment="Left" VerticalAlignment="Bottom" FontSize="8" />
          <Path Stretch="Fill" Data="F1 M 400,224C 400,237.255 389.255,248 376,248L 280,248C 266.745,248 256,237.255 256,224L 256,128C 256,114.745 266.745,104 280,104L 376,104C 389.255,104 400,114.745 400,128L 400,224 Z M 272,136L 312,176L 272,216L 288,232L 328,192L 368,232L 384,216L 344,176L 384,136L 368,120L 328,160L 288,120L 272,136 Z " Margin="8,4,8,0" UseLayoutRounding="False" Fill="{Binding Foreground, ElementName=CancelButton}" Height="28" VerticalAlignment="Top" />
        </Grid>
      </Button>
    </StackPanel>
    <sdk:Label x:Name="TextBlockMessage" VerticalAlignment="Center" Height="44" FontSize="16" HorizontalContentAlignment="Center" Margin="0" Grid.Row="1">
      <sdk:Label.Background>
        <SolidColorBrush Color="{StaticResource ColorAMOTError}" />
      </sdk:Label.Background>
    </sdk:Label>
    <TextBlock x:Name="TextBlockCount" HorizontalAlignment="Right" Margin="0,0,8,0" TextWrapping="Wrap" Text="0" d:LayoutOverrides="Height" Grid.Row="2" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" Visibility="Collapsed"/>
  </Grid>
</sdk:ChildWindow>