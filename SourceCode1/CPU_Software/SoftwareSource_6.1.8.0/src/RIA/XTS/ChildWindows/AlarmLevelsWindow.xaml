<controls:ChildWindow
           xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" 
           xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" 
           xmlns:controls="clr-namespace:System.Windows.Controls;assembly=System.Windows.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:sdk="http://schemas.microsoft.com/winfx/2006/xaml/presentation/sdk"
    mc:Ignorable="d"
    x:Class="XTS.ChildWindows.AlarmLevelsWindow"
           Width="400" Height="200" 
    Title="{Binding Path=ResourceStrings.XTSStringSelectAlarmThresholds, Source={StaticResource LocalizedResources}}"
    Loaded="AlarmLevelsWindow_Loaded"
    HasCloseButton="False">
	<controls:ChildWindow.Style>
    <StaticResource ResourceKey="ChildWindowStyleAMOT" />
	</controls:ChildWindow.Style>
    <Grid x:Name="LayoutRoot" Margin="2">
    	<Grid.ColumnDefinitions>
    		<ColumnDefinition Width="0.512*" />
    		<ColumnDefinition Width="4" />
      <ColumnDefinition Width="0.488*" />
    	</Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
        	<RowDefinition />
        	<RowDefinition Height="48" />
        </Grid.RowDefinitions>
    	<Grid Margin="0">
    		<Grid.Background>
        <SolidColorBrush Color="{StaticResource ColorAMOTBlue}" />
    		</Grid.Background>
      <sdk:Label HorizontalAlignment="Left" VerticalAlignment="Bottom" Content="{Binding Path=ResourceStrings.XTSStringAlarm, Source={StaticResource LocalizedResources}}" Margin="2,0,0,0">
    			<sdk:Label.Foreground>
          <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
    			</sdk:Label.Foreground>
    		</sdk:Label>
      <Button Content="{Binding Path=ResourceStrings.XTSStringButtonUpArrow, Source={StaticResource LocalizedResources}}" Click="buttonAlarmUp_Click" Style="{StaticResource ButtonStyleAMOTNavigationUp}" HorizontalAlignment="Center" Width="88" VerticalAlignment="Top" Margin="4" Height="34">
    			<Button.Background>
          <SolidColorBrush Color="{StaticResource ColorAMOTButton}" />
    			</Button.Background>
    			<Button.Foreground>
          <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
    			</Button.Foreground>
    		</Button>
      <Button Content="{Binding Path=ResourceStrings.XTSStringButtonDownArrow, Source={StaticResource LocalizedResources}}" Height="34" VerticalAlignment="Bottom" Click="buttonAlarmDown_Click" Style="{StaticResource ButtonStyleAMOTNavigationDown}" HorizontalAlignment="Center" Width="88" Margin="4">
    			<Button.Background>
          <SolidColorBrush Color="{StaticResource ColorAMOTButton}" />
    			</Button.Background>
    			<Button.Foreground>
          <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
    			</Button.Foreground>
    		</Button>
      <sdk:Label Content="{Binding Path=ResourceStrings.XTSStringLabel400, Source={StaticResource LocalizedResources}}" HorizontalAlignment="Center" VerticalAlignment="Center" x:Name="labelAlarmLevel" FontSize="24" FontWeight="Bold">
    			<sdk:Label.Foreground>
          <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
    			</sdk:Label.Foreground>
    		</sdk:Label>
    		<Path Stretch="Fill" Data="F1 M 24,14C 26,14 36,33 35,34C 34,35 14,35 13,34C 12,33 22,14 24,14 Z M 24,29C 23.1716,29 22.5,29.6716 22.5,30.5C 22.5,31.3284 23.1716,32 24,32C 24.8284,32 25.5,31.3284 25.5,30.5C 25.5,29.6716 24.8284,29 24,29 Z M 22.5,20L 23,28L 25,28L 25.5,20L 22.5,20 Z "
    			Margin="4,4,0,0" UseLayoutRounding="False" HorizontalAlignment="Left" VerticalAlignment="Top" Width="28" Height="25">
    			<Path.Fill>
          <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
    			</Path.Fill>
    		</Path>
    	</Grid>
    	<Grid Grid.Column="2" Margin="0" d:LayoutOverrides="GridBox">
    		<Grid.Background>
        <SolidColorBrush Color="{StaticResource ColorAMOTBlue}" />
    		</Grid.Background>
      <sdk:Label HorizontalAlignment="Left" VerticalAlignment="Bottom" Content="{Binding Path=ResourceStrings.XTSStringSlowdown, Source={StaticResource LocalizedResources}}" Margin="2,0,0,0">
    			<sdk:Label.Foreground>
          <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
    			</sdk:Label.Foreground>
    		</sdk:Label>
      <Button Content="{Binding Path=ResourceStrings.XTSStringButtonUpArrow, Source={StaticResource LocalizedResources}}" Click="buttonSlowdownUp_Click" Style="{StaticResource ButtonStyleAMOTNavigationUp}" HorizontalAlignment="Center" Width="88" d:LayoutOverrides="GridBox" Height="34" VerticalAlignment="Top" Margin="4">
    			<Button.Background>
          <SolidColorBrush Color="{StaticResource ColorAMOTButton}" />
    			</Button.Background>
    			<Button.Foreground>
          <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
    			</Button.Foreground>
    		</Button>
      <Button Content="{Binding Path=ResourceStrings.XTSStringButtonDownArrow, Source={StaticResource LocalizedResources}}" Height="34" VerticalAlignment="Bottom" Click="buttonSlowdownDown_Click" Style="{StaticResource ButtonStyleAMOTNavigationDown}" HorizontalAlignment="Center" Width="88" d:LayoutOverrides="GridBox" Margin="4">
    			<Button.Background>
          <SolidColorBrush Color="{StaticResource ColorAMOTButton}" />
    			</Button.Background>
    			<Button.Foreground>
          <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
    			</Button.Foreground>
    		</Button>
      <sdk:Label Content="{Binding Path=ResourceStrings.XTSStringLabel700, Source={StaticResource LocalizedResources}}" HorizontalAlignment="Center" VerticalAlignment="Center" x:Name="labelSlowdownLevel" FontSize="24" FontWeight="Bold">
    			<sdk:Label.Foreground>
          <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
    			</sdk:Label.Foreground>
    		</sdk:Label>
    		<Path Stretch="Fill" Data="F1 M 20,12L 28,12L 36,20L 36,28L 28,36L 20,36L 12,28L 12,20L 20,12 Z M 16.7218,28.4497L 19.5502,31.2782L 24,26.8284L 28.4497,31.2782L 31.2781,28.4497L 26.8284,24L 31.2782,19.5503L 28.4497,16.7218L 24,21.1716L 19.5502,16.7218L 16.7218,19.5503L 21.1716,24L 16.7218,28.4497 Z " HorizontalAlignment="Left" Height="28" Margin="4,4,0,0" UseLayoutRounding="False" VerticalAlignment="Top" Width="28">
    			<Path.Fill>
          <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
    			</Path.Fill>
    		</Path>
    	</Grid>
    <Button x:Name="OKButton" Click="OKButton_Click" Height="44" Style="{StaticResource ButtonStyleAMOT}" Margin="0,0,52,0" VerticalAlignment="Bottom" d:LayoutOverrides="Height" Grid.Row="1" Grid.Column="2" HorizontalAlignment="Right" Width="44">
    		<Button.Background>
        <SolidColorBrush Color="{StaticResource ColorAMOTButton}" />
    		</Button.Background>
    		<Button.Foreground>
        <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
    		</Button.Foreground>
    		<Grid>
        <TextBlock Margin="2,0,0,0" TextWrapping="Wrap" Text="{Binding Path=ResourceStrings.XTSStringOK, Source={StaticResource LocalizedResources}}" d:LayoutOverrides="Width, Height" HorizontalAlignment="Left" VerticalAlignment="Bottom" FontSize="8" />
        <Path Stretch="Fill" Data="F1 M 256,112L 257.947,112.078L 344,112L 344,112.123C 357.24,112.123 367.976,122.845 368,136.123L 368,232.123C 368,245.378 357.255,256.123 344,256.123L 342.052,256.045L 256,256.123C 242.745,256.123 232,245.378 232,232.08L 232,136C 232,122.745 242.745,112 256,112 Z M 353.094,140.14L 336,128L 289.684,206.583L 256,176L 243.146,192L 296,240L 353.094,140.14 Z " Margin="8,4,8,12" UseLayoutRounding="False" Fill="{Binding Foreground, ElementName=OKButton}" />
    		</Grid>
    	</Button>
    <Button x:Name="CancelButton" Click="CancelButton_Click" Width="44" Height="44" HorizontalAlignment="Right" Style="{StaticResource ButtonStyleAMOT}" VerticalAlignment="Bottom" d:LayoutOverrides="Height" Grid.Row="1" Grid.Column="2">
    		<Button.Background>
        <SolidColorBrush Color="{StaticResource ColorAMOTButton}" />
    		</Button.Background>
    		<Button.Foreground>
        <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
    		</Button.Foreground>
    		<Grid>
        <TextBlock Margin="2,0,0,0" TextWrapping="Wrap" Text="{Binding Path=ResourceStrings.XTSStringCancel, Source={StaticResource LocalizedResources}}" HorizontalAlignment="Left" VerticalAlignment="Bottom" FontSize="8" />
        <Path Stretch="Fill" Data="F1 M 400,224C 400,237.255 389.255,248 376,248L 280,248C 266.745,248 256,237.255 256,224L 256,128C 256,114.745 266.745,104 280,104L 376,104C 389.255,104 400,114.745 400,128L 400,224 Z M 272,136L 312,176L 272,216L 288,232L 328,192L 368,232L 384,216L 344,176L 384,136L 368,120L 328,160L 288,120L 272,136 Z " Margin="8,4,8,12" UseLayoutRounding="False" Fill="{Binding Foreground, ElementName=CancelButton}" />
    		</Grid>
    	</Button>
    </Grid>
</controls:ChildWindow>