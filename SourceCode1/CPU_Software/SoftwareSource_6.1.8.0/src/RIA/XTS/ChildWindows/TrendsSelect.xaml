<sdk:ChildWindow
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:System.Windows.Controls;assembly=System.Windows.Controls"
    xmlns:sdk="http://schemas.microsoft.com/winfx/2006/xaml/presentation/sdk"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    x:Class="XTS.ChildWindows.TrendsSelect"
    Title="{Binding Path=ResourceStrings.XTSStringSelectTrendsForCurrentConfiguration, Source={StaticResource LocalizedResources}}"
    Style="{StaticResource ChildWindowStyleAMOT}"
    HasCloseButton="False"
    Loaded="TrendsSelect_Loaded">
  <Grid x:Name="LayoutRoot" Margin="2">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="48" />
    </Grid.RowDefinitions>
    <StackPanel Margin="0,0,0,0" Orientation="Vertical" HorizontalAlignment="Center">
      <Grid Margin="4">
        <Grid.Background>
          <SolidColorBrush Color="{StaticResource ColorAMOTBackgroundOverlay}" />
        </Grid.Background>
        <TextBlock Text="{Binding Path=ResourceStrings.XTSStringSensors, Source={StaticResource LocalizedResources}}" HorizontalAlignment="Left" d:LayoutOverrides="Height" VerticalAlignment="Top" Margin="2,2,0,0" FontWeight="Bold" />
        <StackPanel Margin="4,16,0,4" x:Name="SensorsPanel0" HorizontalAlignment="Left" VerticalAlignment="Top" Orientation="Horizontal" MinHeight="44" />
        <StackPanel Margin="4,64,0,4" x:Name="SensorsPanel1" HorizontalAlignment="Left" VerticalAlignment="Top" Orientation="Horizontal" MinHeight="44" />
      </Grid>
      <Grid Margin="4">
        <Grid.Background>
          <SolidColorBrush Color="{StaticResource ColorAMOTBackgroundOverlay}" />
        </Grid.Background>
        <TextBlock Text="{Binding Path=ResourceStrings.XTSStringSensorDeviations, Source={StaticResource LocalizedResources}}" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="2,2,0,0" FontWeight="Bold" />
        <StackPanel Margin="4,16,0,4" x:Name="SensorsDeviationPanel0" HorizontalAlignment="Left" VerticalAlignment="Top" Orientation="Horizontal" MinHeight="44" />
        <StackPanel Margin="4,64,0,4" x:Name="SensorsDeviationPanel1" HorizontalAlignment="Left" VerticalAlignment="Top" Orientation="Horizontal" MinHeight="44" />
      </Grid>
      <Grid Margin="4">
        <Grid.Background>
          <SolidColorBrush Color="{StaticResource ColorAMOTBackgroundOverlay}" />
        </Grid.Background>
        <TextBlock Text="{Binding Path=ResourceStrings.XTSStringCylinders, Source={StaticResource LocalizedResources}}" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="2,2,0,0" FontWeight="Bold" />
        <StackPanel Margin="4,16,0,4" x:Name="CylindersPanel" HorizontalAlignment="Left" VerticalAlignment="Top" Orientation="Horizontal" MinHeight="44" />
      </Grid>
      <Grid Margin="4">
        <Grid.Background>
          <SolidColorBrush Color="{StaticResource ColorAMOTBackgroundOverlay}" />
        </Grid.Background>
        <TextBlock Text="{Binding Path=ResourceStrings.XTSStringCylinderDeviations, Source={StaticResource LocalizedResources}}" VerticalAlignment="Top" d:LayoutOverrides="Width" HorizontalAlignment="Left" Margin="2,2,0,0" FontWeight="Bold" />
        <StackPanel Margin="4,16,0,4" x:Name="CylindersDeviationPanel" HorizontalAlignment="Left" VerticalAlignment="Top" Orientation="Horizontal" MinHeight="44" />
      </Grid>
      <StackPanel Margin="4,4,0,4" x:Name="ExtrasPanel" Orientation="Horizontal" VerticalAlignment="Top">
        <Grid VerticalAlignment="Top" HorizontalAlignment="Left" Margin="0,0,4,0">
          <Grid.Background>
            <SolidColorBrush Color="{StaticResource ColorAMOTBackgroundOverlay}" />
          </Grid.Background>
          <TextBlock Text="{Binding Path=ResourceStrings.XTSStringSEDM, Source={StaticResource LocalizedResources}}" Margin="2,2,0,0" FontWeight="Bold" VerticalAlignment="Top" HorizontalAlignment="Left" d:LayoutOverrides="VerticalAlignment, Margin" />
          <ToggleButton Width="44" Height="44" Margin="4,20,4,4" x:Name="mv" Content="{Binding Path=ResourceStrings.XTSStringmV, Source={StaticResource LocalizedResources}}" Style="{StaticResource ToggleButtonStyleAMOT}" HorizontalAlignment="Left" VerticalAlignment="Top" ContentTemplate="{StaticResource ContentTemplateAMOTButton}">
            <ToggleButton.Foreground>
              <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
            </ToggleButton.Foreground>
            <ToggleButton.Background>
              <SolidColorBrush Color="{StaticResource ColorAMOTButton}" />
            </ToggleButton.Background>
          </ToggleButton>
        </Grid>
        <Grid Margin="0,0,4,0" VerticalAlignment="Top" HorizontalAlignment="Left">
          <Grid.Background>
            <SolidColorBrush Color="{StaticResource ColorAMOTBackgroundOverlay}" />
          </Grid.Background>
          <TextBlock Text="{Binding Path=ResourceStrings.XTSStringWIO, Source={StaticResource LocalizedResources}}" Margin="2,2,0,0" FontWeight="Bold" HorizontalAlignment="Left" VerticalAlignment="Top" d:LayoutOverrides="HorizontalAlignment, VerticalAlignment, VerticalMargin" />
          <ToggleButton Height="44" Style="{StaticResource ToggleButtonStyleAMOT}" x:Name="WIOPercent" Content="{Binding Path=ResourceStrings.XTSStringPercentChar, Source={StaticResource LocalizedResources}}" HorizontalAlignment="Left" Width="44" VerticalAlignment="Top" Margin="4,20,4,4" d:LayoutOverrides="HorizontalAlignment" ContentTemplate="{StaticResource ContentTemplateAMOTButton}">
            <ToggleButton.Foreground>
              <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
            </ToggleButton.Foreground>
            <ToggleButton.Background>
              <SolidColorBrush Color="{StaticResource ColorAMOTButton}" />
            </ToggleButton.Background>
          </ToggleButton>
          <ToggleButton Height="44" Style="{StaticResource ToggleButtonStyleAMOT}" x:Name="PPM" Content="{Binding Path=ResourceStrings.XTSStringPPM, Source={StaticResource LocalizedResources}}" HorizontalAlignment="Left" VerticalAlignment="Top" Width="44" Margin="52,20,4,4" d:LayoutOverrides="GridBox" ContentTemplate="{StaticResource ContentTemplateAMOTButton}">
            <ToggleButton.Foreground>
              <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
            </ToggleButton.Foreground>
            <ToggleButton.Background>
              <SolidColorBrush Color="{StaticResource ColorAMOTButton}" />
            </ToggleButton.Background>
          </ToggleButton>
        </Grid>
                <Grid Margin="0,0,4,0" VerticalAlignment="Top" HorizontalAlignment="Left">
                    <Grid.Background>
                        <SolidColorBrush Color="{StaticResource ColorAMOTBackgroundOverlay}" />
                    </Grid.Background>
                    <TextBlock Text="{Binding Path=ResourceStrings.XTSStringCPP, Source={StaticResource LocalizedResources}}" Margin="2,2,0,0" FontWeight="Bold" HorizontalAlignment="Left" VerticalAlignment="Top" d:LayoutOverrides="HorizontalAlignment, VerticalAlignment, VerticalMargin" />
                    <ToggleButton Height="44" Style="{StaticResource ToggleButtonStyleAMOT}" x:Name="CppPercent" Content="{Binding Path=ResourceStrings.XTSStringPercentChar, Source={StaticResource LocalizedResources}}" HorizontalAlignment="Left" Width="44" VerticalAlignment="Top" Margin="4,20,4,4" d:LayoutOverrides="HorizontalAlignment" ContentTemplate="{StaticResource ContentTemplateAMOTButton}">
                        <ToggleButton.Foreground>
                            <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
                        </ToggleButton.Foreground>
                        <ToggleButton.Background>
                            <SolidColorBrush Color="{StaticResource ColorAMOTButton}" />
                        </ToggleButton.Background>
                    </ToggleButton>
                    <ToggleButton Height="44" Style="{StaticResource ToggleButtonStyleAMOT}" x:Name="CppMa" Content="{Binding Path=ResourceStrings.XTSStringmA, Source={StaticResource LocalizedResources}}" HorizontalAlignment="Left" VerticalAlignment="Top" Width="44" Margin="52,20,4,4" d:LayoutOverrides="GridBox" ContentTemplate="{StaticResource ContentTemplateAMOTButton}">
                        <ToggleButton.Foreground>
                            <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
                        </ToggleButton.Foreground>
                        <ToggleButton.Background>
                            <SolidColorBrush Color="{StaticResource ColorAMOTButton}" />
                        </ToggleButton.Background>
                    </ToggleButton>
                </Grid>
                <ToggleButton Width="44" Height="44" Margin="4,20,4,4" Style="{StaticResource ToggleButtonStyleAMOT}" x:Name="RPM" Content="{Binding Path=ResourceStrings.XTSStringRPM, Source={StaticResource LocalizedResources}}" VerticalAlignment="Bottom" ContentTemplate="{StaticResource ContentTemplateAMOTButton}">
          <ToggleButton.Foreground>
            <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
          </ToggleButton.Foreground>
          <ToggleButton.Background>
            <SolidColorBrush Color="{StaticResource ColorAMOTButton}" />
          </ToggleButton.Background>
        </ToggleButton>
      </StackPanel>
        </StackPanel>
    <Button x:Name="CancelButton" Style="{StaticResource ButtonStyleAMOT}" Click="CancelButton_Click" Width="44" Height="44" HorizontalAlignment="Right" Margin="0" Grid.Row="2" VerticalAlignment="Bottom">
      <Button.Foreground>
        <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
      </Button.Foreground>
      <Button.Background>
        <SolidColorBrush Color="{StaticResource ColorAMOTButton}" />
      </Button.Background>
      <Grid>
        <Path Stretch="Fill" Data="F1 M 400,224C 400,237.255 389.255,248 376,248L 280,248C 266.745,248 256,237.255 256,224L 256,128C 256,114.745 266.745,104 280,104L 376,104C 389.255,104 400,114.745 400,128L 400,224 Z M 272,136L 312,176L 272,216L 288,232L 328,192L 368,232L 384,216L 344,176L 384,136L 368,120L 328,160L 288,120L 272,136 Z " Margin="8,4,8,12" UseLayoutRounding="False" Fill="{Binding Foreground, ElementName=CancelButton}" />
        <TextBlock Margin="2,0,0,0" TextWrapping="Wrap" Text="{Binding Path=ResourceStrings.XTSStringCancel, Source={StaticResource LocalizedResources}}" d:LayoutOverrides="Width, Height" FontSize="8" VerticalAlignment="Bottom" HorizontalAlignment="Left" />
      </Grid>
    </Button>
    <Button x:Name="OKButton" Style="{StaticResource ButtonStyleAMOT}" Click="OKButton_Click" Width="44" Height="44" HorizontalAlignment="Right" Margin="0,0,52,0" Grid.Row="2" VerticalAlignment="Bottom">
      <Button.Foreground>
        <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
      </Button.Foreground>
      <Button.Background>
        <SolidColorBrush Color="{StaticResource ColorAMOTButton}" />
      </Button.Background>
      <Grid>
        <Path Stretch="Fill" Data="F1 M 256,112L 257.947,112.078L 344,112L 344,112.123C 357.24,112.123 367.976,122.845 368,136.123L 368,232.123C 368,245.378 357.255,256.123 344,256.123L 342.052,256.045L 256,256.123C 242.745,256.123 232,245.378 232,232.08L 232,136C 232,122.745 242.745,112 256,112 Z M 353.094,140.14L 336,128L 289.684,206.583L 256,176L 243.146,192L 296,240L 353.094,140.14 Z " Margin="8,4,8,12" UseLayoutRounding="False" Fill="{Binding Foreground, ElementName=OKButton}" />
        <TextBlock Margin="2,0,0,0" TextWrapping="Wrap" Text="{Binding Path=ResourceStrings.XTSStringOK, Source={StaticResource LocalizedResources}}" FontSize="8" VerticalAlignment="Bottom" HorizontalAlignment="Left" />
      </Grid>
    </Button>
    <Button x:Name="TmpButton" Style="{StaticResource ButtonStyleAMOT}" Width="44" Height="44" HorizontalAlignment="Right" Margin="0,0,104,0" Grid.Row="2" VerticalAlignment="Bottom" Click="TmpButton_Click">
        <Button.Foreground>
            <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
        </Button.Foreground>
        <Button.Background>
            <SolidColorBrush Color="{StaticResource ColorAMOTButton}" />
        </Button.Background>
        <Grid>
            <Path Stretch="Fill" Data="F1 M 256,112L 257.947,112.078L 344,112L 344,112.123C 357.24,112.123 367.976,122.845 368,136.123L 368,232.123C 368,245.378 357.255,256.123 344,256.123L 342.052,256.045L 256,256.123C 242.745,256.123 232,245.378 232,232.08L 232,136C 232,122.745 242.745,112 256,112 Z  " Margin="8,4,8,12" UseLayoutRounding="False" Fill="{Binding Foreground, ElementName=OKButton}" />
                <TextBlock Margin="2,0,0,0" TextWrapping="Wrap" Text="{Binding Path=ResourceStrings.XTSStringTempModule, Source={StaticResource LocalizedResources}}" FontSize="8" VerticalAlignment="Bottom" HorizontalAlignment="Left" />
        </Grid>
    </Button>
    </Grid>
</sdk:ChildWindow>