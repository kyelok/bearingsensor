<sdk:ChildWindow
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:System.Windows.Controls;assembly=System.Windows.Controls"
    xmlns:sdk="http://schemas.microsoft.com/winfx/2006/xaml/presentation/sdk"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    x:Class="XTS.ChildWindows.TemperatureSettings"
    Title="{Binding Path=ResourceStrings.XTSStringTemperatureSetting, Source={StaticResource LocalizedResources}}"
    Style="{StaticResource ChildWindowStyleAMOT}"
    HasCloseButton="False"
    Loaded="TemperatureSettings_Loaded">
  <Grid x:Name="LayoutRoot" Margin="2">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="48" />
    </Grid.RowDefinitions>
    <StackPanel Margin="0,0,0,0" Orientation="Vertical" HorizontalAlignment="Center">
            <Grid Margin="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="20" />
                    <RowDefinition Height="22" />
                    <RowDefinition Height="22" />
                    <RowDefinition Height="22" />
                    <RowDefinition Height="6" />
                    <RowDefinition Height="20" />
                    <RowDefinition Height="22" />
                    <RowDefinition Height="22" />
                    <RowDefinition Height="22" />
                    <RowDefinition Height="6" />
                    <RowDefinition Height="20" />
                    <RowDefinition Height="22" />
                    <RowDefinition Height="22" />
                    <RowDefinition Height="22" />
                    <RowDefinition Height="6" />
                    <RowDefinition Height="20" />
                    <RowDefinition Height="22" />
                    <RowDefinition Height="22" />
                    <RowDefinition Height="22" />
                    <RowDefinition Height="6" />
                    <RowDefinition Height="20" />
                    <RowDefinition Height="22" />
                    <RowDefinition Height="22" />
                    <RowDefinition Height="22" />
                    <RowDefinition Height="6" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="58" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.Background>
          <SolidColorBrush Color="{StaticResource ColorAMOTBackgroundOverlay}" />
        </Grid.Background>
        <TextBlock Text="{Binding Path=ResourceStrings.XTSStringEnable, Source={StaticResource LocalizedResources}}" VerticalAlignment="Bottom" Grid.Column="0" Grid.Row="0" HorizontalAlignment="Left" Margin="2,0,0,0" FontSize="10" />
        <TextBlock Text="{Binding Path=ResourceStrings.XTSStringEnable, Source={StaticResource LocalizedResources}}" VerticalAlignment="Bottom" Grid.Column="0" Grid.Row="5" HorizontalAlignment="Left" Margin="2,0,0,0" FontSize="10" />                
        <TextBlock Text="{Binding Path=ResourceStrings.XTSStringEnable, Source={StaticResource LocalizedResources}}" VerticalAlignment="Bottom" Grid.Column="0" Grid.Row="10" HorizontalAlignment="Left" Margin="2,0,0,0" FontSize="10" />                
        <TextBlock Text="{Binding Path=ResourceStrings.XTSStringEnable, Source={StaticResource LocalizedResources}}" VerticalAlignment="Bottom" Grid.Column="0" Grid.Row="15" HorizontalAlignment="Left" Margin="2,0,0,0" FontSize="10" />                
        <TextBlock Text="{Binding Path=ResourceStrings.XTSStringEnable, Source={StaticResource LocalizedResources}}" VerticalAlignment="Bottom" Grid.Column="0" Grid.Row="20" HorizontalAlignment="Left" Margin="2,0,0,0" FontSize="10" />
        <TextBlock Text="{Binding Path=ResourceStrings.XTSStringName, Source={StaticResource LocalizedResources}}" VerticalAlignment="Bottom" Grid.Column="0" Grid.Row="1" HorizontalAlignment="Left" Margin="2,0,0,0" FontSize="10" />
        <TextBlock Text="{Binding Path=ResourceStrings.XTSStringName, Source={StaticResource LocalizedResources}}" VerticalAlignment="Bottom" Grid.Column="0" Grid.Row="6" HorizontalAlignment="Left" Margin="2,0,0,0" FontSize="10" />
        <TextBlock Text="{Binding Path=ResourceStrings.XTSStringName, Source={StaticResource LocalizedResources}}" VerticalAlignment="Bottom" Grid.Column="0" Grid.Row="11" HorizontalAlignment="Left" Margin="2,0,0,0" FontSize="10" />
        <TextBlock Text="{Binding Path=ResourceStrings.XTSStringName, Source={StaticResource LocalizedResources}}" VerticalAlignment="Bottom" Grid.Column="0" Grid.Row="16" HorizontalAlignment="Left" Margin="2,0,0,0" FontSize="10" />
        <TextBlock Text="{Binding Path=ResourceStrings.XTSStringName, Source={StaticResource LocalizedResources}}" VerticalAlignment="Bottom" Grid.Column="0" Grid.Row="21" HorizontalAlignment="Left" Margin="2,0,0,0" FontSize="10" />
        <TextBlock Text="{Binding Path=ResourceStrings.XTSStringAlarm, Source={StaticResource LocalizedResources}}" VerticalAlignment="Bottom" Grid.Column="0" Grid.Row="2" HorizontalAlignment="Left" Margin="2,0,0,0" FontSize="10" />
        <TextBlock Text="{Binding Path=ResourceStrings.XTSStringAlarm, Source={StaticResource LocalizedResources}}" VerticalAlignment="Bottom" Grid.Column="0" Grid.Row="7" HorizontalAlignment="Left" Margin="2,0,0,0" FontSize="10" />
        <TextBlock Text="{Binding Path=ResourceStrings.XTSStringAlarm, Source={StaticResource LocalizedResources}}" VerticalAlignment="Bottom" Grid.Column="0" Grid.Row="12" HorizontalAlignment="Left" Margin="2,0,0,0" FontSize="10" />
        <TextBlock Text="{Binding Path=ResourceStrings.XTSStringAlarm, Source={StaticResource LocalizedResources}}" VerticalAlignment="Bottom" Grid.Column="0" Grid.Row="17" HorizontalAlignment="Left" Margin="2,0,0,0" FontSize="10" />
        <TextBlock Text="{Binding Path=ResourceStrings.XTSStringAlarm, Source={StaticResource LocalizedResources}}" VerticalAlignment="Bottom" Grid.Column="0" Grid.Row="22" HorizontalAlignment="Left" Margin="2,0,0,0" FontSize="10" />
        <TextBlock Text="{Binding Path=ResourceStrings.XTSStringSlowdown, Source={StaticResource LocalizedResources}}" VerticalAlignment="Bottom" Grid.Column="0" Grid.Row="3" HorizontalAlignment="Left" Margin="2,0,0,0" FontSize="10" />
        <TextBlock Text="{Binding Path=ResourceStrings.XTSStringSlowdown, Source={StaticResource LocalizedResources}}" VerticalAlignment="Bottom" Grid.Column="0" Grid.Row="8" HorizontalAlignment="Left" Margin="2,0,0,0" FontSize="10" />
        <TextBlock Text="{Binding Path=ResourceStrings.XTSStringSlowdown, Source={StaticResource LocalizedResources}}" VerticalAlignment="Bottom" Grid.Column="0" Grid.Row="13" HorizontalAlignment="Left" Margin="2,0,0,0" FontSize="10" />
        <TextBlock Text="{Binding Path=ResourceStrings.XTSStringSlowdown, Source={StaticResource LocalizedResources}}" VerticalAlignment="Bottom" Grid.Column="0" Grid.Row="18" HorizontalAlignment="Left" Margin="2,0,0,0" FontSize="10" />
        <TextBlock Text="{Binding Path=ResourceStrings.XTSStringSlowdown, Source={StaticResource LocalizedResources}}" VerticalAlignment="Bottom" Grid.Column="0" Grid.Row="23" HorizontalAlignment="Left" Margin="2,0,0,0" FontSize="10" />

        <StackPanel Margin="4,2,4,4" x:Name="TemperaturePanel0" HorizontalAlignment="Left" VerticalAlignment="Top" Orientation="Horizontal" MinHeight="44" Grid.Column="1" Grid.Row="0" Grid.RowSpan="5" />
        <StackPanel Margin="4,2,4,4" x:Name="TemperaturePanel1" HorizontalAlignment="Left" VerticalAlignment="Top" Orientation="Horizontal" MinHeight="44" Grid.Column="1" Grid.Row="5" Grid.RowSpan="10" />
        <StackPanel Margin="4,2,4,4" x:Name="TemperaturePanel2" HorizontalAlignment="Left" VerticalAlignment="Top" Orientation="Horizontal" MinHeight="44" Grid.Column="1" Grid.Row="10" Grid.RowSpan="15" />
        <StackPanel Margin="4,2,4,4" x:Name="TemperaturePanel3" HorizontalAlignment="Left" VerticalAlignment="Top" Orientation="Horizontal" MinHeight="44" Grid.Column="1" Grid.Row="15" Grid.RowSpan="20" />
        <StackPanel Margin="4,2,4,4" x:Name="TemperaturePanel4" HorizontalAlignment="Left" VerticalAlignment="Top" Orientation="Horizontal" MinHeight="44" Grid.Column="1" Grid.Row="20" Grid.RowSpan="25" />
      </Grid>
    </StackPanel>
    <Button x:Name="CancelButton" Style="{StaticResource ButtonStyleAMOT}" Click="CancelButton_Click" Width="44" Height="44" HorizontalAlignment="Right" Margin="0" Grid.Row="2" VerticalAlignment="Bottom">
      <Button.Foreground>
        <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
      </Button.Foreground>
      <Button.Background>
        <SolidColorBrush Color="{StaticResource ColorAMOTButton}" />
      </Button.Background>
      <Grid>
        <Path Stretch="Fill" Data="F1 M 400,224C 400,237.255 389.255,248 376,248L 280,248C 266.745,248 256,237.255 256,224L 256,128C 256,114.745 266.745,104 280,104L 376,104C 389.255,104 400,114.745 400,128L 400,224 Z M 272,136L 312,176L 272,216L 288,232L 328,192L 368,232L 384,216L 344,176L 384,136L 368,120L 328,160L 288,120L 272,136 Z " Margin="8,4,8,12" UseLayoutRounding="False" Fill="{Binding Foreground, ElementName=CancelButton}" />
                <TextBlock Margin="2,0,0,0" TextWrapping="Wrap" Text="{Binding Path=ResourceStrings.XTSStringClose, Source={StaticResource LocalizedResources}}" d:LayoutOverrides="Width, Height" FontSize="8" VerticalAlignment="Bottom" HorizontalAlignment="Left" />
      </Grid>
    </Button>
    <Button x:Name="OKButton" Style="{StaticResource ButtonStyleAMOT}" Click="OKButton_Click" Width="44" Height="44" HorizontalAlignment="Right" Margin="0,0,50,0" Grid.Row="2" VerticalAlignment="Bottom">
      <Button.Foreground>
        <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
      </Button.Foreground>
      <Button.Background>
        <SolidColorBrush Color="{StaticResource ColorAMOTButton}" />
      </Button.Background>
      <Grid>
        <Path Stretch="Fill" Data="F1 M 256,112L 257.947,112.078L 344,112L 344,112.123C 357.24,112.123 367.976,122.845 368,136.123L 368,232.123C 368,245.378 357.255,256.123 344,256.123L 342.052,256.045L 256,256.123C 242.745,256.123 232,245.378 232,232.08L 232,136C 232,122.745 242.745,112 256,112 Z M 353.094,140.14L 336,128L 289.684,206.583L 256,176L 243.146,192L 296,240L 353.094,140.14 Z " Margin="8,4,8,12" UseLayoutRounding="False" Fill="{Binding Foreground, ElementName=OKButton}" />
                <TextBlock Margin="2,0,0,0" TextWrapping="Wrap" Text="{Binding Path=ResourceStrings.XTSStringKeyboardSubmit, Source={StaticResource LocalizedResources}}" FontSize="8" VerticalAlignment="Bottom" HorizontalAlignment="Left" />
      </Grid>
    </Button>
        <Button x:Name="buttonNone" Click="buttonNone_Click" Width="44" Height="44" HorizontalAlignment="Right" Margin="0,0,100,0" Grid.Row="2" VerticalAlignment="Bottom" Style="{StaticResource ButtonStyleAMOT}">
        <Button.Background>
            <SolidColorBrush Color="{StaticResource ColorAMOTButton}" />
        </Button.Background>
        <Button.Foreground>
            <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
        </Button.Foreground>
        <Grid>
            <Path Stretch="Fill" Data="F1 M32,0 L159.717,0 L159.717,448 L127.616,448 L127.616,480 L64,480 L64,448 L32,448 L32,0 z" Margin="0,0,20,12" UseLayoutRounding="False" Opacity="0.5" HorizontalAlignment="Center" Height="28" Width="8" VerticalAlignment="Bottom" Fill="{Binding Foreground, ElementName=buttonNone}" />
            <Path Stretch="Fill" Data="F1 M32,0 L159.717,0 L159.717,448 L127.616,448 L127.616,480 L64,480 L64,448 L32,448 L32,0 z" Margin="0,0,0,12" UseLayoutRounding="False" Opacity="0.5" HorizontalAlignment="Center" Height="28" Width="8" VerticalAlignment="Bottom" Fill="{Binding Foreground, ElementName=buttonNone}" />
            <Path Stretch="Fill" Data="F1 M32,0 L159.717,0 L159.717,448 L127.616,448 L127.616,480 L64,480 L64,448 L32,448 L32,0 z" Margin="20,0,0,12" UseLayoutRounding="False" Opacity="0.5" HorizontalAlignment="Center" Height="28" Width="8" VerticalAlignment="Bottom" Fill="{Binding Foreground, ElementName=buttonNone}" />
            <TextBlock Margin="2,0,0,0" TextWrapping="Wrap" Text="{Binding Path=ResourceStrings.XTSStringNone, Source={StaticResource LocalizedResources}}" d:LayoutOverrides="Width, Height" FontSize="8" HorizontalAlignment="Left" VerticalAlignment="Bottom" />
        </Grid>
    </Button>
        <Button x:Name="buttonAll" Click="buttonAll_Click" Width="44" Height="44" HorizontalAlignment="Right" Margin="0,0,150,0" Grid.Row="2" VerticalAlignment="Bottom" Style="{StaticResource ButtonStyleAMOT}">
            <Button.Background>
            <SolidColorBrush Color="{StaticResource ColorAMOTButton}" />
        </Button.Background>
        <Button.Foreground>
            <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
        </Button.Foreground>
        <Grid>
            <Path Stretch="Fill" Data="F1 M32,0 L159.717,0 L159.717,448 L127.616,448 L127.616,480 L64,480 L64,448 L32,448 L32,0 z" Margin="0,0,20,12" UseLayoutRounding="False" HorizontalAlignment="Center" Height="28" Width="8" VerticalAlignment="Bottom" Fill="{Binding Foreground, ElementName=buttonAll}" />
            <Path Stretch="Fill" Data="F1 M32,0 L159.717,0 L159.717,448 L127.616,448 L127.616,480 L64,480 L64,448 L32,448 L32,0 z" Margin="0,0,0,12" UseLayoutRounding="False" HorizontalAlignment="Center" Height="28" Width="8" VerticalAlignment="Bottom" Fill="{Binding Foreground, ElementName=buttonAll}" />
            <Path Stretch="Fill" Data="F1 M32,0 L159.717,0 L159.717,448 L127.616,448 L127.616,480 L64,480 L64,448 L32,448 L32,0 z" Margin="20,0,0,12" UseLayoutRounding="False" HorizontalAlignment="Center" Height="28" Width="8" VerticalAlignment="Bottom" Fill="{Binding Foreground, ElementName=buttonAll}" />
            <TextBlock Margin="2,0,0,-0.364" TextWrapping="Wrap" Text="{Binding Path=ResourceStrings.XTSStringAll, Source={StaticResource LocalizedResources}}" FontSize="8" HorizontalAlignment="Left" VerticalAlignment="Bottom" />
        </Grid>
    </Button>
    
    <Button x:Name="buttonNext" Width="44" Height="44" HorizontalAlignment="Right" Margin="0,0,200,0" Grid.Row="2" VerticalAlignment="Bottom" Style="{StaticResource ButtonStyleAMOT}" Click="buttonNext_Click">
        <Button.Background>
            <SolidColorBrush Color="{StaticResource ColorAMOTButton}" />
        </Button.Background>
        <Button.Foreground>
            <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
        </Button.Foreground>
        <Grid>
                <Path Stretch="Fill" Data="F1 M 23.9063,22.5L 21.9063,24.5L 14.9063,31.75L 14.9063,25.25L 23.9063,15.75L 32.9063,25.25L 32.9063,31.75L 25.9063,24.5L 23.9063,22.5 Z " Margin="8,4,8,12" UseLayoutRounding="False" Fill="{Binding Foreground, ElementName=OKButton}" />                                  
                
                <TextBlock Margin="2,0,0,-0.364" TextWrapping="Wrap" Text="{Binding Path=ResourceStrings.XTSStringKeyboardNext, Source={StaticResource LocalizedResources}}" FontSize="8" HorizontalAlignment="Left" VerticalAlignment="Bottom" />
        </Grid>
    </Button>
    </Grid>
</sdk:ChildWindow>