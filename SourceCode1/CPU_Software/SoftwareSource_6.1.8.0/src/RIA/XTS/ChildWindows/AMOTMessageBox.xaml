<controls:ChildWindow
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:System.Windows.Controls;assembly=System.Windows.Controls"
    xmlns:sdk="http://schemas.microsoft.com/winfx/2006/xaml/presentation/sdk"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    x:Name="childWindow"
    mc:Ignorable="d"
    x:Class="XTS.ChildWindows.AMOTMessageBox"
    Width="400" Height="300"
    Title="{Binding Path=ResourceStrings.XTSStringAMOTMessageBox, Source={StaticResource LocalizedResources}}"
    HasCloseButton="False">
  <sdk:ChildWindow.Foreground>
    <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
  </sdk:ChildWindow.Foreground>
  <controls:ChildWindow.Style>
    <StaticResource ResourceKey="ChildWindowStyleAMOT" />
  </controls:ChildWindow.Style>
  <Grid x:Name="LayoutRoot" Margin="2">
        <ToolTipService.ToolTip>
            <ToolTip x:Name="toolname" Content="123"></ToolTip>
        </ToolTipService.ToolTip>
        <Grid.RowDefinitions>
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="22" />
      <RowDefinition Height="44" />
    </Grid.RowDefinitions>
    <TextBlock x:Name="TextBlockMessage" TextWrapping="Wrap" Text="{Binding Path=ResourceStrings.XTSStringTextBlock, Source={StaticResource LocalizedResources}}" TextAlignment="Center" FontSize="13.333" VerticalAlignment="Center" Foreground="{Binding Foreground, ElementName=childWindow}" />
    <Button x:Name="buttonOption0" HorizontalAlignment="Center" Width="88" Style="{StaticResource ButtonStyleAMOT}" Grid.Row="1" VerticalAlignment="Center" Height="88" Margin="0,0,132,0" Click="buttonOption0_Click">
      <Button.Foreground>
        <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
      </Button.Foreground>
      <Button.Background>
        <SolidColorBrush Color="{StaticResource ColorAMOTButton}" />
      </Button.Background>
      <Grid Margin="0">
        <TextBlock x:Name="option0Text" Margin="2,0" TextWrapping="Wrap" Text="{Binding Path=ResourceStrings.XTSStringOption0, Source={StaticResource LocalizedResources}}" d:LayoutOverrides="Width, Height" VerticalAlignment="Bottom" />
        <Path x:Name="option0Path" Stretch="Fill" Data="{Binding Option0Icon}" UseLayoutRounding="False" Fill="{Binding Foreground, ElementName=buttonOption0}" VerticalAlignment="Top" Width="50" Height="50" Margin="0,8,0,0" HorizontalAlignment="Center" />
      </Grid>
    </Button>
    <Button x:Name="buttonOption1" HorizontalAlignment="Center" Width="88" Style="{StaticResource ButtonStyleAMOT}" Grid.Row="1" VerticalAlignment="Center" Height="88" Margin="132,0,0,0" Click="buttonOption1_Click">
      <Button.Foreground>
        <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
      </Button.Foreground>
      <Button.Background>
        <SolidColorBrush Color="{StaticResource ColorAMOTButton}" />
      </Button.Background>
      <Grid Margin="0">
        <TextBlock x:Name="option1Text" Margin="2,0" TextWrapping="Wrap" Text="{Binding Path=ResourceStrings.XTSStringOption1, Source={StaticResource LocalizedResources}}" d:LayoutOverrides="Width, Height" VerticalAlignment="Bottom" />
        <Path x:Name="option1Path" Stretch="Fill" Data="{Binding Option1Icon}" UseLayoutRounding="False" Fill="{Binding Foreground, ElementName=buttonOption1}" Width="50" Height="50" Margin="0,8,0,0" VerticalAlignment="Top" HorizontalAlignment="Center" />
      </Grid>
    </Button>
    <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0" HorizontalAlignment="Right">
      <Button x:Name="OKButton" Click="OKButton_Click" Width="44" Height="44" HorizontalAlignment="Right" Style="{StaticResource ButtonStyleAMOT}" d:LayoutOverrides="Height" Margin="8,0,0,0">
        <Button.Background>
          <SolidColorBrush Color="{StaticResource ColorAMOTButton}" />
        </Button.Background>
        <Button.Foreground>
          <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
        </Button.Foreground>
        <Grid>
          <TextBlock Margin="2,0,0,0" TextWrapping="Wrap" Text="{Binding Path=ResourceStrings.XTSStringOK, Source={StaticResource LocalizedResources}}" d:LayoutOverrides="Width, Height" HorizontalAlignment="Left" VerticalAlignment="Bottom" FontSize="8" />
          <Path Stretch="Fill" Data="F1 M 256,112L 257.947,112.078L 344,112L 344,112.123C 357.24,112.123 367.976,122.845 368,136.123L 368,232.123C 368,245.378 357.255,256.123 344,256.123L 342.052,256.045L 256,256.123C 242.745,256.123 232,245.378 232,232.08L 232,136C 232,122.745 242.745,112 256,112 Z M 353.094,140.14L 336,128L 289.684,206.583L 256,176L 243.146,192L 296,240L 353.094,140.14 Z " Margin="8,4,8,12" UseLayoutRounding="False" Fill="{Binding Foreground, ElementName=OKButton}" />
        </Grid>
      </Button>
      <Button x:Name="CancelButton" Click="CancelButton_Click" Width="44" Height="44" HorizontalAlignment="Right" Margin="8,0,0,0" Style="{StaticResource ButtonStyleAMOT}" d:LayoutOverrides="Height">
        <Button.Background>
          <SolidColorBrush Color="{StaticResource ColorAMOTButton}" />
        </Button.Background>
        <Button.Foreground>
          <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
        </Button.Foreground>
        <Grid>
          <TextBlock Margin="2,0,0,0" TextWrapping="Wrap" Text="{Binding Path=ResourceStrings.XTSStringCancel, Source={StaticResource LocalizedResources}}" HorizontalAlignment="Left" VerticalAlignment="Bottom" FontSize="8" />
          <Path Stretch="Fill" Data="F1 M 400,224C 400,237.255 389.255,248 376,248L 280,248C 266.745,248 256,237.255 256,224L 256,128C 256,114.745 266.745,104 280,104L 376,104C 389.255,104 400,114.745 400,128L 400,224 Z M 272,136L 312,176L 272,216L 288,232L 328,192L 368,232L 384,216L 344,176L 384,136L 368,120L 328,160L 288,120L 272,136 Z " Margin="8,4,8,12" UseLayoutRounding="False" Fill="{Binding Foreground, ElementName=CancelButton}" />
        </Grid>
      </Button>
      <Button x:Name="RetryButton" Click="OKButton_Click" Width="44" Height="44" HorizontalAlignment="Right" Style="{StaticResource ButtonStyleAMOT}" Margin="8,0,0,0">
        <Button.Background>
          <SolidColorBrush Color="{StaticResource ColorAMOTButton}" />
        </Button.Background>
        <Button.Foreground>
          <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
        </Button.Foreground>
        <Grid>
          <TextBlock Margin="2,0,0,0" TextWrapping="Wrap" Text="{Binding Path=ResourceStrings.XTSStringRetry, Source={StaticResource LocalizedResources}}" HorizontalAlignment="Left" VerticalAlignment="Bottom" FontSize="8" />
          <Path Stretch="Fill" Data="F1 M 256,112L 257.947,112.078L 344,112L 344,112.123C 357.24,112.123 367.976,122.845 368,136.123L 368,232.123C 368,245.378 357.255,256.123 344,256.123L 342.052,256.045L 256,256.123C 242.745,256.123 232,245.378 232,232.08L 232,136C 232,122.745 242.745,112 256,112 Z M 353.094,140.14L 336,128L 289.684,206.583L 256,176L 243.146,192L 296,240L 353.094,140.14 Z " Margin="8,4,8,12" UseLayoutRounding="False" Fill="{Binding Foreground, ElementName=RetryButton}" />
        </Grid>
      </Button>
      <Button x:Name="AbortButton" Click="CancelButton_Click" Width="44" Height="44" HorizontalAlignment="Right" Style="{StaticResource ButtonStyleAMOT}" Margin="8,0,0,0">
        <Button.Background>
          <SolidColorBrush Color="{StaticResource ColorAMOTButton}" />
        </Button.Background>
        <Button.Foreground>
          <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
        </Button.Foreground>
        <Grid>
          <TextBlock Margin="2,0,0,0" TextWrapping="Wrap" Text="{Binding Path=ResourceStrings.XTSStringAbort, Source={StaticResource LocalizedResources}}" HorizontalAlignment="Left" VerticalAlignment="Bottom" FontSize="8" />
          <Path Stretch="Fill" Data="F1 M 400,224C 400,237.255 389.255,248 376,248L 280,248C 266.745,248 256,237.255 256,224L 256,128C 256,114.745 266.745,104 280,104L 376,104C 389.255,104 400,114.745 400,128L 400,224 Z M 272,136L 312,176L 272,216L 288,232L 328,192L 368,232L 384,216L 344,176L 384,136L 368,120L 328,160L 288,120L 272,136 Z " Margin="8,4,8,12" UseLayoutRounding="False" Fill="{Binding Foreground, ElementName=AbortButton}" />
        </Grid>
      </Button>
      <Button x:Name="YesButton" Click="OKButton_Click" Width="44" Height="44" HorizontalAlignment="Right" Style="{StaticResource ButtonStyleAMOT}" Margin="8,0,0,0">
        <Button.Background>
          <SolidColorBrush Color="{StaticResource ColorAMOTButton}" />
        </Button.Background>
        <Button.Foreground>
          <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
        </Button.Foreground>
        <Grid>
          <TextBlock Margin="2,0,0,0" TextWrapping="Wrap" Text="{Binding Path=ResourceStrings.XTSStringYes, Source={StaticResource LocalizedResources}}" HorizontalAlignment="Left" VerticalAlignment="Bottom" FontSize="8" />
          <Path Stretch="Fill" Data="F1 M 256,112L 257.947,112.078L 344,112L 344,112.123C 357.24,112.123 367.976,122.845 368,136.123L 368,232.123C 368,245.378 357.255,256.123 344,256.123L 342.052,256.045L 256,256.123C 242.745,256.123 232,245.378 232,232.08L 232,136C 232,122.745 242.745,112 256,112 Z M 353.094,140.14L 336,128L 289.684,206.583L 256,176L 243.146,192L 296,240L 353.094,140.14 Z " Margin="8,4,8,12" UseLayoutRounding="False" Fill="{Binding Foreground, ElementName=YesButton}" />
        </Grid>
      </Button>
      <Button x:Name="NoButton" Click="CancelButton_Click" Width="44" Height="44" HorizontalAlignment="Right" Style="{StaticResource ButtonStyleAMOT}" Margin="8,0,0,0">
        <Button.Background>
          <SolidColorBrush Color="{StaticResource ColorAMOTButton}" />
        </Button.Background>
        <Button.Foreground>
          <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
        </Button.Foreground>
        <Grid>
          <TextBlock Margin="2,0,0,0" TextWrapping="Wrap" Text="{Binding Path=ResourceStrings.XTSStringNo, Source={StaticResource LocalizedResources}}" HorizontalAlignment="Left" VerticalAlignment="Bottom" FontSize="8" />
          <Path Stretch="Fill" Data="F1 M 400,224C 400,237.255 389.255,248 376,248L 280,248C 266.745,248 256,237.255 256,224L 256,128C 256,114.745 266.745,104 280,104L 376,104C 389.255,104 400,114.745 400,128L 400,224 Z M 272,136L 312,176L 272,216L 288,232L 328,192L 368,232L 384,216L 344,176L 384,136L 368,120L 328,160L 288,120L 272,136 Z " Margin="8,4,8,12" UseLayoutRounding="False" Fill="{Binding Foreground, ElementName=NoButton}" />
        </Grid>
      </Button>
      <Button x:Name="CloseButton" Click="CancelButton_Click" Width="44" Height="44" HorizontalAlignment="Right" Margin="8,0,0,0" Style="{StaticResource ButtonStyleAMOT}">
        <Button.Background>
          <SolidColorBrush Color="{StaticResource ColorAMOTButton}" />
        </Button.Background>
        <Button.Foreground>
          <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
        </Button.Foreground>
        <Grid>
          <TextBlock Margin="2,0,0,0" TextWrapping="Wrap" Text="{Binding Path=ResourceStrings.XTSStringClose, Source={StaticResource LocalizedResources}}" HorizontalAlignment="Left" VerticalAlignment="Bottom" FontSize="8" />
          <Path Stretch="Fill" Data="F1 M 400,224C 400,237.255 389.255,248 376,248L 280,248C 266.745,248 256,237.255 256,224L 256,128C 256,114.745 266.745,104 280,104L 376,104C 389.255,104 400,114.745 400,128L 400,224 Z M 272,136L 312,176L 272,216L 288,232L 328,192L 368,232L 384,216L 344,176L 384,136L 368,120L 328,160L 288,120L 272,136 Z " Margin="8,4,8,12" UseLayoutRounding="False" Fill="{Binding Foreground, ElementName=CloseButton}" />
        </Grid>
      </Button>
    </StackPanel>
  </Grid>
</controls:ChildWindow>