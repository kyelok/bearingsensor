<UserControl
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:sdk="http://schemas.microsoft.com/winfx/2006/xaml/presentation/sdk" x:Name="userControl"
	mc:Ignorable="d"
	x:Class="XTS.Controls.FiringOrder"
	d:DesignWidth="630" d:DesignHeight="88" Loaded="FiringOrder_Loaded" Unloaded="FiringOrder_Unloaded">
  <UserControl.Background>
    <SolidColorBrush Color="{StaticResource ColorAMOTBackgroundOverlay}" />
  </UserControl.Background>
  <UserControl.Foreground>
    <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
  </UserControl.Foreground>

  <Grid x:Name="LayoutRoot" Background="{Binding Background, ElementName=userControl}">
    <Grid.RowDefinitions>
      <RowDefinition Height="22" />
      <RowDefinition />
      <RowDefinition Height="16" />
    </Grid.RowDefinitions>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="2" />
      <ColumnDefinition Width="1*" />
      <ColumnDefinition Width="1*" />
      <ColumnDefinition Width="1*" />
      <ColumnDefinition Width="1*" />
      <ColumnDefinition Width="1*" />
      <ColumnDefinition Width="1*" />
      <ColumnDefinition Width="1*" />
      <ColumnDefinition Width="2" />
    </Grid.ColumnDefinitions>
    <sdk:Label Grid.ColumnSpan="7" d:LayoutOverrides="Width, Height" FontSize="16" Content="{Binding Path=ResourceStrings.XTSStringFiringOrder, Source={StaticResource LocalizedResources}}" Margin="2,0,0,0" />
    <Grid Margin="2" Grid.Row="1" Grid.Column="1">
      <Grid.Background>
        <SolidColorBrush Color="{StaticResource ColorAMOTBlue}" />
      </Grid.Background>
      <sdk:Label HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="2,0,0,0" Foreground="{Binding Foreground, ElementName=userControl}" Content="{Binding Path=ResourceStrings.XTSStringLabel1, Source={StaticResource LocalizedResources}}" />
      <sdk:Label x:Name="labelCylinder1" FontSize="29.333" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{Binding Foreground, ElementName=userControl}" />
    </Grid>
    <Grid Grid.Column="2" Margin="2" Grid.Row="1">
      <Grid.Background>
        <SolidColorBrush Color="{StaticResource ColorAMOTBlue}" />
      </Grid.Background>
      <sdk:Label HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="2,0,0,0" Foreground="{Binding Foreground, ElementName=userControl}" Content="{Binding Path=ResourceStrings.XTSStringLabel2, Source={StaticResource LocalizedResources}}" />
      <sdk:Label x:Name="labelCylinder2" FontSize="29.333" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{Binding Foreground, ElementName=userControl}" />
    </Grid>
    <Grid Grid.Column="3" Margin="2" Grid.Row="1">
      <Grid.Background>
        <SolidColorBrush Color="{StaticResource ColorAMOTBlue}" />
      </Grid.Background>
      <sdk:Label HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="2,0,0,0" Foreground="{Binding Foreground, ElementName=userControl}" Content="{Binding Path=ResourceStrings.XTSStringLabel3, Source={StaticResource LocalizedResources}}" />
      <sdk:Label x:Name="labelCylinder3" FontSize="29.333" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{Binding Foreground, ElementName=userControl}" />
    </Grid>
    <Grid Grid.Column="4" Margin="2" Grid.Row="1">
      <Grid.Background>
        <SolidColorBrush Color="{StaticResource ColorAMOTBlue}" />
      </Grid.Background>
      <sdk:Label VerticalAlignment="Bottom" Foreground="{Binding Foreground, ElementName=userControl}" Content="{Binding Path=ResourceStrings.XTSStringLabel4, Source={StaticResource LocalizedResources}}" d:LayoutOverrides="Width" HorizontalAlignment="Left" Margin="2,0,0,0" />
      <sdk:Label x:Name="labelCylinder4" FontSize="29.333" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{Binding Foreground, ElementName=userControl}" />
    </Grid>
    <Grid Grid.Column="5" Margin="2" Grid.Row="1">
      <Grid.Background>
        <SolidColorBrush Color="{StaticResource ColorAMOTBlue}" />
      </Grid.Background>
      <sdk:Label HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="2,0,0,0" Foreground="{Binding Foreground, ElementName=userControl}" Content="{Binding Path=ResourceStrings.XTSStringLabel5, Source={StaticResource LocalizedResources}}" />
      <sdk:Label x:Name="labelCylinder5" FontSize="29.333" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{Binding Foreground, ElementName=userControl}" />
    </Grid>
    <Grid Grid.Column="6" Margin="2" Grid.Row="1">
      <Grid.Background>
        <SolidColorBrush Color="{StaticResource ColorAMOTBlue}" />
      </Grid.Background>
      <sdk:Label HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="2,0,0,0" Foreground="{Binding Foreground, ElementName=userControl}" Content="{Binding Path=ResourceStrings.XTSStringLabel6, Source={StaticResource LocalizedResources}}" />
      <sdk:Label x:Name="labelCylinder6" FontSize="29.333" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{Binding Foreground, ElementName=userControl}" />
    </Grid>
    <Grid Grid.Column="7" Grid.Row="1" Margin="2">
      <Grid.Background>
        <SolidColorBrush Color="{StaticResource ColorAMOTBlue}" />
      </Grid.Background>
      <sdk:Label HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="2,0,0,0" Foreground="{Binding Foreground, ElementName=userControl}" Content="{Binding Path=ResourceStrings.XTSStringLabel7, Source={StaticResource LocalizedResources}}" />
      <sdk:Label x:Name="labelCylinder7" FontSize="29.333" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{Binding Foreground, ElementName=userControl}" />
    </Grid>
    <sdk:Label d:LayoutOverrides="Height" Grid.Row="2" Margin="2,0,0,0" Content="{Binding Path=ResourceStrings.XTSStringMaxChannelsInFiringOrder, Source={StaticResource LocalizedResources}}" Grid.ColumnSpan="9">
      <sdk:Label.Foreground>
        <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
      </sdk:Label.Foreground>
    </sdk:Label>
  </Grid>
</UserControl>