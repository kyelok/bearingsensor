<UserControl
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:ei="http://schemas.microsoft.com/expression/2010/interactions" xmlns:ee="http://schemas.microsoft.com/expression/2010/effects" xmlns:i="http://schemas.microsoft.com/expression/2010/interactivity" xmlns:local="clr-namespace:XTS.Controls" xmlns:sdk="http://schemas.microsoft.com/winfx/2006/xaml/presentation/sdk" x:Name="userControl"
	mc:Ignorable="d"
	x:Class="XTS.Controls.Popup"
	d:DesignWidth="640" d:DesignHeight="480" Width="264" Height="Auto" Loaded="Popup_Loaded" Unloaded="Popup_Unloaded">

  <Grid x:Name="LayoutRoot">
    <Grid.RowDefinitions>
      <RowDefinition Height="52" />
      <RowDefinition Height="0.4*" />
      <RowDefinition Height="4" />
      <RowDefinition Height="0.6*" />
      <RowDefinition Height="52" />
    </Grid.RowDefinitions>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="*" />
      <ColumnDefinition Width="52" />
    </Grid.ColumnDefinitions>
		
    <VisualStateManager.VisualStateGroups>
      <VisualStateGroup x:Name="VisualStateGroup">
        <VisualStateGroup.Transitions>
          <VisualTransition GeneratedDuration="0:0:0.2">
            <ei:ExtendedVisualStateManager.TransitionEffect>
              <ee:FadeTransitionEffect />
            </ei:ExtendedVisualStateManager.TransitionEffect>
            <VisualTransition.GeneratedEasingFunction>
              <BackEase EasingMode="EaseIn" />
            </VisualTransition.GeneratedEasingFunction>
          </VisualTransition>
          <VisualTransition GeneratedDuration="0:0:0.2" To="Show" />
          <VisualTransition GeneratedDuration="0:0:0.2" To="Hide" />
        </VisualStateGroup.Transitions>
        <VisualState x:Name="Show">
          <Storyboard>
            <DoubleAnimation Duration="0" To="1" Storyboard.TargetProperty="(UIElement.Opacity)" Storyboard.TargetName="userControl" d:IsOptimized="True" />
          </Storyboard>
        </VisualState>
        <VisualState x:Name="Hide">
          <Storyboard>
            <DoubleAnimation Duration="0" To="0" Storyboard.TargetProperty="(UIElement.Opacity)" Storyboard.TargetName="userControl" d:IsOptimized="True" />
          </Storyboard>
        </VisualState>
      </VisualStateGroup>
    </VisualStateManager.VisualStateGroups>
    <VisualStateManager.CustomVisualStateManager>
      <ei:ExtendedVisualStateManager />
    </VisualStateManager.CustomVisualStateManager>
    <Border BorderBrush="Black" BorderThickness="1" Grid.RowSpan="5" Grid.ColumnSpan="2">
      <Border.Background>
        <SolidColorBrush Color="{StaticResource ColorAMOTGlassEffect}" />
      </Border.Background>
      <Border.Effect>
        <DropShadowEffect Opacity="0.6" />
      </Border.Effect>
    </Border>
    <Grid Margin="4,0,0,0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>
      <Button x:Name="buttonPrevious" HorizontalAlignment="Left" Style="{StaticResource ButtonStyleAMOTNavigation}" Click="buttonPrevious_Click" RenderTransformOrigin="0.5,0.5" Width="33" Margin="0,0,-22,-12" Height="38" VerticalAlignment="Bottom">
        <Button.Background>
          <SolidColorBrush Color="{StaticResource ColorAMOTBlue75Transparent}" />
        </Button.Background>
        <Button.Foreground>
          <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
        </Button.Foreground>
        <Path Width="16" Height="10" Stretch="Fill" Data="F1 M 23.9063,22.5L 21.9063,24.5L 14.9063,31.75L 14.9063,25.25L 23.9063,15.75L 32.9063,25.25L 32.9063,31.75L 25.9063,24.5L 23.9063,22.5 Z " HorizontalAlignment="Center" VerticalAlignment="Center" UseLayoutRounding="False" RenderTransformOrigin="0.5,0.5" Opacity="0.5">
          <Path.RenderTransform>
            <CompositeTransform Rotation="-90" />
          </Path.RenderTransform>
          <Path.Fill>
            <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
          </Path.Fill>
        </Path>
      </Button>
      <local:FitStackPanel x:Name="StackNames" Orientation="Horizontal" Grid.Column="1" />
      <Button x:Name="buttonNext" Grid.Column="2" HorizontalAlignment="Left" Width="33" Style="{StaticResource ButtonStyleAMOTNavigation}" Click="buttonNext_Click" RenderTransformOrigin="0.5,0.5" Margin="-22,0,0,-12" Height="38" VerticalAlignment="Bottom">
        <Button.Background>
          <SolidColorBrush Color="{StaticResource ColorAMOTBlue75Transparent}" />
        </Button.Background>
        <Button.Foreground>
          <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
        </Button.Foreground>
        <Path Width="16" Height="10" Stretch="Fill" Data="F1 M 23.9063,22.5L 21.9063,24.5L 14.9063,31.75L 14.9063,25.25L 23.9063,15.75L 32.9063,25.25L 32.9063,31.75L 25.9063,24.5L 23.9063,22.5 Z " HorizontalAlignment="Center" VerticalAlignment="Center" UseLayoutRounding="False" RenderTransformOrigin="0.5,0.5" Opacity="0.5">
          <Path.RenderTransform>
            <CompositeTransform Rotation="90" />
          </Path.RenderTransform>
          <Path.Fill>
            <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
          </Path.Fill>
        </Path>
      </Button>
    </Grid>
    <local:FitStackPanel x:Name="StackDeviation" Grid.Row="1" Orientation="Horizontal" Margin="4,0,0,0" />
    <local:FitStackPanel x:Name="StackWear" Grid.Row="3" Orientation="Horizontal" Margin="4,0,0,0" />
    <local:Scale x:Name="ScaleWear" Grid.Column="1" Grid.Row="3" d:LayoutOverrides="Width, Height" Margin="2,3,0,3" />
    <local:Scale x:Name="ScaleDeviation" d:LayoutOverrides="Width, Height" Grid.Row="1" Grid.Column="1" Margin="2,3,0,3" />
    <Button x:Name="button" Style="{StaticResource ButtonStyleAMOT}" Click="OnButtonClose_Click" Grid.Column="1" Width="44" Height="44" Grid.Row="4" Margin="4">
      <Button.Foreground>
        <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
      </Button.Foreground>
      <Button.Background>
        <SolidColorBrush Color="{StaticResource ColorAMOTButton}" />
      </Button.Background>
			
			
      <Grid>
        <Path Stretch="Fill" Data="F1 M 400,224C 400,237.255 389.255,248 376,248L 280,248C 266.745,248 256,237.255 256,224L 256,128C 256,114.745 266.745,104 280,104L 376,104C 389.255,104 400,114.745 400,128L 400,224 Z M 272,136L 312,176L 272,216L 288,232L 328,192L 368,232L 384,216L 344,176L 384,136L 368,120L 328,160L 288,120L 272,136 Z " Margin="8,4,8,12" UseLayoutRounding="False" Fill="{Binding Foreground, ElementName=button}" />
        <TextBlock Margin="2,0,0,0" TextWrapping="Wrap" Text="{Binding Path=ResourceStrings.XTSStringClose, Source={StaticResource LocalizedResources}}" FontSize="8" VerticalAlignment="Bottom" HorizontalAlignment="Left" />
      </Grid>
			
    </Button>
    <Button x:Name="button1" Style="{StaticResource ButtonStyleAMOT}" Click="OnButtonTrends_Click" Height="44" VerticalAlignment="Center" Margin="0" Width="44" HorizontalAlignment="Center" Grid.Column="2">
      <Button.Foreground>
        <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
      </Button.Foreground>
      <Button.Background>
        <SolidColorBrush Color="{StaticResource ColorAMOTButton}" />
      </Button.Background>
			
			
      <Grid>
												
        <Path Data="M0,2.6189141 L2.8139999,2.6189141 L2.8139999,33.78558 L36.582001,33.78558 L36.582001,36.618916 L0,36.618916 z M37.213223,0 L38.387848,5.4068189 L30.074724,25.614353 L29.977371,25.477348 L30.105015,25.877434 L13.971685,19.134987 L3.821414,30.801674 L3.8584554,25.760609 L13.916018,14.200482 L13.916018,14.037435 L14.017054,14.084352 L14.027615,14.072212 L14.027489,14.089197 L28.053623,20.602318 z" Canvas.Left="11" Stretch="Fill" Canvas.Top="12" UseLayoutRounding="False" Fill="{Binding Foreground, ElementName=button1}" HorizontalAlignment="Center" VerticalAlignment="Top" Width="18" Height="18" Margin="0,1,0,0" />
        <TextBlock Margin="2,0" TextWrapping="Wrap" Text="{Binding Path=ResourceStrings.XTSStringAddSpaceToTrend, Source={StaticResource LocalizedResources}}" d:LayoutOverrides="Width, Height" FontSize="8" VerticalAlignment="Bottom" HorizontalAlignment="Left" />
      </Grid>
			
    </Button>
    <RadioButton x:Name="buttonSensors" Content="{Binding Path=ResourceStrings.XTSStringSensors, Source={StaticResource LocalizedResources}}" VerticalAlignment="Center" Style="{StaticResource ToggleButtonStyleAMOT}" GroupName="CylinderOrSensor" Width="44" Height="44" HorizontalAlignment="Left" Margin="52,0,0,0" Checked="buttonSensors_Checked" Grid.Row="4" d:LayoutOverrides="GridBox" FontSize="8" ContentTemplate="{StaticResource ContentTemplateAMOTButton}">
      <RadioButton.Foreground>
        <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
      </RadioButton.Foreground>
      <RadioButton.Background>
        <SolidColorBrush Color="{StaticResource ColorAMOTButton}" />
      </RadioButton.Background>
    </RadioButton>
    <RadioButton x:Name="buttonCylinders" Content="{Binding Path=ResourceStrings.XTSStringCylinders, Source={StaticResource LocalizedResources}}" Style="{StaticResource ToggleButtonStyleAMOT}" GroupName="CylinderOrSensor" Width="44" HorizontalAlignment="Left" Margin="4,0,0,0" Checked="buttonCylinders_Checked" d:LayoutOverrides="GridBox" Grid.Row="4" Height="44" VerticalAlignment="Center" ContentTemplate="{StaticResource ContentTemplateAMOTButton}" FontSize="8">
      <RadioButton.Foreground>
        <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
      </RadioButton.Foreground>
      <RadioButton.Background>
        <SolidColorBrush Color="{StaticResource ColorAMOTButton}" />
      </RadioButton.Background>
    </RadioButton>
  </Grid>
</UserControl>