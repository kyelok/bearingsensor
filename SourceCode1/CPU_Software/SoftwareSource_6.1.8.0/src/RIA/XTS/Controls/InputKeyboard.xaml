<telerik:RadWindow x:Class="XTS.ChildWindows.InputKeyboard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
                  
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    
    WindowStartupLocation="Manual"
    CanMove="False"
    CanClose="False"
    ResizeMode="NoResize"
    BorderBrush="{x:Null}" BorderBackground="{x:Null}" Background="{x:Null}" Header="" Loaded="InputKeyboard_Loaded">

    <telerik:RadWindow.Resources>
        <telerik:MetroTheme x:Key="Theme" />

        <DataTemplate x:Key="WindowHeaderTemplate">
        </DataTemplate>


        <Style x:Key="RadWindowStyle1" TargetType="telerik:RadWindow">
            <Setter Property="IsTopmost" Value="true"/>
            <Setter Property="telerik:AnimationManager.AnimationSelector">
                <Setter.Value>
                    <telerik:AnimationSelector>
                        <telerik:AnimationGroup AnimationName="Show">

                            <!--
                            
                            <telerik:FadeAnimation Direction="In"  TargetElementName="LayoutRoot">
                                
                                
                                <telerik:FadeAnimation.Easing>
                                    <QuarticEase EasingMode="EaseOut"/>
                                </telerik:FadeAnimation.Easing>
                            </telerik:FadeAnimation>
                            <telerik:ScaleAnimation Direction="In" MinScale="0.9" TargetElementName="LayoutRoot">
                                <telerik:ScaleAnimation.Easing>
                                    <QuarticEase EasingMode="EaseOut"/>
                                </telerik:ScaleAnimation.Easing>
                            </telerik:ScaleAnimation>
                            -->
                        </telerik:AnimationGroup>
                        <telerik:AnimationGroup AnimationName="Hide">
                            <!--
                            <telerik:FadeAnimation Direction="Out" TargetElementName="LayoutRoot">
                                <telerik:FadeAnimation.Easing>
                                    <QuarticEase EasingMode="EaseOut"/>
                                </telerik:FadeAnimation.Easing>
                            </telerik:FadeAnimation>
                            <telerik:ScaleAnimation Direction="Out" MinScale="0.9" TargetElementName="LayoutRoot">
                                <telerik:ScaleAnimation.Easing>
                                    <QuarticEase EasingMode="EaseIn"/>
                                </telerik:ScaleAnimation.Easing>
                            </telerik:ScaleAnimation>
                            -->
                        </telerik:AnimationGroup>
                    </telerik:AnimationSelector>
                </Setter.Value>
            </Setter>
        </Style>
    </telerik:RadWindow.Resources>

    <telerik:RadWindow.Style>
        <StaticResource ResourceKey="RadWindowStyle1"/>
    </telerik:RadWindow.Style>

    <Grid x:Name="LayoutRoot">
        <Grid.Background>
            <SolidColorBrush Color="{StaticResource ColorAMOTGlassEffect}">
            </SolidColorBrush>
        </Grid.Background>

        <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Bottom" Name="AlphaKeyboard" Margin="4">
            <StackPanel Name="Line1" HorizontalAlignment="Right" Orientation="Horizontal">
                <StackPanel Name="Line1Keys" HorizontalAlignment="Right" Orientation="Horizontal" >
                    
                </StackPanel>
                <Button  Width="84" Height="44" Name="BackSpace" Click="BackSpace_Click" Style="{StaticResource ButtonStyleAMOT}" Margin="4" IsTabStop="False" >
                	<Button.Foreground>
                		<SolidColorBrush Color="{StaticResource ColorAMOTText}"/>
                	</Button.Foreground>
                	<Button.Background>
                		<SolidColorBrush Color="{StaticResource ColorAMOTButton}"/>
                	</Button.Background>
