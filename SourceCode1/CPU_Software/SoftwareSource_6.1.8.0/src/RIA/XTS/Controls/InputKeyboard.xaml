                <Button Width="44" Height="44" Style="{StaticResource ButtonStyleAMOT}" Margin="4" Content="1" Click="b_Click" Name="NumericOne" ContentTemplate="{StaticResource ContentTemplateAMOTButton}" IsTabStop="False">
                	<Button.Foreground>
                		<SolidColorBrush Color="{StaticResource ColorAMOTText}"/>
                	</Button.Foreground>
                	<Button.Background>
                		<SolidColorBrush Color="{StaticResource ColorAMOTButton}"/>
                	</Button.Background>
                </Button>
                <Button Width="44" Height="44" Style="{StaticResource ButtonStyleAMOT}" Margin="4" Content="2" Click="b_Click" Name="NumericTwo" ContentTemplate="{StaticResource ContentTemplateAMOTButton}" IsTabStop="False">
                	<Button.Foreground>
                		<SolidColorBrush Color="{StaticResource ColorAMOTText}"/>
                	</Button.Foreground>
                	<Button.Background>
                		<SolidColorBrush Color="{StaticResource ColorAMOTButton}"/>
                	</Button.Background>
                </Button>
                <Button Width="44" Height="44" Style="{StaticResource ButtonStyleAMOT}" Margin="4" Content="3" Click="b_Click" Name="NumericThree" ContentTemplate="{StaticResource ContentTemplateAMOTButton}" IsTabStop="False">
                	<Button.Foreground>
                		<SolidColorBrush Color="{StaticResource ColorAMOTText}"/>
                	</Button.Foreground>
                	<Button.Background>
                		<SolidColorBrush Color="{StaticResource ColorAMOTButton}"/>
                	</Button.Background>
                </Button>
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <Button Width="44" Height="44" Style="{StaticResource ButtonStyleAMOT}" Margin="4" Content="4" Click="b_Click"  Name="NumericFour" ContentTemplate="{StaticResource ContentTemplateAMOTButton}" IsTabStop="False">
                	<Button.Foreground>
                		<SolidColorBrush Color="{StaticResource ColorAMOTText}"/>
                	</Button.Foreground>
                	<Button.Background>
                		<SolidColorBrush Color="{StaticResource ColorAMOTButton}"/>
                	</Button.Background>
                </Button>
                <Button Width="44" Height="44" Style="{StaticResource ButtonStyleAMOT}" Margin="4" Content="5" Click="b_Click"  Name="NumericFive" ContentTemplate="{StaticResource ContentTemplateAMOTButton}" IsTabStop="False">
                	<Button.Foreground>
                		<SolidColorBrush Color="{StaticResource ColorAMOTText}"/>
                	</Button.Foreground>
                	<Button.Background>
                		<SolidColorBrush Color="{StaticResource ColorAMOTButton}"/>
                	</Button.Background>
                </Button>
                <Button Width="44" Height="44" Style="{StaticResource ButtonStyleAMOT}" Margin="4" Content="6" Click="b_Click"  Name="NumericSix" ContentTemplate="{StaticResource ContentTemplateAMOTButton}" IsTabStop="False">
                	<Button.Foreground>
                		<SolidColorBrush Color="{StaticResource ColorAMOTText}"/>
                	</Button.Foreground>
                	<Button.Background>
                		<SolidColorBrush Color="{StaticResource ColorAMOTButton}"/>
                	</Button.Background>
                </Button>
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <Button Width="44" Height="44" Style="{StaticResource ButtonStyleAMOT}" Margin="4" Content="7" Click="b_Click" Name="NumericSeven" ContentTemplate="{StaticResource ContentTemplateAMOTButton}" IsTabStop="False">
                	<Button.Foreground>
                		<SolidColorBrush Color="{StaticResource ColorAMOTText}"/>
                	</Button.Foreground>
                	<Button.Background>
                		<SolidColorBrush Color="{StaticResource ColorAMOTButton}"/>
                	</Button.Background>
                </Button>
                <Button Width="44" Height="44" Style="{StaticResource ButtonStyleAMOT}" Margin="4" Content="8" Click="b_Click"  Name="NumericEight" ContentTemplate="{StaticResource ContentTemplateAMOTButton}" IsTabStop="False">
                	<Button.Foreground>
                		<SolidColorBrush Color="{StaticResource ColorAMOTText}"/>
                	</Button.Foreground>
                	<Button.Background>
                		<SolidColorBrush Color="{StaticResource ColorAMOTButton}"/>
                	</Button.Background>
                </Button>
                <Button Width="44" Height="44" Style="{StaticResource ButtonStyleAMOT}" Margin="4" Content="9" Click="b_Click"  Name="NumericNine" ContentTemplate="{StaticResource ContentTemplateAMOTButton}" IsTabStop="False">
                	<Button.Foreground>
                		<SolidColorBrush Color="{StaticResource ColorAMOTText}"/>
                	</Button.Foreground>
                	<Button.Background>
                		<SolidColorBrush Color="{StaticResource ColorAMOTButton}"/>
                	</Button.Background>
                </Button>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Width="44" Height="44" Style="{StaticResource ButtonStyleAMOT}" Margin="4" Content="." Click="b_Click"  Name="Point" ContentTemplate="{StaticResource ContentTemplateAMOTButton}" IsTabStop="False">
                	<Button.Foreground>
                		<SolidColorBrush Color="{StaticResource ColorAMOTText}"/>
                	</Button.Foreground>
                	<Button.Background>
                		<SolidColorBrush Color="{StaticResource ColorAMOTButton}"/>
                	</Button.Background>
                </Button>
                
                <Button Width="44" Height="44" Style="{StaticResource ButtonStyleAMOT}" Margin="4" Content="0" Click="b_Click"  Name="NumericZero" ContentTemplate="{StaticResource ContentTemplateAMOTButton}" IsTabStop="False">
                	<Button.Foreground>
                		<SolidColorBrush Color="{StaticResource ColorAMOTText}"/>
                	</Button.Foreground>
                	<Button.Background>
                		<SolidColorBrush Color="{StaticResource ColorAMOTButton}"/>
                	</Button.Background>
                </Button>

                <Button  Width="44" Height="44" Name="NumBackSpace" Click="BackSpace_Click" Style="{StaticResource ButtonStyleAMOT}" Margin="4" IsTabStop="False" >
                	<Button.Foreground>
                		<SolidColorBrush Color="{StaticResource ColorAMOTText}"/>
                	</Button.Foreground>
                	<Button.Background>
                		<SolidColorBrush Color="{StaticResource ColorAMOTButton}"/>
                	</Button.Background>
                    <Grid>
                        <Path  Stretch="Fill" VerticalAlignment="Center"
                               HorizontalAlignment="Center"  Data="F1 M 34,15L 18.2721,15L 10.7868,22.4853C 10.0058,23.2663 10.0058,24.5327 10.7868,25.3137L 18.2231,33L 34,33C 35.1046,33 36,32.1046 36,31L 36,17C 36,15.8954 35.1046,15 34,15 Z M 32.4444,17C 33.3036,17 34,17.6964 34,18.5556L 34,29.4444C 34,30.3036 33.3036,31 32.4444,31L 19.5,31L 13.3898,25.0218C 12.7823,24.4143 12.7823,23.4294 13.3898,22.8219L 19.5,17L 32.4444,17 Z M 22.4644,28.9496L 25.9999,25.4141L 29.5355,28.9496L 30.9497,27.5354L 27.4141,23.9999L 30.9496,20.4644L 29.5354,19.0501L 25.9999,22.5857L 22.4644,19.0502L 21.0502,20.4644L 24.5857,23.9999L 21.0502,27.5354L 22.4644,28.9496 Z " UseLayoutRounding="False" Fill="{Binding Foreground, ElementName=NumBackSpace}" Width="34" Height="24"   />
                    </Grid>
                </Button>

            </StackPanel>
            
