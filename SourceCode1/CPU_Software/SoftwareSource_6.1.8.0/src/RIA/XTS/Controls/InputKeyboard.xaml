                    </Grid>
                </Button>
            </StackPanel>
            <StackPanel Name="Line2" HorizontalAlignment="Right" Orientation="Horizontal">
                <StackPanel Name="Line2Keys" HorizontalAlignment="Right" Orientation="Horizontal"></StackPanel>

                <Button  Width="74" Height="44" Name="Return" Click="Return_Click" Style="{StaticResource ButtonStyleAMOT}" Margin="4" Content="Enter" ContentTemplate="{StaticResource ContentTemplateAMOTButton}" IsTabStop="False">
                	<Button.Background>
                		<SolidColorBrush Color="{StaticResource ColorAMOTButton}"/>
                	</Button.Background>
                    <Button.Foreground>
                        <SolidColorBrush Color="{StaticResource ColorAMOTText}"/>
                    </Button.Foreground>
                </Button>
            </StackPanel>
            
            <StackPanel Name="Line3" HorizontalAlignment="Center" Orientation="Horizontal">

                <ToggleButton  Width="44" Height="44" x:Name="LShift" Click="Shift_Click" Style="{StaticResource ToggleButtonStyleAMOTPlain}" IsTabStop="False">
                	<ToggleButton.Foreground>
                		<SolidColorBrush Color="{StaticResource ColorAMOTText}"/>
                	</ToggleButton.Foreground>
                	<ToggleButton.Background>
                		<SolidColorBrush Color="{StaticResource ColorAMOTButton}"/>
                	</ToggleButton.Background>
                	<Grid>
                		<Path  Stretch="Fill" VerticalAlignment="Center"
                			HorizontalAlignment="Center" Data="F1 M 22,36L 26,36L 26,19.75L 33,27L 33,20.5L 24,11L 15,20.5L 15,27L 22,19.75L 22,36 Z " UseLayoutRounding="False" Fill="{Binding Foreground, ElementName=LShift}" Width="18" Height="19"   />
                	</Grid>
                </ToggleButton>

                <StackPanel x:Name="Line3Keys" HorizontalAlignment="Right" Orientation="Horizontal"/>
                <ToggleButton  Width="44" Height="44" x:Name="RShift" Click="Shift_Click" Style="{StaticResource ToggleButtonStyleAMOTPlain}" Margin="4" IsTabStop="False" >
                	<ToggleButton.Background>
                		<SolidColorBrush Color="{StaticResource ColorAMOTButton}"/>
                	</ToggleButton.Background>
                	<ToggleButton.Foreground>
                		<SolidColorBrush Color="{StaticResource ColorAMOTText}"/>
                	</ToggleButton.Foreground>
                    <Grid>
                        <Path  Stretch="Fill" VerticalAlignment="Center"
                               HorizontalAlignment="Center" Data="F1 M 22,36L 26,36L 26,19.75L 33,27L 33,20.5L 24,11L 15,20.5L 15,27L 22,19.75L 22,36 Z " UseLayoutRounding="False" Fill="{Binding Foreground, ElementName=RShift}" Width="18" Height="19"   />
                    </Grid>
                </ToggleButton>
            </StackPanel>
            
            <StackPanel Name="Line4" HorizontalAlignment="Center" Orientation="Horizontal">
                <ToggleButton Width="44" Height="44" Style="{StaticResource ToggleButtonStyleAMOTPlain}" Content="CTRL" Name="Ctrl" Visibility="Collapsed" ContentTemplate="{StaticResource ContentTemplateAMOTButton}" IsTabStop="False">
                    <ToggleButton.Foreground>
                		<SolidColorBrush Color="{StaticResource ColorAMOTText}"/>
                	</ToggleButton.Foreground>
                	<ToggleButton.Background>
                		<SolidColorBrush Color="{StaticResource ColorAMOTButton}"/>
                	</ToggleButton.Background>
                </ToggleButton>

                <ToggleButton Width="44" Height="44" Style="{StaticResource ToggleButtonStyleAMOTPlain}" Margin="2" Content="&amp;123" Name="AltText" Click="AltText_Click" ContentTemplate="{StaticResource ContentTemplateAMOTButton}" IsTabStop="False">
                	<ToggleButton.Foreground>
                		<SolidColorBrush Color="{StaticResource ColorAMOTText}"/>
                	</ToggleButton.Foreground>
                	<ToggleButton.Background>
                		<SolidColorBrush Color="{StaticResource ColorAMOTButton}"/>
                	</ToggleButton.Background>
                </ToggleButton>

                <Button Width="247" Height="44" Style="{StaticResource ButtonStyleAMOT}" Margin="2" Name="Space" Click="Space_Click" IsTabStop="False">
                	<Button.Foreground>
                		<SolidColorBrush Color="{StaticResource ColorAMOTText}"/>
                	</Button.Foreground>
                	<Button.Background>
                		<SolidColorBrush Color="{StaticResource ColorAMOTButton}"/>
                	</Button.Background>
                </Button>

                <Button Width="44" Height="44" Style="{StaticResource ButtonStyleAMOT}" Margin="2" Name="CaratLeft" Click="CaratLeft_Click" IsTabStop="False">
                	<Button.Foreground>
                		<SolidColorBrush Color="{StaticResource ColorAMOTText}"/>
                	</Button.Foreground>
                	<Button.Background>
                		<SolidColorBrush Color="{StaticResource ColorAMOTButton}"/>
                	</Button.Background>
                    <Grid>
                        <Path  Stretch="Fill" VerticalAlignment="Center"
                               HorizontalAlignment="Center" Data="F1 M 22.6563,23.75L 24.6563,25.75L 31.9063,32.75L 25.4063,32.75L 15.9063,23.75L 25.4063,14.75L 31.9063,14.75L 24.6563,21.75L 22.6563,23.75 Z " UseLayoutRounding="False" Fill="{Binding Foreground, ElementName=CaratLeft}" Width="16" Height="18"   />
                    </Grid>
                </Button>
                <Button Width="44" Height="44" Style="{StaticResource ButtonStyleAMOT}" Margin="2" Name="CaratRight" Click="CaratRight_Click" IsTabStop="False">
                	<Button.Foreground>
                		<SolidColorBrush Color="{StaticResource ColorAMOTText}"/>
                	</Button.Foreground>
                	<Button.Background>
                		<SolidColorBrush Color="{StaticResource ColorAMOTButton}"/>
                	</Button.Background>
                    <Grid>
                        <Path  Stretch="Fill" VerticalAlignment="Center"
                               HorizontalAlignment="Center" Data="F1 M 25.1563,23.75L 23.1563,21.75L 15.9063,14.75L 22.4063,14.75L 31.9063,23.75L 22.4063,32.75L 15.9063,32.75L 23.1563,25.75L 25.1563,23.75 Z " UseLayoutRounding="False" Fill="{Binding Foreground, ElementName=CaratRight}" Width="16" Height="18"   />
                    </Grid>
                </Button>
            </StackPanel>
        </StackPanel>
        
