<UserControl
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:sdk="http://schemas.microsoft.com/winfx/2006/xaml/presentation/sdk" x:Name="userControl"
	mc:Ignorable="d"
	x:Class="XTS.Controls.CylinderPercentComparison"
	d:DesignWidth="116" d:DesignHeight="36">
  <UserControl.Foreground>
    <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
  </UserControl.Foreground>

  <Grid x:Name="LayoutRoot" MaxHeight="44" Margin="6,0">
    <Grid.RowDefinitions>
      <RowDefinition Height="3*" />
      <RowDefinition Height="1*" />
    </Grid.RowDefinitions>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="2*" />
      <ColumnDefinition Width="3*" MinWidth="44" />
      <ColumnDefinition Width="2*" />
    </Grid.ColumnDefinitions>
    <Rectangle VerticalAlignment="Bottom" Height="4" Grid.ColumnSpan="3">
      <Rectangle.Fill>
        <SolidColorBrush Color="{StaticResource ColorAMOTBGIcon}" />
      </Rectangle.Fill>
    </Rectangle>
    <Rectangle HorizontalAlignment="Left" Width="4" Grid.Row="1" d:LayoutOverrides="GridBox">
      <Rectangle.Fill>
        <SolidColorBrush Color="{StaticResource ColorAMOTBGIcon}" />
      </Rectangle.Fill>
    </Rectangle>
    <Rectangle Grid.Column="1" Grid.RowSpan="2">
      <Rectangle.Fill>
        <SolidColorBrush Color="{StaticResource ColorAMOTBlue}" />
      </Rectangle.Fill>
    </Rectangle>
    <sdk:Label VerticalAlignment="Bottom" Margin="2,0,10,0" Content="{Binding Path=ResourceStrings.XTSStringPercentChar, Source={StaticResource LocalizedResources}}" FontWeight="Bold" FontSize="16" Foreground="{Binding Foreground, ElementName=userControl}" d:LayoutOverrides="Width" Grid.Column="1" Grid.RowSpan="2" />
    <Rectangle x:Name="RectStatus" Margin="0" VerticalAlignment="Top" Height="8" Grid.Column="1">
      <Rectangle.Fill>
        <SolidColorBrush Color="{StaticResource ColorAMOTSensorNormal}" />
      </Rectangle.Fill>
    </Rectangle>
    <Rectangle Margin="0" Stroke="Black" Opacity="0.5" VerticalAlignment="Top" Height="8" Grid.Column="1" />
    <Rectangle HorizontalAlignment="Right" Width="4" Grid.Row="1" d:LayoutOverrides="GridBox" Grid.Column="2">
      <Rectangle.Fill>
        <SolidColorBrush Color="{StaticResource ColorAMOTBGIcon}" />
      </Rectangle.Fill>
    </Rectangle>
  </Grid>
</UserControl>