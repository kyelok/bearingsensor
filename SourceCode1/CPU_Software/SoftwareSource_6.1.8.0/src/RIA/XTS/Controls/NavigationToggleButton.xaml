<UserControl x:Class="XTS.Controls.NavigationToggleButton"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    d:DesignHeight="88" d:DesignWidth="88" Loaded="NavigationToggleButton_Loaded">
    
    <Grid x:Name="LayoutRoot">
        <ToggleButton x:Name="Advanced" VerticalAlignment="Top" Style="{StaticResource ToggleButtonStyleAMOT75Opacity}" Width="88" Height="88" HorizontalAlignment="Center" Checked="Advanced_Checked" Unchecked="Advanced_Unchecked">
            <ToggleButton.Background>
                <SolidColorBrush Color="{StaticResource ColorAMOTButton}"/>
            </ToggleButton.Background>
            <ToggleButton.Foreground>
                <SolidColorBrush Color="{StaticResource ColorAMOTText}"/>
            </ToggleButton.Foreground>

            <Grid>
                <Path x:Name="Path" Canvas.Left="7.71753" Canvas.Top="12.8158" Stretch="Fill" Data="{Binding Icon}" Margin="12,8,12,24" UseLayoutRounding="False" RenderTransformOrigin="0.5,0.5" HorizontalAlignment="Center" VerticalAlignment="Center" Fill="White"/>
                <TextBlock Text="{Binding Text}" HorizontalAlignment="Left" VerticalAlignment="Bottom" FontSize="10.667" Margin="2,0,0,0" d:LayoutOverrides="HorizontalAlignment"/>
            </Grid>
        </ToggleButton>
    </Grid>
</UserControl>
