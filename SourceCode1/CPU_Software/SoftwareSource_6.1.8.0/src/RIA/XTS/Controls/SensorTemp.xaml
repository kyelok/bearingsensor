<UserControl
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:sdk="http://schemas.microsoft.com/winfx/2006/xaml/presentation/sdk" x:Name="userControl"
    xmlns:local="clr-namespace:XTS.Controls"
	mc:Ignorable="d"
	x:Class="XTS.Controls.SensorTemperature"
	d:DesignWidth="60" d:DesignHeight="280" MinWidth="120" MinHeight="60">
	<UserControl.Background>
		<SolidColorBrush Color="{StaticResource ColorAMOTButton}"/>
	</UserControl.Background>
	<UserControl.Foreground>
		<SolidColorBrush Color="{StaticResource ColorAMOTText}"/>
	</UserControl.Foreground>

	<Grid x:Name="LayoutRoot" Background="{Binding Background, ElementName=userControl}">
		<Grid.RowDefinitions>
			<RowDefinition Height="20"/>
            <RowDefinition Height="22"/>
			<RowDefinition Height="22"/>
            <RowDefinition Height="22"/>            
        </Grid.RowDefinitions>
        
        <ToolTipService.ToolTip>
            <ToolTip x:Name="ToolTipName" Content="temprature"></ToolTip>
        </ToolTipService.ToolTip>
        
        <CheckBox Name="checkBoxEnable" Content="" Height="16" Margin="40,2,0,0" HorizontalAlignment="Center"  VerticalAlignment="Top" Width="50" />
        <local:InputBox IsPassword="False" x:Name="txtName" Margin="0" FontSize="10" HorizontalContentAlignment="Center" MaxWidth="116"  Grid.Row="1"/>
        <local:InputBox IsPassword="False" x:Name="txtAlarmLevel" Margin="0" FontSize="10" HorizontalContentAlignment="Center" MaxWidth="116" Grid.Row="2"/>
        <local:InputBox IsPassword="False" x:Name="txtSlowdownLevel" Margin="0" FontSize="10" HorizontalContentAlignment="Center" MaxWidth="116" Grid.Row="3"/>        
    </Grid>
</UserControl>