<UserControl
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:sdk="http://schemas.microsoft.com/winfx/2006/xaml/presentation/sdk" x:Name="userControl"
  xmlns:local="clr-namespace:XTS"
	mc:Ignorable="d"
	x:Class="XTS.Controls.SEDM" d:DesignHeight="364" Height="Auto">

  <UserControl.Resources>
    <local:XTSSEDMConverter x:Key="XTSSEDMConverter" />
    <local:MimicModel x:Key="MimicModelDataSource" />
    <local:XTSSensorStatusConverter x:Key="StatusConverter" />
  </UserControl.Resources>
  <UserControl.Background>
    <SolidColorBrush Color="{StaticResource ColorAMOTButton}" />
  </UserControl.Background>
  <UserControl.Foreground>
    <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
  </UserControl.Foreground>

  <Grid x:Name="LayoutRoot" DataContext="{Binding Source={StaticResource MimicModelDataSource}}">
    <Grid.RowDefinitions>
      <RowDefinition />
      <RowDefinition Height="32" />
      <RowDefinition Height="10" />
      <RowDefinition Height="Auto" MinHeight="55" />
      <RowDefinition Height="10" />
      <RowDefinition Height="8" />
      <RowDefinition Height="18" />
    </Grid.RowDefinitions>
    <Button x:Name="buttonSEDM" Style="{StaticResource ButtonStyleAMOT}" Background="{Binding Background, ElementName=userControl}" Foreground="{Binding Foreground, ElementName=userControl}" Click="buttonSEDM_Click" Grid.RowSpan="7" ContentTemplate="{StaticResource ContentTemplateAMOTButton}" Content="{Binding Path=ResourceStrings.XTSStringSEDM, Source={StaticResource LocalizedResources}}" IsEnabled="{Binding IsEnabled, ElementName=userControl}" />
    <Rectangle Fill="{Binding XTSDataSource.EngineData.SEDM.Status, Converter={StaticResource StatusConverter}}" Height="8" VerticalAlignment="Top" Margin="0" />
    <Rectangle Height="8" VerticalAlignment="Top" Stroke="Black" Opacity="0.35" Margin="0" />
    <Path Width="14" Height="21" Stretch="Fill" Data="F1 M 33.0013,11.9983L 24,22L 32,22L 15.9989,38L 22,25L 15,25L 22.9999,11.9983L 33.0013,11.9983 Z " HorizontalAlignment="Left" VerticalAlignment="Top" Margin="8,12,0,0" UseLayoutRounding="False" Fill="{Binding Foreground, ElementName=userControl}" IsHitTestVisible="False" />
    <Rectangle StrokeThickness="0.5" IsHitTestVisible="False" Grid.Row="1" VerticalAlignment="Bottom" Height="20" Grid.RowSpan="6" Margin="-1,0,-1,107">
      <Rectangle.Fill>
        <LinearGradientBrush EndPoint="0.5,0" StartPoint="0.5,1">
          <GradientStop Color="#FF606060" />
          <GradientStop Color="White" Offset="0.65" />
        </LinearGradientBrush>
      </Rectangle.Fill>
    </Rectangle>
    <Path Data="M60,82 L60,100" Stretch="Fill" StrokeLineJoin="Round" UseLayoutRounding="False" Width="1" HorizontalAlignment="Center" Stroke="{Binding Foreground, ElementName=userControl}" IsHitTestVisible="False" Grid.Row="2" StrokeStartLineCap="Square" StrokeEndLineCap="Square" />
    <Path Data="M60,82 L60,100" Stretch="Fill" StrokeLineJoin="Round" UseLayoutRounding="False" Width="1" HorizontalAlignment="Center" Stroke="{Binding Foreground, ElementName=userControl}" IsHitTestVisible="False" Grid.Row="4" StrokeStartLineCap="Square" StrokeEndLineCap="Square" />
    <Ellipse x:Name="ellipse" StrokeLineJoin="Round" HorizontalAlignment="Center" Stroke="{Binding Foreground, ElementName=userControl}" IsHitTestVisible="False" Grid.Row="3" Width="55" Height="55" />
    <TextBlock x:Name="LabelMV" HorizontalAlignment="Center" FontSize="{Binding FontSize, ElementName=userControl}" Text="{Binding XTSDataSource.EngineData.SEDM.Value, Converter={StaticResource XTSSEDMConverter}}" FontFamily="{Binding FontFamily, ElementName=userControl}" Foreground="{Binding Foreground, ElementName=userControl}" FontWeight="{Binding FontWeight, ElementName=userControl}" IsHitTestVisible="False" Grid.Row="3" d:LayoutOverrides="Height" VerticalAlignment="Center" Margin="6,0" TextAlignment="Center" TextWrapping="Wrap" />
    <Path Stretch="Fill" StrokeLineJoin="Round" Data="M 96,416L 274.667,416M 160,416L 128,448M 192,416L 160,448M 224,416L 192,448M 128,416L 96,448M 256,416L 224,448" UseLayoutRounding="False" HorizontalAlignment="Center" Width="30" Stroke="{Binding Foreground, ElementName=userControl}" IsHitTestVisible="False" Grid.Row="5" StrokeStartLineCap="Square" StrokeEndLineCap="Square" />
    <Path Stretch="Fill" StrokeLineJoin="Round" Stroke="#FF787878" Data="F1 M 192,256L 192,128L 224,96L 352,96L 384,128L 384,256L 352,288L 224,288L 192,256 Z " HorizontalAlignment="Center" UseLayoutRounding="False" Width="40" IsHitTestVisible="False" Grid.Row="1">
      <Path.Fill>
        <ImageBrush Stretch="Fill" ImageSource="/XTS;component/Resources/BrushedMetalBack.png" />
      </Path.Fill>
    </Path>
  </Grid>
</UserControl>