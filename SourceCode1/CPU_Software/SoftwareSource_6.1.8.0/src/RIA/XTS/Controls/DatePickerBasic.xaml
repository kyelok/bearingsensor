<UserControl
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:sdk="http://schemas.microsoft.com/winfx/2006/xaml/presentation/sdk" xmlns:XTS="clr-namespace:XTS" x:Name="userControl" x:Class="XTS.Controls.DatePickerBasic"
    mc:Ignorable="d"
    d:DesignHeight="300" d:DesignWidth="400">
    
  <UserControl.Resources>
    <XTS:XTSDisabledOpacityConverter x:Key="XTSDisabledOpacityConverter" />
  </UserControl.Resources>
    
  <Grid x:Name="LayoutRoot" Background="{Binding Background, ElementName=userControl}">
    <Grid.RowDefinitions>
      <RowDefinition Height="0.5*" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="0.5*" />
    </Grid.RowDefinitions>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="1*" />
      <ColumnDefinition Width="2*" />
      <ColumnDefinition Width="1*" />
    </Grid.ColumnDefinitions>
    <Button Content="{Binding Path=ResourceStrings.XTSStringButton, Source={StaticResource LocalizedResources}}" Style="{StaticResource ButtonStyleAMOTNavigationUp}" Click="buttonDayUp_Click" Margin="4" BorderBrush="{x:Null}">
      <Button.Foreground>
        <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
      </Button.Foreground>
      <Button.Background>
        <SolidColorBrush Color="{StaticResource ColorAMOTButton}" />
      </Button.Background>
    </Button>
    <TextBlock x:Name="textBlockDay" Foreground="{Binding Foreground, ElementName=userControl}" FontSize="{Binding FontSize, ElementName=userControl}" FontWeight="{Binding FontWeight, ElementName=userControl}" Text="{Binding Path=ResourceStrings.XTSStringLabel1, Source={StaticResource LocalizedResources}}" TextAlignment="Center" Margin="4,0" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="{Binding IsEnabled, Converter={StaticResource XTSDisabledOpacityConverter}, ElementName=userControl}" Grid.Row="1" />
    <TextBlock x:Name="textBlockMonth" Foreground="{Binding Foreground, ElementName=userControl}" FontSize="{Binding FontSize, ElementName=userControl}" Text="{Binding Path=ResourceStrings.XTSStringApril, Source={StaticResource LocalizedResources}}" FontWeight="{Binding FontWeight, ElementName=userControl}" TextAlignment="Center" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="4,0" Grid.Column="1" Opacity="{Binding IsEnabled, Converter={StaticResource XTSDisabledOpacityConverter}, ElementName=userControl}" Grid.Row="1" />
    <TextBlock x:Name="textBlockYear" Foreground="{Binding Foreground, ElementName=userControl}" FontSize="{Binding FontSize, ElementName=userControl}" FontWeight="{Binding FontWeight, ElementName=userControl}" Text="{Binding Path=ResourceStrings.XTSStringLabel2012, Source={StaticResource LocalizedResources}}" TextAlignment="Center" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="4,0" Grid.Column="2" Opacity="{Binding IsEnabled, Converter={StaticResource XTSDisabledOpacityConverter}, ElementName=userControl}" Grid.Row="1" />
    <Button Content="{Binding Path=ResourceStrings.XTSStringButton, Source={StaticResource LocalizedResources}}" Grid.Row="2" Style="{StaticResource ButtonStyleAMOTNavigationDown}" Click="buttonDayDown_Click" Margin="4" BorderBrush="{x:Null}">
      <Button.Foreground>
        <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
      </Button.Foreground>
      <Button.Background>
        <SolidColorBrush Color="{StaticResource ColorAMOTButton}" />
      </Button.Background>
    </Button>
    <Button Content="{Binding Path=ResourceStrings.XTSStringButton, Source={StaticResource LocalizedResources}}" Grid.Column="1" Style="{StaticResource ButtonStyleAMOTNavigationUp}" Click="buttonMonthUp_Click" Margin="4" BorderBrush="{x:Null}">
      <Button.Foreground>
        <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
      </Button.Foreground>
      <Button.Background>
        <SolidColorBrush Color="{StaticResource ColorAMOTButton}" />
      </Button.Background>
    </Button>
    <Button Content="{Binding Path=ResourceStrings.XTSStringButton, Source={StaticResource LocalizedResources}}" Grid.Column="1" Grid.Row="2" Style="{StaticResource ButtonStyleAMOTNavigationDown}" Click="buttonMonthDown_Click" Margin="4" BorderBrush="{x:Null}">
      <Button.Foreground>
        <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
      </Button.Foreground>
      <Button.Background>
        <SolidColorBrush Color="{StaticResource ColorAMOTButton}" />
      </Button.Background>
    </Button>
    <Button Content="{Binding Path=ResourceStrings.XTSStringButton, Source={StaticResource LocalizedResources}}" Grid.Column="2" Style="{StaticResource ButtonStyleAMOTNavigationUp}" Click="buttonYearUp_Click" Margin="4" BorderBrush="{x:Null}">
      <Button.Foreground>
        <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
      </Button.Foreground>
      <Button.Background>
        <SolidColorBrush Color="{StaticResource ColorAMOTButton}" />
      </Button.Background>
    </Button>
    <Button Content="{Binding Path=ResourceStrings.XTSStringButton, Source={StaticResource LocalizedResources}}" Grid.Column="2" Grid.Row="2" Style="{StaticResource ButtonStyleAMOTNavigationDown}" Click="buttonYearDown_Click" Margin="4" BorderBrush="{x:Null}">
      <Button.Foreground>
        <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
      </Button.Foreground>
      <Button.Background>
        <SolidColorBrush Color="{StaticResource ColorAMOTButton}" />
      </Button.Background>
    </Button>
  </Grid>
</UserControl>
