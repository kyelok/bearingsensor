<UserControl
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:XTS="clr-namespace:XTS" x:Name="userControl" x:Class="XTS.Controls.TimePicker"
    mc:Ignorable="d"
    d:DesignHeight="300" d:DesignWidth="400">

  <UserControl.Resources>
    <XTS:XTSDisabledOpacityConverter x:Key="XTSDisabledOpacityConverter" />
  </UserControl.Resources>

  <Grid x:Name="LayoutRoot" Background="{Binding Background, ElementName=userControl}">
    <Grid.RowDefinitions>
      <RowDefinition Height="0.5*" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="0.5*" />
    </Grid.RowDefinitions>
    <Grid.ColumnDefinitions>
      <ColumnDefinition />
      <ColumnDefinition />
    </Grid.ColumnDefinitions>


    <Button Style="{StaticResource ButtonStyleAMOTNavigationUp}" Grid.Column="0" x:Name="buttonHourUp" Click="buttonHourUp_Click" Margin="4">
      <Button.Background>
        <SolidColorBrush Color="{StaticResource ColorAMOTButton}" />
      </Button.Background>
      <Button.Foreground>
        <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
      </Button.Foreground>
    </Button>
    <Button Style="{StaticResource ButtonStyleAMOTNavigationUp}" Grid.Column="1" x:Name="buttonMinuteUp" Click="buttonMinuteUp_Click" Margin="4">
      <Button.Background>
        <SolidColorBrush Color="{StaticResource ColorAMOTButton}" />
      </Button.Background>
      <Button.Foreground>
        <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
      </Button.Foreground>
    </Button>
    <TextBlock x:Name="Hour" Text="{Binding Path=ResourceStrings.XTSStringLabel00, Source={StaticResource LocalizedResources}}" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="{Binding IsEnabled, Converter={StaticResource XTSDisabledOpacityConverter}, ElementName=userControl}" Grid.Row="1" />
    <TextBlock Text="{Binding Path=ResourceStrings.XTSStringTimeSeparator, Source={StaticResource LocalizedResources}}" HorizontalAlignment="Center" VerticalAlignment="Center" Grid.ColumnSpan="2" Opacity="{Binding IsEnabled, Converter={StaticResource XTSDisabledOpacityConverter}, ElementName=userControl}" Grid.Row="1" />
    <TextBlock x:Name="Minute" Grid.Column="1" Text="{Binding Path=ResourceStrings.XTSStringLabel00, Source={StaticResource LocalizedResources}}" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="{Binding IsEnabled, Converter={StaticResource XTSDisabledOpacityConverter}, ElementName=userControl}" Grid.Row="1" />
    <Button Style="{StaticResource ButtonStyleAMOTNavigationDown}" Grid.Column="0" Grid.Row="2" x:Name="buttonHourDown" Click="buttonHourDown_Click" Margin="4">
      <Button.Background>
        <SolidColorBrush Color="{StaticResource ColorAMOTButton}" />
      </Button.Background>
      <Button.Foreground>
        <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
      </Button.Foreground>
    </Button>
    <Button Style="{StaticResource ButtonStyleAMOTNavigationDown}" Grid.Column="1" Grid.Row="2" x:Name="buttonMinuteDown" Click="buttonMinuteDown_Click" Margin="4">
      <Button.Background>
        <SolidColorBrush Color="{StaticResource ColorAMOTButton}" />
      </Button.Background>
      <Button.Foreground>
        <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
      </Button.Foreground>
    </Button>
  </Grid>
    
 
    
    
</UserControl>
