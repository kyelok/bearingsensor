<UserControl
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:sdk="http://schemas.microsoft.com/winfx/2006/xaml/presentation/sdk" x:Name="userControl"
    xmlns:local="clr-namespace:XTS.Controls"
	mc:Ignorable="d"
	x:Class="XTS.Controls.MainBearing"
	d:DesignWidth="70" d:DesignHeight="706" Height="706">

	<Grid x:Name="LayoutRoot" Background="{Binding Background, ElementName=userControl}">
		<Grid.RowDefinitions>
    	<RowDefinition Height="88"/>
    	<RowDefinition Height="100"/>
    	<RowDefinition/>
            <RowDefinition Height="22"/>            
        </Grid.RowDefinitions>
  	<Rectangle x:Name="EngineBlockCylinderEdgeLeft" HorizontalAlignment="Left" Grid.Row="1" Width="8" Margin="-0.5,-1,0,-0.5">
  		<Rectangle.Fill>
  			<SolidColorBrush Color="{StaticResource ColorAMOTEngineBlock}"/>
  		</Rectangle.Fill>
  	</Rectangle>
    <Path x:Name="EngineBlockCylinderEdgeLeftTop" Stretch="Fill" Data="F1 M 96,336L 96,480L 64,480L 32,480L 32,352L 48,352L 48,336L 96,336 Z " UseLayoutRounding="False" Width="10" Height="26.4" VerticalAlignment="Bottom" HorizontalAlignment="Left" RenderTransformOrigin="0.5,0.5" Margin="-0.5,0,0,0">
    	<Path.Fill>
    		<SolidColorBrush Color="{StaticResource ColorAMOTEngineBlock}"/>
    	</Path.Fill>
    	<Path.RenderTransform>
    		<CompositeTransform ScaleX="-1"/>
    	</Path.RenderTransform>
    </Path>
  	<Rectangle x:Name="EngineBlockCylinderEdgeRight" HorizontalAlignment="Right" Grid.Row="1" Width="8" Margin="0,-1,-0.5,-0.5">
  		<Rectangle.Fill>
  			<SolidColorBrush Color="{StaticResource ColorAMOTEngineBlock}"/>
  		</Rectangle.Fill>
  	</Rectangle>
    <Path x:Name="EngineBlockCylinderEdgeRightTop" Stretch="Fill" Data="F1 M 96,336L 96,480L 64,480L 32,480L 32,352L 48,352L 48,336L 96,336 Z " UseLayoutRounding="False" Width="10" Height="26.4" VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="0,0,-0.5,0">
    	<Path.Fill>
    		<SolidColorBrush Color="{StaticResource ColorAMOTEngineBlock}"/>
    	</Path.Fill>
    </Path>
  	<Rectangle x:Name="EngineBlockMid" Grid.Row="2" Grid.RowSpan="2" Fill="#FFA6B5BC" Margin="-0.5,0" d:IsHidden="True"/>
  	<Grid x:Name="EngineBlockRight" Grid.Row="2" Grid.RowSpan="2">
  		<Grid.RowDefinitions>
  			<RowDefinition Height="1*"/>
  			<RowDefinition Height="1*"/>
  		</Grid.RowDefinitions>
  		<Grid.ColumnDefinitions>
  			<ColumnDefinition />
  			<ColumnDefinition Width="16"/>
  		</Grid.ColumnDefinitions>
  		<Path Data="F1 M35,259 L0,259 L0,0" UseLayoutRounding="False" Grid.Column="1" Stretch="Fill" Margin="0.5,0,-1,-0.5">
  			<Path.Fill>
  				<SolidColorBrush Color="{StaticResource ColorAMOTEngineBlock}"/>
  			</Path.Fill>
  		</Path>
  		<Rectangle Grid.Row="1" Fill="#FFA6B5BC" Grid.ColumnSpan="2" Grid.RowSpan="2" Margin="-0.5,-0.5,-0.5,0"/>
  		<Rectangle Fill="#FFA6B5BC" Margin="-0.5,0,-0.5,-0.5"/>
  	</Grid>
  	<Grid x:Name="EngineBlockLeft" Grid.Row="2" Grid.RowSpan="2" d:IsHidden="True">
  		<Grid.RowDefinitions>
  			<RowDefinition Height="1*"/>
  			<RowDefinition Height="1*"/>
  		</Grid.RowDefinitions>
  		<Grid.ColumnDefinitions>
  			<ColumnDefinition Width="16"/>
  			<ColumnDefinition />
  		</Grid.ColumnDefinitions>
  		<Path Data="F1 M35,259 L0,259 L0,0" UseLayoutRounding="False" RenderTransformOrigin="0.5,0.5" Stretch="Fill" Margin="0,0,-0.5,-0.5">
  			<Path.RenderTransform>
  				<CompositeTransform ScaleX="-1"/>
  			</Path.RenderTransform>
  			<Path.Fill>
  				<SolidColorBrush Color="{StaticResource ColorAMOTEngineBlock}"/>
  			</Path.Fill>
  		</Path>
  		<Rectangle Grid.Row="1" Fill="#FFA6B5BC" Grid.ColumnSpan="2" Grid.RowSpan="2" Margin="-0.5,-0.5,-0.5,0"/>
  		<Rectangle Fill="#FFA6B5BC" Grid.Column="1" Margin="-0.5,0,-0.5,-0.5"/>
  	</Grid>
  	<Grid Grid.RowSpan="3">
  		<Rectangle Margin="0,0,0,107" StrokeThickness="0.5" Height="20" VerticalAlignment="Bottom">
  			<Rectangle.Fill>
  				<LinearGradientBrush EndPoint="0.5,0" StartPoint="0.5,1">
  					<GradientStop Color="#FF606060" />
  					<GradientStop Color="White" Offset="0.65" />
  				</LinearGradientBrush>
  			</Rectangle.Fill>
  		</Rectangle>
  		<Grid HorizontalAlignment="Center" Width="26" d:LayoutOverrides="GridBox">
  			<Rectangle Margin="2,0,2,96" Stroke="#FF888A85" StrokeThickness="0.5" Height="44" VerticalAlignment="Bottom">
  				<Rectangle.Fill>
  					<ImageBrush Stretch="None" ImageSource="/XTS;component/Resources/BrushedMetalBack.png" />
  				</Rectangle.Fill>
  			</Rectangle>
                <Grid>
                    <ToolTipService.ToolTip>
                        <ToolTip x:Name="ToolTipName" Content=""></ToolTip>
                    </ToolTipService.ToolTip> 
                    <Rectangle x:Name="Bearing" Height="40" VerticalAlignment="Bottom" Margin="4,0,4,98">
  				    <Rectangle.Fill>
  					    <SolidColorBrush Color="{StaticResource ColorAMOTSensorNormal}" />
  				    </Rectangle.Fill>
  			        </Rectangle>
                
                    <Rectangle Height="40" VerticalAlignment="Bottom" Margin="4,0,4,98" Opacity="0.35" Stroke="Black" />
                                   
                    <TextBlock x:Name="TextBlockBearing" Margin="0,0,0,60" TextWrapping="Wrap" Text="n" VerticalAlignment="Bottom" d:LayoutOverrides="Width" HorizontalAlignment="Center" TextAlignment="Center" FontWeight="Bold" FontSize="18"/>
                </Grid>
            </Grid>
        
  	</Grid>

    </Grid>
</UserControl>