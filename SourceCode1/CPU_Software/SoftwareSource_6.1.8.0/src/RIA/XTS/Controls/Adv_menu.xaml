      </Grid>
    </ControlTemplate>
  </UserControl.Resources>
  <UserControl.DataContext>
    <XTSGenII_ViewModels:NavBarViewModel />
  </UserControl.DataContext>
  <Grid x:Name="LayoutRoot">
    <StackPanel>
      <Button x:Name="BarGraph1" Content="{Binding Path=ResourceStrings.XTSStringButton, Source={StaticResource LocalizedResources}}" Height="48" Template="{StaticResource BarSensor}">
        <i:Interaction.Triggers>
          <i:EventTrigger EventName="Click">
            <ei:CallMethodAction TargetObject="{Binding Mode=OneWay}" MethodName="bargraph_clicked" />
          </i:EventTrigger>
        </i:Interaction.Triggers>
      </Button>
      <Button x:Name="Trend1" Content="{Binding Path=ResourceStrings.XTSStringButton, Source={StaticResource LocalizedResources}}" Template="{StaticResource Trend}" Height="49">
        <i:Interaction.Triggers>
          <i:EventTrigger EventName="Click">
            <ei:CallMethodAction TargetObject="{Binding Mode=OneWay}" MethodName="trends_clicked" />
          </i:EventTrigger>
        </i:Interaction.Triggers>
      </Button>
      <Button x:Name="Settings1" Content="{Binding Path=ResourceStrings.XTSStringButton, Source={StaticResource LocalizedResources}}" Template="{StaticResource BarCylindersTemplate}" Height="49">
        <i:Interaction.Triggers>
          <i:EventTrigger EventName="Click">
            <ei:CallMethodAction TargetObject="{Binding Mode=OneWay}" MethodName="settings_clicked" />
          </i:EventTrigger>
        </i:Interaction.Triggers>
      </Button>
      <Button x:Name="Advanced1" Content="{Binding Path=ResourceStrings.XTSStringButton, Source={StaticResource LocalizedResources}}" Template="{StaticResource Advanced}" Height="48">
