<UserControl
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:sdk="http://schemas.microsoft.com/winfx/2006/xaml/presentation/sdk"
	xmlns:XTS_ViewModels="clr-namespace:XTS.ViewModels" xmlns:i="http://schemas.microsoft.com/expression/2010/interactivity" xmlns:ei="http://schemas.microsoft.com/expression/2010/interactions"
	mc:Ignorable="d"
	x:Class="XTS.Controls.TopBar" d:DesignWidth="1024" d:DesignHeight="52" Loaded="TopBar_Loaded" Unloaded="TopBar_Unloaded">

  <UserControl.DataContext>
    <XTS_ViewModels:NavBarViewModel />
  </UserControl.DataContext>
  <Grid x:Name="LayoutRoot">
    <Grid.Background>
      <SolidColorBrush Color="{StaticResource ColorAMOTBackgroundOverlay}" />
    </Grid.Background>
    <TextBlock x:Name="LabelMessage" FontSize="13.333" Margin="100,3,163,0" d:LayoutOverrides="HorizontalAlignment" VerticalAlignment="Top" Text="{Binding Path=ResourceStrings.XTSStringStatusDefault, Source={StaticResource LocalizedResources}}" FontWeight="Bold" TextTrimming="WordEllipsis">
      <TextBlock.Foreground>
        <SolidColorBrush Color="{StaticResource ColorAMOTAlert}" />
      </TextBlock.Foreground>
    </TextBlock>
    <sdk:Label x:Name="LabelScreenDescription" Height="22" VerticalAlignment="Bottom" Content="{Binding Path=ResourceStrings.XTSStringDescription, Source={StaticResource LocalizedResources}}" Margin="100,0,163,5" BorderThickness="0" d:LayoutOverrides="HorizontalAlignment" FontWeight="Bold" FontSize="16" Padding="4,0,0,0">
      <sdk:Label.Foreground>
        <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
      </sdk:Label.Foreground>
      <sdk:Label.Background>
        <SolidColorBrush Color="{StaticResource ColorAMOTBlue}" />
      </sdk:Label.Background>
    </sdk:Label>
    <Image Source="/XTS;component/Resources/logo_amot.png" HorizontalAlignment="Right" Margin="0,0,8,0" />

  </Grid>
</UserControl>