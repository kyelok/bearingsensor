<UserControl
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:sdk="http://schemas.microsoft.com/winfx/2006/xaml/presentation/sdk" x:Name="userControl"
	mc:Ignorable="d"
	x:Class="XTS.Controls.PeakGauge"
	d:DesignWidth="150" d:DesignHeight="444" LayoutUpdated="OnLayoutUpdated" Background="White">

  <Grid x:Name="LayoutRoot">
    <Grid.RowDefinitions>
      <RowDefinition Height="22" />
      <RowDefinition Height="*" />
      <RowDefinition Height="4" />
      <RowDefinition Height="22" />
      <RowDefinition Height="8" />
      <RowDefinition Height="44" />
    </Grid.RowDefinitions>
    <sdk:Label x:Name="LabelTitle" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{Binding Foreground, ElementName=userControl}" FontWeight="Bold" />
    <Border x:Name="BorderValue" BorderBrush="Black" BorderThickness="1" Margin="2,0" Grid.Row="3" MaxWidth="44">
      <Border.Background>
        <SolidColorBrush Color="{StaticResource ColorAMOTPopUpBG}" />
      </Border.Background>
      <sdk:Label x:Name="LabelValue" VerticalAlignment="Center" HorizontalContentAlignment="Center" FontWeight="Bold">
        <sdk:Label.Foreground>
          <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
        </sdk:Label.Foreground>
      </sdk:Label>
    </Border>
    <Button x:Name="ButtonPeak" Margin="2,0" Grid.Row="6" Style="{StaticResource ButtonStyleAMOT}" Click="buttonPeak_Clicked" MaxWidth="44">
      <Button.Background>
        <SolidColorBrush Color="{StaticResource ColorAMOTButton}" />
      </Button.Background>
      <Button.Foreground>
        <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
      </Button.Foreground>
      <Grid>
        <Path Stretch="Fill" Fill="{Binding Foreground, ElementName=ButtonPeak}" Data="F1 M 24,13C 27.1521,13 29.9945,14.3258 32,16.4501L 32,11L 35,14L 35,22L 27,22L 24,19L 29.5903,19C 28.217,17.4656 26.2212,16.5 24,16.5C 20.1969,16.5 17.055,19.3306 16.5661,23L 13.0448,23C 13.5501,17.3935 18.262,13 24,13 Z M 24,31.5C 27.8031,31.5 30.945,28.6694 31.4339,25L 34.9552,25C 34.4499,30.6065 29.738,35 24,35C 20.8479,35 18.0055,33.6742 16,31.5499L 16,37L 13,34L 13,26L 21,26L 24,29L 18.4097,29C 19.783,30.5344 21.7787,31.5 24,31.5 Z " HorizontalAlignment="Center" Height="35" UseLayoutRounding="False" VerticalAlignment="Center" Width="28" Opacity="0.15" />
        <TextBlock TextWrapping="Wrap" Text="{Binding Path=ResourceStrings.XTSStringReset, Source={StaticResource LocalizedResources}}" d:LayoutOverrides="Width, Height" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="2,0,0,0" FontWeight="Normal" Visibility="Collapsed" />
        <TextBlock x:Name="TextBlockPeak" TextWrapping="Wrap" d:LayoutOverrides="Width, Height" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Margin="0" />
      </Grid>
    </Button>
    <Grid x:Name="GridGauge" Margin="0" Grid.Row="1">
      <Rectangle x:Name="RectOK" Height="136" Margin="0,183,0,0" VerticalAlignment="Top" >
      	<Rectangle.Fill>
      		<SolidColorBrush Color="{StaticResource ColorAMOTSensorAlarm}"/>
      	</Rectangle.Fill>
      </Rectangle>
      <Rectangle x:Name="RectIdeal" Height="39" Margin="0,233,0,0" VerticalAlignment="Top" >
      	<Rectangle.Fill>
      		<SolidColorBrush Color="{StaticResource ColorAMOTSensorNormal}"/>
      	</Rectangle.Fill>
      </Rectangle>
      <Rectangle Margin="8,0" Fill="{Binding Background, ElementName=userControl}">
        <Rectangle.Stroke>
          <SolidColorBrush Color="{StaticResource ColorAMOTDarkGrey}" />
        </Rectangle.Stroke>
      </Rectangle>
      <Rectangle x:Name="RectPeak" Height="300" Margin="8,0" VerticalAlignment="Top" Opacity="0.4">
        <Rectangle.Fill>
          <SolidColorBrush Color="{StaticResource ColorAMOTSensorNormal}" />
        </Rectangle.Fill>
        <Rectangle.Stroke>
          <SolidColorBrush Color="{StaticResource ColorAMOTDarkGrey}" />
        </Rectangle.Stroke>
      </Rectangle>
      <Rectangle x:Name="RectValue" Height="136" Margin="8,0" VerticalAlignment="Top">
        <Rectangle.Fill>
          <SolidColorBrush Color="{StaticResource ColorAMOTSensorNormal}" />
        </Rectangle.Fill>
        <Rectangle.Stroke>
          <SolidColorBrush Color="{StaticResource ColorAMOTDarkGrey}" />
        </Rectangle.Stroke>
      </Rectangle>
    </Grid>
  </Grid>
</UserControl>