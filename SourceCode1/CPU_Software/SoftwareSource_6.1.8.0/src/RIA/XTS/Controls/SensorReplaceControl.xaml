<UserControl
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:sdk="http://schemas.microsoft.com/winfx/2006/xaml/presentation/sdk"
	mc:Ignorable="d"
	x:Class="XTS.Controls.SensorReplaceControl"
	d:DesignWidth="640" d:DesignHeight="480" Height="52" LayoutUpdated="OnLayoutUpdated">

  <Grid x:Name="LayoutRoot">
    <Grid.Background>
      <SolidColorBrush Color="{StaticResource ColorAMOTBackgroundOverlay}" />
    </Grid.Background>
    <sdk:Label x:Name="LabelTitle" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="2,0,0,0" Foreground="Black" FontWeight="Bold" />
    <Button x:Name="buttonReplace" Width="88" HorizontalAlignment="Right" Margin="0,4,188,4" Style="{StaticResource ButtonStyleAMOT}" Height="44" IsEnabled="False" Click="buttonReplace_Click">
      <Button.Background>
        <SolidColorBrush Color="{StaticResource ColorAMOTButton}" />
      </Button.Background>
      <Button.Foreground>
        <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
      </Button.Foreground>
      <Grid>
        <TextBlock x:Name="buttonReplaceText" Margin="2,0,0,0" TextWrapping="Wrap" Text="{Binding Path=ResourceStrings.XTSStringReplace, Source={StaticResource LocalizedResources}}" VerticalAlignment="Bottom" HorizontalAlignment="Left" />
        <Path Stretch="Fill" Fill="{Binding Foreground, ElementName=buttonReplace}" Data="F1 M 14,16L 30.75,16L 25,11L 31.5,11L 39,18L 31.5,25L 25,25L 30.75,20L 14,20L 14,16 Z M 34,28L 34,32L 17.25,32L 23,37L 16.5,37L 9,30L 16.5,23L 23,23L 17.25,28L 34,28 Z " HorizontalAlignment="Left" UseLayoutRounding="False" Width="25" VerticalAlignment="Top" Height="21" Margin="4,4,0,0" />
      </Grid>
    </Button>
    <Button x:Name="buttonSend" Width="88" HorizontalAlignment="Right" Margin="0,4,96,4" Style="{StaticResource ButtonStyleAMOT}" Height="44" IsEnabled="False" Click="buttonSend_Click">
      <Button.Background>
        <SolidColorBrush Color="{StaticResource ColorAMOTButton}" />
      </Button.Background>
      <Button.Foreground>
        <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
      </Button.Foreground>
      <Grid>
        <TextBlock Margin="2,0,0,0" TextWrapping="Wrap" Text="{Binding Path=ResourceStrings.XTSStringSend, Source={StaticResource LocalizedResources}}" VerticalAlignment="Bottom" HorizontalAlignment="Left" />
        <Path Stretch="Fill" Fill="{Binding Foreground, ElementName=buttonSend}" Data="F1 M 19.0027,22.0036L 28.0039,22.0031L 23.0032,18.0025L 30.0042,18.0025L 37.0052,24.0033L 30.0042,30.0042L 23.0032,30.0042L 28.0039,26.0036L 19.0027,26.0036L 19.0027,22.0036 Z M 32.0045,12.0017L 32.0045,17.0024L 30.0042,17.0024L 30.0042,14.002L 16.0022,14.002L 16.0022,34.0047L 30.0042,34.0047L 30.0042,31.0043L 32.0045,31.0043L 32.0045,36.005L 14.0019,36.005L 14.0019,12.0017L 32.0045,12.0017 Z " HorizontalAlignment="Left" Margin="4,4,0,0" UseLayoutRounding="False" Width="20" VerticalAlignment="Top" Height="20" />
      </Grid>
    </Button>
    <Button x:Name="buttonImport" Width="88" HorizontalAlignment="Right" Margin="0,4,4,4" Style="{StaticResource ButtonStyleAMOT}" Height="44" IsEnabled="False" Click="buttonImport_Click">
      <Button.Background>
        <SolidColorBrush Color="{StaticResource ColorAMOTButton}" />
      </Button.Background>
      <Button.Foreground>
        <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
      </Button.Foreground>
      <Grid>
        <TextBlock Margin="2,0,0,0" TextWrapping="Wrap" Text="{Binding Path=ResourceStrings.XTSStringImport, Source={StaticResource LocalizedResources}}" VerticalAlignment="Bottom" HorizontalAlignment="Left" />
        <Path Stretch="Fill" Fill="{Binding Foreground, ElementName=buttonImport}" Data="F1 M 16.0021,12.0017L 34.0046,12.0017L 34.0046,36.005L 16.0021,36.005L 16.0021,31.0043L 18.0024,31.0043L 18.0024,34.0047L 32.0043,34.0047L 32.0043,14.002L 18.0024,14.002L 18.0024,17.0024L 16.0021,17.0024L 16.0021,12.0017 Z M 12.0017,22.0031L 21.0029,22.0031L 16.0022,18.0025L 23.0032,18.0025L 30.0042,24.0034L 23.0032,30.0042L 16.0022,30.0042L 21.0029,26.0036L 12.0017,26.0036L 12.0017,22.0031 Z " HorizontalAlignment="Left" UseLayoutRounding="False" Width="20" VerticalAlignment="Top" Height="20" Margin="4,4,0,0" />
      </Grid>
    </Button>
    <Grid HorizontalAlignment="Left" Width="88" Margin="32,4,0,4">
      <Grid.Background>
        <SolidColorBrush Color="{StaticResource ColorAMOTBlue}" />
      </Grid.Background>
      <sdk:Label x:Name="LabelFailure" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0" FontSize="9.333">
    		<sdk:Label.Foreground>
    			<SolidColorBrush Color="{StaticResource ColorAMOTText}" />
    		</sdk:Label.Foreground>
    	</sdk:Label>
      <sdk:Label HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="2,0,0,0" Content="{Binding ResourceStrings.XTSStringFailure, Source={StaticResource LocalizedResources}}">
        <sdk:Label.Foreground>
          <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
        </sdk:Label.Foreground>
      </sdk:Label>
    </Grid>
    <Grid HorizontalAlignment="Left" Width="88" Margin="124,4,0,4">
      <Grid.Background>
        <SolidColorBrush Color="{StaticResource ColorAMOTBlue}" />
      </Grid.Background>
      <sdk:Label x:Name="LabelReplaced" VerticalAlignment="Center" Margin="0" FontSize="9.333" HorizontalAlignment="Center">
    		<sdk:Label.Foreground>
    			<SolidColorBrush Color="{StaticResource ColorAMOTText}" />
    		</sdk:Label.Foreground>
    	</sdk:Label>
      <sdk:Label HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="2,0,0,0" Content="{Binding ResourceStrings.XTSStringReplaced, Source={StaticResource LocalizedResources}}">
        <sdk:Label.Foreground>
          <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
        </sdk:Label.Foreground>
      </sdk:Label>
    </Grid>
    <Grid x:Name="GridProgress" Margin="216,4,372,4">
      <Grid.Background>
        <SolidColorBrush Color="{StaticResource ColorAMOTBlue}" />
      </Grid.Background>
      <sdk:Label x:Name="LabelProgress" VerticalAlignment="Center" Margin="0" FontSize="14.667" HorizontalAlignment="Center">
        <sdk:Label.Foreground>
          <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
        </sdk:Label.Foreground>
      </sdk:Label>
      <Rectangle Height="8" VerticalAlignment="Top" Margin="0">
        <Rectangle.Fill>
          <SolidColorBrush Color="{StaticResource ColorAMOTDarkGrey}" />
        </Rectangle.Fill>
      </Rectangle>
      <Rectangle x:Name="RectProgress" Height="8" VerticalAlignment="Top" Margin="0" HorizontalAlignment="Left">
        <Rectangle.Fill>
          <SolidColorBrush Color="{StaticResource ColorAMOTSensorNormal}" />
        </Rectangle.Fill>
      </Rectangle>
      <Rectangle Stroke="Black" Height="8" VerticalAlignment="Top" Opacity="0.5" Margin="0" />
      <sdk:Label HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="2,0,0,0" Content="{Binding Path=ResourceStrings.XTSStringProgress, Source={StaticResource LocalizedResources}}">
        <sdk:Label.Foreground>
          <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
        </sdk:Label.Foreground>
      </sdk:Label>
    </Grid>
    <Grid HorizontalAlignment="Right" Width="88" Margin="0,4,280,4">
      <Grid.Background>
        <SolidColorBrush Color="{StaticResource ColorAMOTBlue}" />
      </Grid.Background>
      <sdk:Label x:Name="LabelStage" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0" FontSize="12">
        <sdk:Label.Foreground>
          <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
        </sdk:Label.Foreground>
      </sdk:Label>
      <sdk:Label HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="2,0,0,0" Content="{Binding Path=ResourceStrings.XTSStringStage, Source={StaticResource LocalizedResources}}">
        <sdk:Label.Foreground>
          <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
        </sdk:Label.Foreground>
      </sdk:Label>
    </Grid>
  </Grid>
</UserControl>