<UserControl
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	mc:Ignorable="d"
	x:Class="XTS.Controls.TrendReorder" Loaded="TrendReorder_Loaded" Unloaded="TrendReorder_Unloaded">

	<Grid x:Name="LayoutRoot" Height="38" Width="80">
		<Button x:Name="buttonUp" Style="{StaticResource ButtonStyleAMOT}" HorizontalAlignment="Left" Margin="0,4" Width="32" Click="buttonUp_Click">
			<Button.Foreground>
				<SolidColorBrush Color="{StaticResource ColorAMOTText}"/>
			</Button.Foreground>
			<Button.Background>
				<SolidColorBrush Color="{StaticResource ColorAMOTButton}"/>
			</Button.Background>
			<Path x:Name="path" Height="16" Stretch="Fill" Data="F1 M 23.9063,22.5L 21.9063,24.5L 14.9063,31.75L 14.9063,25.25L 23.9063,15.75L 32.9063,25.25L 32.9063,31.75L 25.9063,24.5L 23.9063,22.5 Z " UseLayoutRounding="False" Width="18" HorizontalAlignment="Center" Margin="0" VerticalAlignment="Center" d:LayoutOverrides="Width">
				<Path.Fill>
					<SolidColorBrush Color="{StaticResource ColorAMOTText}"/>
				</Path.Fill>
			</Path>
		</Button>
		<Button x:Name="buttonDown" Style="{StaticResource ButtonStyleAMOT}" HorizontalAlignment="Right" Margin="0,4,8,4" Width="32" Click="buttonDown_Click">
			<Button.Foreground>
				<SolidColorBrush Color="{StaticResource ColorAMOTText}"/>
			</Button.Foreground>
			<Button.Background>
				<SolidColorBrush Color="{StaticResource ColorAMOTButton}"/>
			</Button.Background>
			<Path x:Name="path_Copy" Width="18" Height="16" Stretch="Fill" Data="F1 M 23.9063,22.5L 21.9063,24.5L 14.9063,31.75L 14.9063,25.25L 23.9063,15.75L 32.9063,25.25L 32.9063,31.75L 25.9063,24.5L 23.9063,22.5 Z " HorizontalAlignment="Center" VerticalAlignment="Center" UseLayoutRounding="False" RenderTransformOrigin="0.5,0.5">
				<Path.RenderTransform>
					<CompositeTransform Rotation="180"/>
				</Path.RenderTransform>
				<Path.Fill>
					<SolidColorBrush Color="{StaticResource ColorAMOTText}"/>
				</Path.Fill>
			</Path>
		</Button>
	</Grid>
</UserControl>