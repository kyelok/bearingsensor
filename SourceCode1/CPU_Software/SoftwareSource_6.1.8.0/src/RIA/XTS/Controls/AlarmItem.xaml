<UserControl
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:XTS.Controls"
    xmlns:sdk="http://schemas.microsoft.com/winfx/2006/xaml/presentation/sdk" x:Name="userControl" x:Class="XTS.Controls.AlarmItem"
    mc:Ignorable="d"
    d:DesignHeight="16" d:DesignWidth="700" Loaded="AlarmItem_Loaded" Unloaded="AlarmItem_Unloaded" FontSize="13">
	<UserControl.Background>
		<SolidColorBrush Color="{StaticResource ColorAMOTError}"/>
	</UserControl.Background>
    
    <Grid x:Name="LayoutRoot" Background="{Binding Background, ElementName=userControl}" Height="14" VerticalAlignment="Center" Margin="0,1">
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="4*" />
			<ColumnDefinition Width="10*" />
			<ColumnDefinition Width="4*" />
			<ColumnDefinition Width="*" />
		</Grid.ColumnDefinitions>
                    
		<TextBlock Grid.Column="0" x:Name="AlarmTimeString"  HorizontalAlignment="Stretch" Margin="1" Foreground="{Binding Foreground, ElementName=userControl}" VerticalAlignment="Center"/>
		<TextBlock Grid.Column="1" x:Name="AlarmMessage"  
			VerticalAlignment="Center" HorizontalAlignment="Stretch" Foreground="{Binding Foreground, ElementName=userControl}" Margin="1"/>

		<TextBlock Grid.Column="2" x:Name="AckTimeStamp"  
			VerticalAlignment="Center"  HorizontalAlignment="Stretch" Foreground="{Binding Foreground, ElementName=userControl}" Margin="1"/>

		<TextBlock Grid.Column="3" x:Name="AckUserID"
			VerticalAlignment="Center" Margin="1" HorizontalAlignment="Stretch" Foreground="{Binding Foreground, ElementName=userControl}"/>

	</Grid>
</UserControl>
