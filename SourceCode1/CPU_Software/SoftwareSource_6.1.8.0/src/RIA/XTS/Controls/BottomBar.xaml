<UserControl
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:sdk="http://schemas.microsoft.com/winfx/2006/xaml/presentation/sdk"
	xmlns:local="clr-namespace:XTS.Controls"
	xmlns:ed="http://schemas.microsoft.com/expression/2010/drawing" x:Class="XTS.Controls.BottomBar"
    mc:Ignorable="d"
    d:DesignHeight="52" d:DesignWidth="1024" Width="Auto" Height="Auto" Loaded="BottomBar_Loaded" Unloaded="BottomBar_Unloaded">
	<Grid x:Name="LayoutRoot">
		<local:UserLogInControl x:Name="UserLogIn" HorizontalAlignment="Left" Width="184" />
		<local:RPM x:Name="RPM" HorizontalAlignment="Left" Margin="188,0,0,0" Width="44" Height="44" FontSize="14.667" FontWeight="Bold" />
		<Button x:Name="ButtonScreenCapture" HorizontalAlignment="Right" Margin="0,0,204,0" Width="44" Height="44" Style="{StaticResource ButtonStyleAMOT}" FontSize="9.333" Click="ButtonScreenCapture_Click">
			<Button.Background>
				<SolidColorBrush Color="{StaticResource ColorAMOTButton}" />
			</Button.Background>
			<Button.Foreground>
				<SolidColorBrush Color="{StaticResource ColorAMOTText}" />
			</Button.Foreground>
			<Grid>
				<Path Stretch="Fill"
					Data="F1 M 33,17C 34.1046,17 35,17.8954 35,19L 35,30C 35,31.1046 34.1046,32 33,32L 15,32C 13.8954,32 13,31.1046 13,30L 13,19C 13,17.8954 13.8954,17 15,17L 19,17C 19,15.3432 20.3431,14 22,14L 26,14C 27.6569,14 29,15.3432 29,17L 33,17 Z M 24,21C 21.7908,21 20,22.7909 20,25C 20,27.2091 21.7908,29 24,29C 26.2091,29 28,27.2091 28,25C 28,22.7909 26.2091,21 24,21 Z M 24,22C 25.6568,22 27,23.3432 27,25C 27,26.6569 25.6568,28 24,28C 22.3431,28 21,26.6569 21,25C 21,23.3432 22.3431,22 24,22 Z M 17,21L 17,19.25L 15.25,19.25L 15.25,21L 17,21 Z " Margin="6,8,8,14" UseLayoutRounding="False" Fill="{Binding Foreground, ElementName=ButtonScreenCapture}"/>
        <TextBlock Text="{Binding Path=ResourceStrings.XTSStringCapture, Source={StaticResource LocalizedResources}}" HorizontalAlignment="Left" VerticalAlignment="Bottom" FontSize="8" Margin="2,0,0,0" />
			</Grid>
		</Button>
		<Button x:Name="ButtonHelp" HorizontalAlignment="Right" Margin="0,0,156,0" Width="44" Height="44" Style="{StaticResource ButtonStyleAMOT}" FontSize="9.333" Click="buttonHelp_Click">
			<Button.Background>
				<SolidColorBrush Color="{StaticResource ColorAMOTButton}" />
			</Button.Background>
			<Button.Foreground>
				<SolidColorBrush Color="{StaticResource ColorAMOTText}" />
			</Button.Foreground>
			<!--Content="Help" -->
      <Button.Content>
			<Grid>
          <TextBlock Text="{Binding Path=ResourceStrings.XTSStringQuestionMarkChar, Source={StaticResource LocalizedResources}}" FontSize="32" Margin="0,0,0,6" FontWeight="Bold" HorizontalAlignment="Center" Height="40" VerticalAlignment="Center" />
          <TextBlock Text="{Binding Path=ResourceStrings.XTSStringHelp, Source={StaticResource LocalizedResources}}" HorizontalAlignment="Left" VerticalAlignment="Bottom" FontSize="8" Margin="2,0,0,0" d:LayoutOverrides="HorizontalAlignment" />
			</Grid>
      </Button.Content>
		</Button>
	
		<Button x:Name="ButtonSensorKey" HorizontalAlignment="Right" Margin="0,0,252,0" Width="44" Height="44" Style="{StaticResource ButtonStyleAMOT}" FontSize="9.333" Click="ButtonSensorKey_Click">
			<Button.Background>
				<SolidColorBrush Color="{StaticResource ColorAMOTButton}" />
			</Button.Background>
			<Button.Foreground>
				<SolidColorBrush Color="{StaticResource ColorAMOTText}" />
			</Button.Foreground>
			<!--Content="Help" -->
			<Grid>
				<TextBlock Text="{Binding ResourceStrings.XTSStringKey, Source={StaticResource LocalizedResources}}" HorizontalAlignment="Left" VerticalAlignment="Bottom" FontSize="8" Margin="2,0,0,0" Width="39" Height="12" ></TextBlock>
				<ed:Arc ArcThickness="3" ArcThicknessUnit="Pixel" EndAngle="360" Margin="0,13.25,6.5,18" Stretch="None" StartAngle="0" UseLayoutRounding="False" RenderTransformOrigin="0.545,0.245" HorizontalAlignment="Right" Width="13.5">
					<ed:Arc.Fill>
						<SolidColorBrush Color="{StaticResource ColorAMOTText}"/>
					</ed:Arc.Fill>
				</ed:Arc>
				<Rectangle Margin="8,17,18,0" Height="5" VerticalAlignment="Top">
					<Rectangle.Fill>
						<SolidColorBrush Color="{StaticResource ColorAMOTText}"/>
					</Rectangle.Fill>
				</Rectangle>
				<ed:RegularPolygon HorizontalAlignment="Left" InnerRadius="1" Margin="10.75,14,0,0" PointCount="3" Stretch="Fill" UseLayoutRounding="False" Width="3" Height="4" VerticalAlignment="Top">
					<ed:RegularPolygon.Fill>
						<SolidColorBrush Color="{StaticResource ColorAMOTText}"/>
					</ed:RegularPolygon.Fill>
				</ed:RegularPolygon>
				<ed:RegularPolygon HorizontalAlignment="Left" InnerRadius="1" Margin="17,13.25,0,0" PointCount="3" Stretch="Fill" UseLayoutRounding="False" Width="3" Height="4" VerticalAlignment="Top">
					<ed:RegularPolygon.Fill>
						<SolidColorBrush Color="{StaticResource ColorAMOTText}"/>
					</ed:RegularPolygon.Fill>
				</ed:RegularPolygon>
				<ed:RegularPolygon HorizontalAlignment="Left" Height="5" InnerRadius="1" Margin="5.75,17,0,0" PointCount="5" Stretch="Fill" UseLayoutRounding="False" VerticalAlignment="Top" Width="4">
					<ed:RegularPolygon.Fill>
						<SolidColorBrush Color="{StaticResource ColorAMOTText}"/>
					</ed:RegularPolygon.Fill>
				</ed:RegularPolygon>
			</Grid>
		</Button>

        <Button x:Name="ButtonCloseWindowRia" HorizontalAlignment="Right" Margin="0,0,108,0" Width="44" Height="44" Style="{StaticResource ButtonStyleAMOT}" FontSize="9.333" Click="ButtonCloseWindowRia_Click">
            <Button.Background>
                <SolidColorBrush Color="{StaticResource ColorAMOTButton}" />
            </Button.Background>
            <Button.Foreground>
                <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
            </Button.Foreground>
            <!--Content="Help" -->
            <Button.Content>
                <Grid>
                    <TextBlock Text="{Binding Path=ResourceStrings.XTSStringCloseWindow, Source={StaticResource LocalizedResources}}" FontSize="32" Margin="0,0,0,16" FontWeight="Bold" HorizontalAlignment="Center" Height="40" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding Path=ResourceStrings.XTSStringClose, Source={StaticResource LocalizedResources}}" HorizontalAlignment="Left" VerticalAlignment="Bottom" FontSize="8" Margin="2,0,0,0" d:LayoutOverrides="HorizontalAlignment" />
                </Grid>
            </Button.Content>
        </Button>
        
        <local:SPUDateTimeControl x:Name="SPUDateTime" HorizontalAlignment="Right" d:LayoutOverrides="Width" />
	</Grid>
</UserControl>
