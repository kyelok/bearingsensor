<UserControl
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:sdk="http://schemas.microsoft.com/winfx/2006/xaml/presentation/sdk"
	mc:Ignorable="d"
	x:Class="XTS.Controls.Scale"
	d:DesignWidth="269" d:DesignHeight="480" SizeChanged="OnSizeChanged">

  <Grid x:Name="LayoutRoot">
    <Grid.RowDefinitions>
      <RowDefinition Height="14" />
      <RowDefinition Height="3" />
      <RowDefinition />
      <RowDefinition Height="3" />
      <RowDefinition Height="28" />
    </Grid.RowDefinitions>
    <Grid x:Name="GridScale" Grid.Row="2" />
    <Path x:Name="PathBar" Data="M0,100 L0,0" Fill="Black" HorizontalAlignment="Left" Grid.Row="2" Stretch="Fill" Stroke="Black" UseLayoutRounding="False" Width="1" StrokeStartLineCap="Square" StrokeEndLineCap="Square" />
    <sdk:Label x:Name="LabelLegend" Content="{Binding ResourceStrings.XTSStringLegend, Source={StaticResource LocalizedResources}}" FontSize="16" RenderTransformOrigin="0.5,0.5" HorizontalContentAlignment="Center" Foreground="Black" FontStyle="Italic" Grid.RowSpan="5" UseLayoutRounding="False" d:LayoutRounding="Auto" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="-200,0" >
    	<sdk:Label.RenderTransform>
    		<CompositeTransform Rotation="270"/>
    	</sdk:Label.RenderTransform>
    </sdk:Label>
  </Grid>
</UserControl>