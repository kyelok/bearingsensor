<UserControl
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" x:Name="userControl"
	mc:Ignorable="d"
	x:Class="XTS.Controls.ContentScroll"
	d:DesignWidth="640" d:DesignHeight="480">

	<ScrollViewer x:Name="LayoutRoot" Background="{Binding Background, ElementName=userControl}" Style="{StaticResource ScrollViewerStyleAMOT}">
		<StackPanel x:Name="stackPanelContent" MouseLeftButtonDown="stackPanelContent_MouseLeftButtonDown" MouseMove="stackPanelContent_MouseMove" MouseLeftButtonUp="stackPanelContent_MouseLeftButtonUp" MouseLeave="stackPanelContent_MouseLeave"/>
	</ScrollViewer>
</UserControl>