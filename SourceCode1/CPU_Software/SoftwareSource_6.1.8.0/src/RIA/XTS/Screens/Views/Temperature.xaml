<UserControl
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:local="clr-namespace:XTS"
	xmlns:xtscontrols="clr-namespace:XTS.Controls"
	xmlns:telerik="http://schemas.telerik.com/2008/xaml/presentation"
	xmlns:sdk="http://schemas.microsoft.com/winfx/2006/xaml/presentation/sdk"
	mc:Ignorable="d"
	x:Class="XTS.Temperature"
	d:DesignWidth="1024" d:DesignHeight="546" Width="Auto" Height="Auto" Loaded="BarGraph_Loaded" Unloaded="BarGraph_Unloaded">
  <UserControl.Resources>
    <local:BarGraphModel x:Key="TemperatureModelDataSource" />
  </UserControl.Resources>

    <Grid x:Name="LayoutRoot" DataContext="{Binding Source={StaticResource TemperatureModelDataSource}}">
    <Grid.RowDefinitions>
      <RowDefinition Height="1*" />
      <RowDefinition Height="2*" />
    </Grid.RowDefinitions>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="62" />
      <ColumnDefinition />
      <ColumnDefinition Width="62" />
    </Grid.ColumnDefinitions>
    <xtscontrols:FitStackPanel x:Name="PanelDeviation" Margin="4,4,4,2" Padding="2" Grid.Column="1">
      <xtscontrols:FitStackPanel.Background>
        <SolidColorBrush Color="{StaticResource ColorAMOTGlassEffect}" />
      </xtscontrols:FitStackPanel.Background>
    </xtscontrols:FitStackPanel>

    <xtscontrols:FitStackPanel x:Name="PanelTemperature" Margin="4,2,4,4" Padding="2" Grid.Row="1" Grid.Column="1">
      <xtscontrols:FitStackPanel.Background>
        <SolidColorBrush Color="{StaticResource ColorAMOTGlassEffect}" />
      </xtscontrols:FitStackPanel.Background>
    </xtscontrols:FitStackPanel>
    <xtscontrols:Scale x:Name="ScaleDeviation" Margin="0,6,0,4" RenderTransformOrigin="0.5,0.5">
      <xtscontrols:Scale.RenderTransform>
        <CompositeTransform />
      </xtscontrols:Scale.RenderTransform>
    </xtscontrols:Scale>
    <xtscontrols:Scale x:Name="ScaleTemperature" Margin="0,4,0,6" Grid.Row="1" RenderTransformOrigin="0.5,0.5">
      <xtscontrols:Scale.RenderTransform>
        <CompositeTransform />
      </xtscontrols:Scale.RenderTransform>
    </xtscontrols:Scale>
    <RadioButton x:Name="buttonPageTwo" Content="{Binding Path=ResourceStrings.XTSStringPageTwo, Source={StaticResource LocalizedResources}}" VerticalAlignment="Top" Style="{StaticResource ToggleButtonStyleAMOT}" GroupName="CylinderOrSensor" Width="44" Height="44" HorizontalAlignment="Center" Grid.Column="3" Margin="0,56,0,0" Checked="buttonSensors_Checked" ContentTemplate="{StaticResource ContentTemplateAMOTButton}" FontSize="8">
      <RadioButton.Foreground>
        <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
      </RadioButton.Foreground>
      <RadioButton.Background>
        <SolidColorBrush Color="{StaticResource ColorAMOTButton}" />
      </RadioButton.Background>
    </RadioButton>
    <RadioButton x:Name="buttonPageOne" Content="{Binding Path=ResourceStrings.XTSStringPageOne, Source={StaticResource LocalizedResources}}" VerticalAlignment="Top" Style="{StaticResource ToggleButtonStyleAMOT}" GroupName="CylinderOrSensor" Width="44" Height="44" HorizontalAlignment="Center" Grid.Column="3" Margin="0,8,0,0" Checked="buttonCylinders_Checked" ContentTemplate="{StaticResource ContentTemplateAMOTButton}" FontSize="8">
      <RadioButton.Foreground>
        <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
      </RadioButton.Foreground>
      <RadioButton.Background>
        <SolidColorBrush Color="{StaticResource ColorAMOTButton}" />
      </RadioButton.Background>
    </RadioButton>
        <Button x:Name="buttonSetting" Margin="9,0,0,32"  Grid.Row="2" Grid.Column="2" Height="44" VerticalAlignment="Top" Style="{StaticResource ButtonStyleAMOT}" Width="44" HorizontalAlignment="Left" Click="buttonSettings_clicked">
            <Button.Background>
                <SolidColorBrush Color="{StaticResource ColorAMOTButton}" />
            </Button.Background>
            <Button.Foreground>
                <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
            </Button.Foreground>
            <Grid>
                <TextBlock Margin="2,0,0,0" TextWrapping="Wrap" Text="{Binding ResourceStrings.XTSStringSettings, Source={StaticResource LocalizedResources}}" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="9"/>
                <Path Stretch="Fill" Fill="{Binding Foreground, ElementName=buttonTrendsConfigSelect}" Data="F1 M 36.5937,39.25L 36.5937,32.25L 43.5937,32.25L 43.5937,39.25L 36.5937,39.25 Z M 28.5937,39.25L 28.5937,32.25L 35.5937,32.25L 35.5937,39.25L 28.5937,39.25 Z M 20.5937,39.25L 20.5937,32.25L 27.5937,32.25L 27.5937,39.25L 20.5937,39.25 Z M 20.5937,31.25L 20.5937,24.25L 27.5937,24.25L 27.5937,31.25L 20.5937,31.25 Z M 36.5937,31.25L 36.5937,24.25L 43.5937,24.25L 43.5937,31.25L 36.5937,31.25 Z M 28.5937,31.25L 28.5937,24.25L 35.5937,24.25L 35.5937,31.25L 28.5937,31.25 Z M 30.5937,29.25L 33.5937,29.25L 33.5937,26.25L 30.5937,26.25L 30.5937,29.25 Z " Height="17" Margin="0,6,0,0" UseLayoutRounding="False" VerticalAlignment="Top" HorizontalAlignment="Center" Width="26" />
            </Grid>    
        </Button>
        <Button x:Name="buttonSaveSetting" Margin="9,50,0,0"  Grid.Row="2" Grid.Column="2" Height="44" VerticalAlignment="Top" Style="{StaticResource ButtonStyleAMOT}" Width="44" HorizontalAlignment="Left" Click="buttonSaveSetting_Click">
            <Button.Background>
                <SolidColorBrush Color="{StaticResource ColorAMOTButton}" />
            </Button.Background>
            <Button.Foreground>
                <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
            </Button.Foreground>
            <Grid>
                <TextBlock Margin="2,0,0,0" TextWrapping="Wrap" Text="{Binding ResourceStrings.XTSStringExport, Source={StaticResource LocalizedResources}}" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="9"/>
                <Path Stretch="Fill" Fill="{Binding Foreground, ElementName=buttonTrendsConfigSelect}" Data="F1 M 36.5937,39.25L 36.5937,32.25L 43.5937,32.25L 43.5937,39.25L 36.5937,39.25 Z M 28.5937,39.25L 28.5937,32.25L 35.5937,32.25L 35.5937,39.25L 28.5937,39.25 Z M 20.5937,39.25L 20.5937,32.25L 27.5937,32.25L 27.5937,39.25L 20.5937,39.25 Z M 20.5937,31.25L 20.5937,24.25L 27.5937,24.25L 27.5937,31.25L 20.5937,31.25 Z M 36.5937,31.25L 36.5937,24.25L 43.5937,24.25L 43.5937,31.25L 36.5937,31.25 Z M 28.5937,31.25L 28.5937,24.25L 35.5937,24.25L 35.5937,31.25L 28.5937,31.25 Z M 30.5937,29.25L 33.5937,29.25L 33.5937,26.25L 30.5937,26.25L 30.5937,29.25 Z " Height="17" Margin="0,6,0,0" UseLayoutRounding="False" VerticalAlignment="Top" HorizontalAlignment="Center" Width="26" />
            </Grid>
        </Button>
    </Grid>
</UserControl>
