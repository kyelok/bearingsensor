<UserControl
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	mc:Ignorable="d"
	xmlns:local="clr-namespace:XTS"
	xmlns:xtscontrols="clr-namespace:XTS.Controls"
	x:Class="XTS.SensorReplace"
	d:DesignWidth="1024" d:DesignHeight="546" Width="Auto" Height="Auto" Loaded="SensorReplace_Loaded" Unloaded="SensorReplace_Unloaded">
  <UserControl.Resources>
    <local:SensorReplaceModel x:Key="SensorReplaceModelDataSource" />
  </UserControl.Resources>

  <Grid x:Name="LayoutRoot" DataContext="{Binding Source={StaticResource SensorReplaceModelDataSource}}" Margin="16,16,16,4">
    <xtscontrols:ContentScroll x:Name="contentScrollSensors" Margin="0,0,0,48">
      <xtscontrols:ContentScroll.Background>
        <SolidColorBrush Color="{StaticResource ColorAMOTGlassEffect}" />
      </xtscontrols:ContentScroll.Background>
    </xtscontrols:ContentScroll>
    <Button x:Name="button" HorizontalAlignment="Right" VerticalAlignment="Bottom" Width="88" Height="44" Style="{StaticResource ButtonStyleAMOT}" FontSize="9.333" Click="buttonSlowroll_Click" IsEnabled="{Binding XTSDataSource.EngineData.RPMSlowroll}">
      <Button.Background>
        <SolidColorBrush Color="{StaticResource ColorAMOTButton}" />
      </Button.Background>
      <Button.Foreground>
        <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
      </Button.Foreground>
      <Grid>
        <TextBlock Margin="2,0,0,0" TextWrapping="Wrap" Text="{Binding Path=ResourceStrings.XTSStringSlowroll, Source={StaticResource LocalizedResources}}" VerticalAlignment="Bottom" HorizontalAlignment="Left" />
        <Path Stretch="Fill" Fill="{Binding Foreground, ElementName=button}" Data="F1 M 24,10C 31.732,10 38,16.268 38,24C 38,31.732 31.732,38 24,38C 16.268,38 10,31.732 10,24C 10,16.268 16.268,10 24,10 Z M 16.2218,31.7782L 31.7781,16.2218C 27.4824,11.9261 20.5175,11.9261 16.2218,16.2218C 11.926,20.5176 11.926,27.4824 16.2218,31.7782 Z " HorizontalAlignment="Left" Margin="4,4,0,0" UseLayoutRounding="False" Width="24" Height="24" VerticalAlignment="Top" />
      </Grid>
    </Button>
  </Grid>
</UserControl>
