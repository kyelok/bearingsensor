<UserControl
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:local="clr-namespace:XTS"
	xmlns:xtscontrols="clr-namespace:XTS.Controls"
	xmlns:sdk="http://schemas.microsoft.com/winfx/2006/xaml/presentation/sdk"
	mc:Ignorable="d"
	x:Class="XTS.SurveyorTest"
	d:DesignWidth="1024" d:DesignHeight="546" Width="Auto" Height="Auto" Loaded="SurveyorTest_Loaded" Unloaded="SurveyorTest_Unloaded">
  <UserControl.Resources>
    <local:SurveyorTestModel x:Key="SurveyorTestModelDataSource" />
  </UserControl.Resources>

  <Grid x:Name="LayoutRoot" DataContext="{Binding Source={StaticResource SurveyorTestModelDataSource}}" Margin="0,16,16,16">
    <Grid.RowDefinitions>
      <RowDefinition Height="*" />
      <RowDefinition Height="88" />
    </Grid.RowDefinitions>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="62" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <xtscontrols:Scale x:Name="ScalePrecomp" Margin="0,6,0,8" RenderTransformOrigin="0.5,0.5">
      <xtscontrols:Scale.RenderTransform>
        <CompositeTransform />
      </xtscontrols:Scale.RenderTransform>
    </xtscontrols:Scale>

    <xtscontrols:FitStackPanel x:Name="PanelPrecomp" Margin="4,2,4,4" Padding="2" Grid.Column="1">
      <xtscontrols:FitStackPanel.Background>
        <SolidColorBrush Color="{StaticResource ColorAMOTGlassEffect}" />
      </xtscontrols:FitStackPanel.Background>
    </xtscontrols:FitStackPanel>
    <Button Margin="0,0,52,0" VerticalAlignment="Top" Grid.Column="1" HorizontalAlignment="Left" Width="88" Height="88" Style="{StaticResource ButtonStyleAMOT}" Click="buttonAlarmLevels_Click" Grid.Row="1">
      <Button.Background>
        <SolidColorBrush Color="{StaticResource ColorAMOTButton}" />
      </Button.Background>
      <Button.Foreground>
        <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
      </Button.Foreground>
      <Grid>
        <TextBlock Margin="2,0,0,0" TextWrapping="Wrap" Text="{Binding Path=ResourceStrings.XTSStringAlarmSlowdownLevels, Source={StaticResource LocalizedResources}}" VerticalAlignment="Bottom" HorizontalAlignment="Left" />
        <Path Stretch="Fill" Data="F1 M 24,14C 26,14 36,33 35,34C 34,35 14,35 13,34C 12,33 22,14 24,14 Z M 24,29C 23.1716,29 22.5,29.6716 22.5,30.5C 22.5,31.3284 23.1716,32 24,32C 24.8284,32 25.5,31.3284 25.5,30.5C 25.5,29.6716 24.8284,29 24,29 Z M 22.5,20L 23,28L 25,28L 25.5,20L 22.5,20 Z " Margin="4,4,0,0" UseLayoutRounding="False" HorizontalAlignment="Left" VerticalAlignment="Top" Width="28" Height="25">
          <Path.Fill>
            <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
          </Path.Fill>
        </Path>
        <Path Stretch="Fill" Data="F1 M 20,12L 28,12L 36,20L 36,28L 28,36L 20,36L 12,28L 12,20L 20,12 Z M 16.7218,28.4497L 19.5502,31.2782L 24,26.8284L 28.4497,31.2782L 31.2781,28.4497L 26.8284,24L 31.2782,19.5503L 28.4497,16.7218L 24,21.1716L 19.5502,16.7218L 16.7218,19.5503L 21.1716,24L 16.7218,28.4497 Z " HorizontalAlignment="Left" Height="26" Margin="36,4,0,0" UseLayoutRounding="False" VerticalAlignment="Top" Width="26">
          <Path.Fill>
            <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
          </Path.Fill>
        </Path>
      </Grid>
    </Button>
    <Grid Margin="0" Grid.Row="1" Grid.Column="1" HorizontalAlignment="Center" Width="200" Visibility="Collapsed">
      <Grid.Background>
        <SolidColorBrush Color="{StaticResource ColorAMOTBackgroundOverlay}" />
      </Grid.Background>
      <sdk:Label x:Name="LabelStatus" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="24">
        <sdk:Label.Foreground>
          <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
        </sdk:Label.Foreground>
      </sdk:Label>
    </Grid>
    <ToggleButton x:Name="buttonTest" VerticalAlignment="Top" Style="{StaticResource ToggleButtonStyleAMOT}" Height="88" Click="buttonTest_Click" Grid.Row="1" Grid.Column="1" Width="88" HorizontalAlignment="Right" Margin="0,0,92,0">
      <ToggleButton.Background>
        <SolidColorBrush Color="{StaticResource ColorAMOTButton}" />
      </ToggleButton.Background>
      <ToggleButton.Foreground>
        <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
      </ToggleButton.Foreground>
      <Grid Height="88" Width="88">
        <TextBlock x:Name="TextBlockTest" Margin="2,0,0,0" TextWrapping="Wrap" Text="{Binding Path=ResourceStrings.XTSStringEnable, Source={StaticResource LocalizedResources}}" VerticalAlignment="Bottom" HorizontalAlignment="Left" />
        <Path Stretch="Fill" Data="F1 M 17.0024,12.0017L 18.0025,12.0017C 18.5549,12.0017 19.0026,12.4495 19.0026,13.0018L 19.0026,35.0049C 19.0026,35.5572 18.5549,36.005 18.0025,36.005L 17.0024,36.005C 16.45,36.005 16.0022,35.5572 16.0022,35.0049L 16.0022,13.0018C 16.0022,12.4495 16.45,12.0017 17.0024,12.0017 Z M 20.0028,15.0021C 21.0029,14.3353 22.0031,13.6686 23.67,13.8353C 25.3369,14.002 27.6705,15.0022 29.5041,15.0022C 31.3377,15.0022 32.6712,14.002 34.0047,13.0018L 34.0047,22.0029C 32.6712,23.0031 31.3377,24.0033 29.5041,24.0033C 27.6705,24.0033 25.3369,23.0031 23.67,22.8364C 22.0031,22.6697 21.0029,23.3364 20.0028,24.0032L 20.0028,15.0021 Z " HorizontalAlignment="Left" Height="24.003" Margin="8,6,0,0" UseLayoutRounding="False" VerticalAlignment="Top" Width="18.003">
          <Path.Fill>
            <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
          </Path.Fill>
        </Path>
      </Grid>
    </ToggleButton>
    <Button x:Name="AlarmOutputsButton" Margin="0" VerticalAlignment="Top" Style="{StaticResource ButtonStyleAMOT}" Width="88" Height="88" Grid.Row="1" Grid.Column="1" HorizontalAlignment="Right" Click="buttonTestAlarms_Click">
      <Button.Background>
        <SolidColorBrush Color="{StaticResource ColorAMOTButton}" />
      </Button.Background>
      <Button.Foreground>
        <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
      </Button.Foreground>
      <Grid>
        <TextBlock Margin="2,0,0,0" TextWrapping="Wrap" Text="{Binding Path=ResourceStrings.XTSStringAlarmOutputs, Source={StaticResource LocalizedResources}}" VerticalAlignment="Bottom" HorizontalAlignment="Left" />
        <Grid Width="28" Height="28" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="4,4,0,0">
          <Grid.RowDefinitions>
            <RowDefinition Height="3*" />
            <RowDefinition Height="1*" />
            <RowDefinition Height="3*" />
            <RowDefinition Height="1*" />
            <RowDefinition Height="3*" />
          </Grid.RowDefinitions>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*" />
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="3*" />
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="3*" />
          </Grid.ColumnDefinitions>
          <Rectangle>
            <Rectangle.Fill>
              <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
            </Rectangle.Fill>
          </Rectangle>
          <Rectangle Opacity="0.8" Grid.Column="2">
            <Rectangle.Fill>
              <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
            </Rectangle.Fill>
          </Rectangle>
          <Rectangle Opacity="0.6" Grid.Column="4">
            <Rectangle.Fill>
              <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
            </Rectangle.Fill>
          </Rectangle>
          <Rectangle Opacity="0.8" Grid.Row="2">
            <Rectangle.Fill>
              <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
            </Rectangle.Fill>
          </Rectangle>
          <Rectangle Opacity="0.6" Grid.Row="2" Grid.Column="2">
            <Rectangle.Fill>
              <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
            </Rectangle.Fill>
          </Rectangle>
          <Rectangle Opacity="0.4" Grid.Row="2" Grid.Column="4">
            <Rectangle.Fill>
              <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
            </Rectangle.Fill>
          </Rectangle>
          <Rectangle Opacity="0.6" Grid.Row="4">
            <Rectangle.Fill>
              <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
            </Rectangle.Fill>
          </Rectangle>
          <Rectangle Opacity="0.4" Grid.Row="4" Grid.Column="2">
            <Rectangle.Fill>
              <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
            </Rectangle.Fill>
          </Rectangle>
          <Rectangle Opacity="0.2" Grid.Row="4" Grid.Column="4">
            <Rectangle.Fill>
              <SolidColorBrush Color="{StaticResource ColorAMOTText}" />
            </Rectangle.Fill>
          </Rectangle>
        </Grid>
      </Grid>
    </Button>
  </Grid>
</UserControl>
