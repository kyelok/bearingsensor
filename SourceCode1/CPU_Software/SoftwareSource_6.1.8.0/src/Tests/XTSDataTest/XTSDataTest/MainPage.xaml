<UserControl
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	x:Class="XTSDataTest.MainPage"
	Width="640" Height="480">

	<Grid x:Name="LayoutRoot" Background="White">
		<TextBlock Margin="8,44,8,8" TextWrapping="Wrap"/>
		<StackPanel Height="44" VerticalAlignment="Top" Margin="8" Orientation="Horizontal">
			<ComboBox x:Name="comboBoxTests" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="8,0,0,0" Width="144" SelectionChanged="comboBoxTests_SelectionChanged">
				<TextBlock x:Name="testAlarmList" TextWrapping="Wrap" Text="Alarm List"/>
			</ComboBox>
			<Button x:Name="buttonTest" Content="Test" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="8,0,0,0" Width="40" IsEnabled="False" Click="buttonTest_Click"/>
		</StackPanel>
	</Grid>
</UserControl>