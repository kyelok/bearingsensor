<UserControl x:Class="DataProviderTest.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    d:DesignHeight="480" d:DesignWidth="640" xmlns:sdk="http://schemas.microsoft.com/winfx/2006/xaml/presentation/sdk">

    <Grid x:Name="LayoutRoot" Background="White">
        <sdk:Label HorizontalAlignment="Left" VerticalAlignment="Top" Margin="8,78,0,0" Content="Users:"/>
        <ListBox Height="173" HorizontalAlignment="Left" Margin="8,95,0,0" x:Name="listBoxUsers" VerticalAlignment="Top" Width="300" d:LayoutOverrides="HorizontalAlignment" />
        <Border BorderBrush="Silver" BorderThickness="1" Height="56" HorizontalAlignment="Left" Margin="8,8,0,0" VerticalAlignment="Top" Width="463">
            <Grid>
                <RadioButton Content="WebServer" Height="16" HorizontalAlignment="Left" Margin="8,8,8,0" x:Name="radioButtonWebServer" VerticalAlignment="Top" GroupName="radioButtonsDataProvider" />
                <RadioButton Content="Marketing Mode" Height="16" HorizontalAlignment="Left" Margin="8,30,0,0" x:Name="radioButtonSimulator" VerticalAlignment="Top" IsChecked="True" GroupName="radioButtonsDataProvider" />
                <Button Content="Connect" Height="23" HorizontalAlignment="Right" Margin="0,8,8,0" x:Name="buttonConnect" VerticalAlignment="Top" Width="75" Click="buttonConnect_Click" d:LayoutOverrides="VerticalAlignment" />
                <TextBox Height="27" HorizontalAlignment="Left" Margin="156,4,0,0" Name="textBoxIP" VerticalAlignment="Top" Width="133" Text="10.150.225.126" />
                <sdk:Label Height="25" HorizontalAlignment="Left" Margin="134,10,0,0" Name="label2" Content="(IP:" VerticalAlignment="Top" Width="26" />
                <sdk:Label Height="26" HorizontalAlignment="Left" Margin="295,9,0,0" Name="label3" VerticalAlignment="Top" Width="31" Content=")" />
            </Grid>
        </Border>
        <Border BorderBrush="Silver" BorderThickness="1" Height="173" HorizontalAlignment="Left" Margin="312,95,0,0" VerticalAlignment="Top" Width="159">
            <Grid>
                <RadioButton Content="DC Mode" Height="16" HorizontalAlignment="Left" x:Name="radioButtonSensorModeDCMode" VerticalAlignment="Top" GroupName="radioButtonsSensorMode" IsChecked="False" IsEnabled="False" Margin="10,35,0,0" Width="141" />
                <RadioButton Content="Pulse Mode" GroupName="radioButtonsSensorMode" Height="16" HorizontalAlignment="Left" IsEnabled="False" x:Name="radioButtonSensorModePulseMode" VerticalAlignment="Top" Margin="10,57,0,0" Width="141" />
                <RadioButton Content="DC Peek Hold" GroupName="radioButtonsSensorMode" Height="16" HorizontalAlignment="Left" IsEnabled="False" x:Name="radioButtonSensorModeDCPeekHold" VerticalAlignment="Top" Margin="10,79,0,0" Width="141" />
                <Button Content="Set Sensor Mode" Height="23" HorizontalAlignment="Left" x:Name="buttonSensorMode" VerticalAlignment="Top" Width="145" Margin="6,6,0,0" IsEnabled="False" Click="buttonSensorMode_Click" />
                <sdk:Label Height="22" HorizontalAlignment="Left" Margin="10,143,0,0" x:Name="labelSensorMode" VerticalAlignment="Top" Width="141" Content="-" />
                <sdk:Label Height="17" HorizontalAlignment="Left" Margin="10,120,0,0" x:Name="label1" VerticalAlignment="Top" Width="66" Content="Current:" />
            </Grid>
        </Border>
        <ListBox x:Name="listBoxAlarms" Height="175" VerticalAlignment="Top" Margin="8,296,8,0"/>
        <sdk:Label HorizontalAlignment="Left" VerticalAlignment="Top" Margin="8,280,0,0" Content="Alarms:"/>
        <ComboBox x:Name="comboBoxCylinder" HorizontalAlignment="Right" Margin="0,95,105,0" VerticalAlignment="Top" Width="60" Height="30">
        	<ListBoxItem Content="1"/>
        	<ListBoxItem Content="2"/>
        	<ListBoxItem Content="3"/>
        	<ListBoxItem Content="4"/>
        	<ListBoxItem Content="5"/>
        	<ListBoxItem Content="6"/>
        	<ListBoxItem Content="7"/>
        	<ListBoxItem Content="8"/>
        	<ListBoxItem Content="9"/>
        	<ListBoxItem Content="10"/>
        	<ListBoxItem Content="11"/>
        	<ListBoxItem Content="12"/>
        	<ListBoxItem Content="13"/>
        	<ListBoxItem Content="14"/>
        </ComboBox>
        <ComboBox x:Name="comboBoxSensor" HorizontalAlignment="Right" Margin="0,95,41,0" VerticalAlignment="Top" Width="60" Height="30">
        	<ListBoxItem Content="1"/>
        	<ListBoxItem Content="2"/>
        </ComboBox>
        <Button Content="Send Import File" HorizontalAlignment="Right" Height="25" Margin="0,129,41,0" VerticalAlignment="Top" Width="124" Click="buttonSendImportFile_Click" IsEnabled="False" Name="buttonSendImportFile" />
    </Grid>
</UserControl>
