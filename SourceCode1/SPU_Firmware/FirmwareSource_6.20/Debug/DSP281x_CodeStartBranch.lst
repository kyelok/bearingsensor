      55 00000003 5616      CLRC AMODE
      56 00000004 2901          CLRC SXM
      57 00000005 2908      CLRC C
      58                  
      59 00000006 7622      EALLOW              ;Enable EALLOW protected register access
      60                  
      61 00000007 B9C0      MOVZ DP, #7029h>>6  ;Set data page for WDCR register
      62 00000008 2829      MOV @7029h, #0068h  ;Set WDDIS bit in WDCR to disable WD
         00000009 0068 
      63                  
      64                  ;AJB - setup gpd and turn off the led
      65 0000000a F5A9      MOV       AL,*(0:0x70cd)
         0000000b 70CD 
      66 0000000c 5002      ORB       AL,#0x02 
      67 0000000d F4A9      MOV       *(0:0x70cd),AL
         0000000e 70CD 
      68                  
      69 0000000f 761F!     MOVW      DP,#_gpd                  ;turn off the led
         00000010 0000 
      70 00000011 1800!     AND       @_gpd,#0xfffd    
         00000012 FFFD 
      71                     
      72 00000013 761A      EDIS                ;Disable EALLOW protected register access
      73 00000014 0040!     LB _c_int00       ;Branch to start of boot.asm in RTS library
         00000015 0000 
