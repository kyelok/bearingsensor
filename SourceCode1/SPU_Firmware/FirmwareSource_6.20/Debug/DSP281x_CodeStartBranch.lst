       3              ;// FILE:  DSP281x_CodeStartBranch.asm  
       4              ;//
       5              ;// TITLE: Branch for redirecting code execution after boot. 
       6              ;//
       7              ;//###########################################################################
       8              ;//
       9              ;//  Ver | dd mmm yyyy | Who  | Description of changes
      10              ;// =====|=============|======|===============================================
      11              ;//  1.00| 11 Sep 03   | L.H. | Updated based on D.A source to allow 
      12              ;//      |             |      | disabling the watchdog before branching to
      13              ;//      |             |      | the C init routine.  This is useful if the
      14              ;//      |             |      | watchdog is timing out before main() is reached.
      15              ;//###########################################################################  
      16              
      17              
      18              ***********************************************************************
      19              
      20        0001  WD_DISABLE      .set    1               ;set to 1 to disable WD, else set to 0
      21              
      22                  .ref _c_int00
      23                  .ref _gpd
      24              ***********************************************************************
      25              * Function: codestart section
      26              *
      27              * Description: Branch to code starting point
      28              ***********************************************************************
      29              
      30 00000000           .sect "codestart"
      31              
      32              code_start:
      33                  .if WD_DISABLE == 1
      34 00000000 0040'         LB wd_disable       ;Branch to watchdog disable code
         00000001 0000 
      35              
      36                  .else
      37                      LB _c_int00         ;Branch to start of boot.asm in RTS library
      38                  .endif
      39              
      40              ;end codestart section
      41              
      42              
      43              ***********************************************************************
      44              * Function: wd_disable
      45              *
      46              * Description: Disables the watchdog timer
      47              ***********************************************************************
      48                  .if WD_DISABLE == 1
      49              
      50 00000000           .text
      51 00000000       wd_disable:
      52 00000000 561F      SETC OBJMODE        ;Set OBJMODE for 28x object code
      53 00000001 561A      SETC M0M1MAP
      54 00000002 2940      CLRC PAGE0 ;PAGE0 = 0 not relevant for 28x mode,
